---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KarbonGameStudios — oyun rehberleri, haberler ve içerik arşivi' } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — karbonkafa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="background:#0a0a0a; color:#e5e5e5; margin:0;">
    <nav style="border-bottom: 1px solid #222; padding: 0 24px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #0a0a0a; z-index: 100;">
      <a href="/" style="font-weight: 600; font-size: 15px; letter-spacing: -0.02em;">
        karbon<span style="color: #e5c46b;">kafa</span>
      </a>
      <div style="display: flex; gap: 32px; font-size: 14px; color: #666;">
        <a href="/oyunlar" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">Oyunlar</a>
        <a href="/rehberler" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">Rehberler</a>
        <a href="/haberler" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">Haberler</a>
      </div>
    </nav>

    <main style="max-width: 960px; margin: 0 auto; padding: 48px 24px;">
      <slot />
    </main>

    <footer style="border-top: 1px solid #222; padding: 24px; text-align: center; font-size: 13px; color: #444; margin-top: 80px;">
      KarbonGameStudios © {new Date().getFullYear()}
    </footer>
  </body>
</html>
