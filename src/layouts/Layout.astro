---
import '../styles/global.css';
import ClientRouter from 'astro/components/ClientRouter.astro';
import { t } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KarbonGameStudios — game guides, news and content archive' } = Astro.props;

const apps = [
  { href: '/lists',      icon: '📋', label: 'LİSTELER' },
  { href: '/guides',     icon: '🏆', label: 'REHBERLER' },
  { href: '/news',       icon: '📰', label: 'HABERLER' },
  { href: '/dizi-film',  icon: '🎬', label: 'DİZİ&FİLM' },
  { href: '/schedule',   icon: '📺', label: 'KARBON TV' },
  { href: '/muzik',      icon: '🎵', label: 'MÜZİK' },
  { href: '/yemek',      icon: '🍜', label: 'YEMEK' },
  { href: '/mekan',      icon: '📍', label: 'MEKAN' },
  { href: '/quiz',       icon: '🎮', label: 'QUİZ' },
  { href: '/arcade',     icon: '🕹', label: 'ARCADE' },
];
---

<!doctype html>
<html lang="tr" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — karbonkafa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=VT323&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <ClientRouter />
  </head>
  <body style="background:#0a0a0a; color:#e5e5e5; margin:0; padding-bottom: 72px;">

    <div style="position: fixed; inset: 0; background: radial-gradient(ellipse at 20% 50%, #0a0a1a 0%, #050508 70%); pointer-events: none; z-index: -1;"></div>

    <button id="langToggle" style="display:none;">EN</button>

    <main style="max-width: 960px; margin: 0 auto; padding: 20px 24px;">

      <!-- System bar -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; padding: 4px 0; border-bottom: 1px solid #1e1e2e;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/" style="display:flex;align-items:center;text-decoration:none;">
            <img src="/logo.png" alt="Karbon OS" style="width:28px;height:28px;image-rendering:pixelated;" />
          </a>
          <span style="font-family: 'VT323', monospace; font-size: 14px; color: #ef4444; letter-spacing: 0.06em;">ALPHA VERSION</span>
        </div>
      </div>

      <!-- Radio + System Info -->
      <div class="layout-sys-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 6px;">

        <!-- Radio -->
        <div style="background:#0d0d12;border:1px solid #3b82f622;">
          <div id="radio-body" style="padding:6px 12px;display:flex;align-items:center;gap:10px;">
            <span style="font-family:'VT323',monospace;font-size:13px;color:#3b82f644;flex-shrink:0;letter-spacing:0.04em;">🎧 RADYO</span>
            <button id="radio-play"
              style="font-family:'VT323',monospace;font-size:14px;background:none;border:1px solid #3b82f666;color:#3b82f6;padding:1px 8px;cursor:pointer;letter-spacing:0.06em;transition:all 0.15s;flex-shrink:0;"
              onmouseover="this.style.borderColor='#3b82f6'" onmouseout="this.style.borderColor='#3b82f666'">
              ▶ BAŞLAT
            </button>
            <div id="radio-status" style="display:flex;align-items:center;gap:5px;flex:1;min-width:0;">
              <span id="radio-dot" style="width:6px;height:6px;border-radius:50%;background:#333344;display:inline-block;flex-shrink:0;"></span>
              <span id="radio-label" style="font-family:'VT323',monospace;font-size:14px;color:#555566;letter-spacing:0.04em;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">HAZIR</span>
            </div>
            <input id="radio-vol" type="range" min="0" max="100" value="25"
              style="width:50px;accent-color:#3b82f6;flex-shrink:0;" />
            <span id="radio-close" style="font-family:'VT323',monospace;font-size:16px;color:#333344;cursor:pointer;flex-shrink:0;padding:0 2px;"
              onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#333344'">×</span>
          </div>
        </div>

        <!-- System Info -->
        <div style="background:#0d0d12;border:1px solid #1e1e2e;">
          <div style="padding:6px 12px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
              <a id="sysLogin" href="/auth/login" style="display:none;font-family:'VT323',monospace;font-size:14px;color:#888899;border:1px solid #2a2a3a;padding:1px 8px;text-decoration:none;transition:all 0.1s;"
                onmouseover="this.style.color='#e5c46b';this.style.borderColor='#e5c46b55'" onmouseout="this.style.color='#888899';this.style.borderColor='#2a2a3a'">
                👤 GİRİŞ
              </a>
              <div id="sysProfile" style="display:none;align-items:center;gap:6px;">
                <div id="sysAvatar" style="width:20px;height:20px;background:#1a1a2a;border:1px solid #2a2a3a;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'VT323',monospace;font-size:10px;color:#e5c46b;flex-shrink:0;"></div>
                <span id="sysUser" style="font-family:'VT323',monospace;font-size:14px;color:#aaaacc;"></span>
              </div>
            </div>
            <div style="display:flex;align-items:baseline;gap:6px;flex-shrink:0;">
              <span id="sysDate2" style="font-family:'VT323',monospace;font-size:12px;color:#444455;"></span>
              <span id="sysClock2" style="font-family:'VT323',monospace;font-size:17px;color:#aaaacc;line-height:1;"></span>
            </div>
            <button id="langToggle2"
              style="font-family:'VT323',monospace;font-size:14px;background:none;border:1px solid #e5c46b33;color:#e5c46b66;padding:1px 7px;cursor:pointer;transition:all 0.1s;flex-shrink:0;"
              onmouseover="this.style.color='#e5c46b';this.style.borderColor='#e5c46b'" onmouseout="this.style.color='#e5c46b66';this.style.borderColor='#e5c46b33'">
              EN
            </button>
          </div>
        </div>
      </div>

      <!-- Apps bar -->
      <div style="background:#0d0d12;border:1px solid #1e1e2e;margin-bottom:8px;">
        <div style="padding:1px 8px;display:flex;gap:0;flex-wrap:nowrap;overflow-x:auto;">
          <a href="/" class="app-icon" style="flex-shrink:0;min-width:56px;">
            <div style="width:36px;height:36px;overflow:hidden;border:1px solid #e5c46b22;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
              <img src="/logo.png" alt="Ana Sayfa" style="width:100%;height:100%;object-fit:cover;image-rendering:pixelated;" />
            </div>
            <span class="icon-label">ANA SAYFA</span>
          </a>
          {apps.map(app => (
            <a href={app.href} class="app-icon" style="flex:1;min-width:56px;">
              <div style="width:36px;height:36px;border:1px solid #1e1e2e;background:#080810;display:flex;align-items:center;justify-content:center;font-size:18px;">{app.icon}</div>
              <span class="icon-label">{app.label}</span>
            </a>
          ))}
        </div>
      </div>

      <slot />
    </main>

    <!-- Sticky Bottom Taskbar -->
    <div style="position:fixed;bottom:0;left:0;right:0;z-index:200;background:#050508;border-top:2px solid #1e1e2e;display:flex;align-items:stretch;height:48px;box-shadow:0 -4px 0 #020205;">

      <a href="/" style="display:flex;align-items:center;gap:6px;padding:0 14px;border-right:1px solid #1e1e2e;text-decoration:none;transition:background 0.1s;flex-shrink:0;"
        onmouseover="this.style.background='#0d0d12'" onmouseout="this.style.background='none'">
        <div style="width:16px;height:16px;background:#e5c46b;display:flex;align-items:center;justify-content:center;font-family:'VT323',monospace;font-size:11px;color:#000;font-weight:900;flex-shrink:0;">K</div>
      </a>

      <div style="display:flex;align-items:stretch;overflow-x:auto;flex:1;min-width:0;">
        {apps.map(app => (
          <a href={app.href}
            style="display:flex;align-items:center;justify-content:center;padding:0 12px;font-size:16px;border-right:1px solid #1e1e2e;text-decoration:none;transition:background 0.1s;flex-shrink:0;"
            onmouseover="this.style.background='#0d0d12'" onmouseout="this.style.background='none'">
            {app.icon}
          </a>
        ))}
      </div>

      <div style="display:flex;align-items:center;gap:8px;padding:0 12px;border-left:1px solid #1e1e2e;flex-shrink:0;">
        <button id="taskbarRadioBtn"
          style="font-family:'VT323',monospace;font-size:16px;background:#0d0d12;border:1px solid #1e1e2e;color:#3b82f6;padding:3px 10px;cursor:pointer;transition:all 0.1s;"
          onmouseover="this.style.borderColor='#3b82f6'" onmouseout="this.style.borderColor='#1e1e2e'">
          🎧 ▶
        </button>
        <span id="taskbarRadioStatus" style="font-family:'VT323',monospace;font-size:13px;color:#333344;white-space:nowrap;display:none;">●</span>
      </div>

      <div style="display:flex;align-items:center;border-left:1px solid #1e1e2e;flex-shrink:0;">
        <a id="taskbarLogin" href="/auth/login" style="display:none;align-items:center;padding:0 12px;font-family:'VT323',monospace;font-size:14px;color:#555566;text-decoration:none;transition:all 0.1s;height:100%;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#555566'">
          👤
        </a>
        <a id="taskbarProfile" href="#" style="display:none;align-items:center;padding:0 12px;font-family:'VT323',monospace;font-size:14px;color:#aaaacc;text-decoration:none;transition:all 0.1s;height:100%;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#aaaacc'">
          <div id="taskbarAvatar" style="width:20px;height:20px;border-radius:50%;background:#1a1a2a;border:1px solid #2a2a3a;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:11px;color:#e5c46b;"></div>
        </a>
      </div>

    </div>

    <footer style="border-top: 1px solid #1e1e2e; padding: 16px 24px; text-align: center; font-family:'VT323',monospace; font-size: 16px; color: #333344; letter-spacing:0.04em;">
      KARBONGAMESTUDIOS © {new Date().getFullYear()} — KARBON OS ALPHA
    </footer>
  </body>
</html>

<style>
  @media (max-width: 600px) {
    .layout-sys-row { grid-template-columns: 1fr !important; }
  }
  .app-icon { padding: 2px 6px; }
</style>

<!-- i18n: inline so translations are available, astro:after-swap for re-apply on navigation -->
<script is:inline define:vars={{ translations: t }}>
  window.i18nTranslations = translations;

  let lang = localStorage.getItem('lang') || 'tr';

  function applyLang(l) {
    lang = l;
    localStorage.setItem('lang', l);
    const html = document.getElementById('html-root');
    if (html) html.setAttribute('lang', l);
    const btn = document.getElementById('langToggle');
    if (btn) btn.textContent = l === 'tr' ? 'EN' : 'TR';
    const btn2 = document.getElementById('langToggle2');
    if (btn2) btn2.textContent = l === 'tr' ? 'EN' : 'TR';
    const dict = (window.i18nTranslations || {})[l] || {};
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });
    document.querySelectorAll('[data-i18n-tr]').forEach(el => {
      const text = el.getAttribute('data-i18n-' + l);
      if (text) el.textContent = text;
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key && dict[key]) el.placeholder = dict[key];
    });
    document.querySelectorAll('option[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });
  }

  function attachLangListeners() {
    const btn = document.getElementById('langToggle');
    if (btn && !btn.dataset.kbLang) {
      btn.dataset.kbLang = '1';
      btn.addEventListener('click', () => applyLang(lang === 'tr' ? 'en' : 'tr'));
    }
    const btn2 = document.getElementById('langToggle2');
    if (btn2 && !btn2.dataset.kbLang) {
      btn2.dataset.kbLang = '1';
      btn2.addEventListener('click', () => document.getElementById('langToggle')?.click());
    }
  }

  applyLang(lang);
  attachLangListeners();

  // Re-apply on View Transitions navigation
  document.addEventListener('astro:after-swap', () => {
    attachLangListeners();
    applyLang(lang);
  });
</script>

<script>
  import { createClient } from '@supabase/supabase-js';

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  // ── CLOCK ──────────────────────────────────────────────────
  function startClock() {
    if ((window as any).kbClockInterval) clearInterval((window as any).kbClockInterval);
    function tick() {
      const now = new Date();
      const time = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const date = now.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });
      const c = document.getElementById('sysClock2'); if (c) c.textContent = time;
      const d = document.getElementById('sysDate2'); if (d) d.textContent = date;
    }
    tick();
    (window as any).kbClockInterval = setInterval(tick, 1000);
  }
  startClock();

  // ── AUTH ───────────────────────────────────────────────────
  async function initAuth() {
    const { data: { user } } = await sb.auth.getUser();

    const taskbarLoginEl = document.getElementById('taskbarLogin') as HTMLAnchorElement;
    const taskbarProfileEl = document.getElementById('taskbarProfile') as HTMLAnchorElement;
    const taskbarAvatarEl = document.getElementById('taskbarAvatar');
    const sysLoginEl = document.getElementById('sysLogin');
    const sysProfileEl = document.getElementById('sysProfile') as HTMLElement;
    const sysAvatarEl = document.getElementById('sysAvatar');
    const sysUserEl = document.getElementById('sysUser');

    if (!user) {
      if (taskbarLoginEl) taskbarLoginEl.style.display = 'flex';
      if (sysLoginEl) sysLoginEl.style.display = 'inline-flex';
      return;
    }

    const { data: profile } = await sb.from('profiles')
      .select('username,display_name,avatar_url')
      .eq('id', user.id).single();
    if (!profile) return;

    // Taskbar
    if (taskbarProfileEl) { taskbarProfileEl.href = `/u/${profile.username}`; taskbarProfileEl.style.display = 'flex'; }
    if (taskbarAvatarEl) {
      taskbarAvatarEl.innerHTML = '';
      if (profile.avatar_url) {
        const img = document.createElement('img');
        img.src = profile.avatar_url;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
        taskbarAvatarEl.appendChild(img);
      } else {
        taskbarAvatarEl.textContent = (profile.display_name || profile.username)[0].toUpperCase();
      }
    }

    // System panel
    if (sysProfileEl) sysProfileEl.style.display = 'flex';
    if (sysAvatarEl) {
      sysAvatarEl.innerHTML = '';
      if (profile.avatar_url) {
        const img = document.createElement('img');
        img.src = profile.avatar_url;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
        sysAvatarEl.appendChild(img);
      } else {
        sysAvatarEl.textContent = (profile.display_name || profile.username)[0].toUpperCase();
      }
    }
    if (sysUserEl) sysUserEl.textContent = (profile.display_name || profile.username || '').toUpperCase();
  }
  initAuth();

  // ── RADIO ──────────────────────────────────────────────────
  const STREAMS = [
    'https://ice4.somafm.com/groovesalad-256-mp3',
    'https://stream.radioparadise.com/mp3-192',
    'https://ice6.somafm.com/cliqhop-256-mp3',
    'https://ice4.somafm.com/spacestation-256-mp3',
  ];

  // Global state persists across View Transitions navigations
  if (!(window as any).kbRadio) {
    (window as any).kbRadio = { audio: null as HTMLAudioElement | null, playing: false, streamIdx: 0, autoStarted: false, loading: false };
  }
  const rs = (window as any).kbRadio as { audio: HTMLAudioElement | null; playing: boolean; streamIdx: number; autoStarted: boolean; loading: boolean };

  function bindRadio() {
    const playBtn  = document.getElementById('radio-play') as HTMLButtonElement;
    const dot      = document.getElementById('radio-dot') as HTMLElement;
    const lbl      = document.getElementById('radio-label') as HTMLElement;
    const vol      = document.getElementById('radio-vol') as HTMLInputElement;
    const closeBtn = document.getElementById('radio-close') as HTMLElement;
    const tbBtn    = document.getElementById('taskbarRadioBtn') as HTMLButtonElement;
    const tbStatus = document.getElementById('taskbarRadioStatus') as HTMLElement;

    if (!playBtn) return;

    function setStatus(state: 'playing'|'loading'|'stopped'|'error') {
      const map = {
        playing: { color:'#22c55e', text:'YAYIN — CANLI', btn:'■ DURDUR' },
        loading: { color:'#f59e0b', text:'BAĞLANIYOR...', btn:'...' },
        stopped: { color:'#333344', text:'HAZIR',          btn:'▶ BAŞLAT' },
        error:   { color:'#ef4444', text:'HATA',           btn:'▶ BAŞLAT' },
      };
      const s = map[state];
      if (dot) { dot.style.background = s.color; dot.style.animation = state === 'playing' ? 'pulse 2s infinite' : ''; }
      if (lbl) { lbl.style.color = s.color; lbl.textContent = s.text; }
      if (playBtn) playBtn.textContent = s.btn;
      const isPlaying = state === 'playing';
      if (tbBtn) { tbBtn.textContent = isPlaying ? '🎧 ■' : '🎧 ▶'; tbBtn.style.color = isPlaying ? '#22c55e' : '#3b82f6'; }
      if (tbStatus) tbStatus.style.display = isPlaying ? 'inline' : 'none';
    }

    function tryStream(idx: number) {
      rs.streamIdx = idx;
      if (idx >= STREAMS.length) { setStatus('error'); rs.playing = false; rs.loading = false; return; }
      if (rs.audio) { rs.audio.pause(); rs.audio.src = ''; }
      rs.audio = new Audio();
      rs.audio.volume = Number(vol?.value ?? 25) / 100;
      rs.audio.src = STREAMS[idx];
      rs.loading = true;
      setStatus('loading');
      rs.audio.play()
        .then(() => { rs.loading = false; setStatus('playing'); rs.playing = true; })
        .catch(() => tryStream(idx + 1));
      rs.audio.onerror = () => tryStream(idx + 1);
    }

    // Restore UI from global state
    if (rs.playing && rs.audio) {
      setStatus('playing');
      rs.audio.onerror = () => tryStream(rs.streamIdx + 1);
    } else if (rs.loading) {
      setStatus('loading');
    } else {
      setStatus('stopped');
    }

    if (vol && rs.audio) vol.value = String(Math.round(rs.audio.volume * 100));

    // Auto-start on first visit: try immediately, fallback to first user click
    if (!rs.autoStarted) {
      rs.autoStarted = true;
      if (vol) vol.value = '25';
      tryStream(0);

      const retryOnClick = () => {
        if (!rs.playing && !rs.loading) tryStream(0);
        document.removeEventListener('click', retryOnClick);
        document.removeEventListener('keydown', retryOnClick);
      };
      document.addEventListener('click', retryOnClick);
      document.addEventListener('keydown', retryOnClick);
    }

    playBtn.addEventListener('click', () => {
      if (rs.playing) { rs.audio?.pause(); rs.playing = false; setStatus('stopped'); }
      else tryStream(0);
    });

    vol?.addEventListener('input', () => { if (rs.audio) rs.audio.volume = Number(vol.value) / 100; });

    closeBtn?.addEventListener('click', () => {
      rs.audio?.pause(); rs.playing = false;
      const card = closeBtn.closest('.px-window') as HTMLElement;
      if (card) card.style.display = 'none';
      setStatus('stopped');
    });

    tbBtn?.addEventListener('click', () => playBtn.click());
  }

  // Call directly for initial load + via event for View Transitions navigations
  startClock();
  initAuth();
  bindRadio();
  document.addEventListener('astro:page-load', () => {
    startClock();
    initAuth();
    bindRadio();
  });
</script>
