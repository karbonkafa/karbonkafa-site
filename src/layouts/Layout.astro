---
import '../styles/global.css';
import { t } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KarbonGameStudios — game guides, news and content archive' } = Astro.props;
---

<!doctype html>
<html lang="tr" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — karbonkafa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="background:#0a0a0a; color:#e5e5e5; margin:0;">
    <nav style="border-bottom: 1px solid #222; padding: 0 24px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #0a0a0a; z-index: 100;">
      <a href="/" style="font-weight: 600; font-size: 15px; letter-spacing: -0.02em;">
        karbon<span style="color: #e5c46b;">kafa</span>
      </a>
      <div style="display: flex; align-items: center; gap: 28px; font-size: 14px; color: #666;">
        <a href="/games" data-i18n="nav.games" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">{t.en['nav.games']}</a>
        <a href="/guides" data-i18n="nav.guides" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">{t.en['nav.guides']}</a>
        <a href="/news" data-i18n="nav.news" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">{t.en['nav.news']}</a>
        <!-- Lang toggle -->
        <button id="langToggle" style="background: none; border: 1px solid #333; color: #666; font-size: 11px; padding: 3px 8px; cursor: pointer; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; transition: all 0.15s;"
          onmouseover="this.style.borderColor='#e5c46b';this.style.color='#e5c46b'"
          onmouseout="this.style.borderColor='#333';this.style.color='#666'">
          EN
        </button>
      </div>
    </nav>

    <main style="max-width: 960px; margin: 0 auto; padding: 48px 24px;">
      <slot />
    </main>

    <footer style="border-top: 1px solid #222; padding: 24px; text-align: center; font-size: 13px; color: #444; margin-top: 80px;">
      KarbonGameStudios © {new Date().getFullYear()}
    </footer>
  </body>
</html>

<script define:vars={{ translations: t }}>
  const btn = document.getElementById('langToggle');
  const html = document.getElementById('html-root');
  let lang = localStorage.getItem('lang') || 'en';

  function applyLang(l) {
    lang = l;
    localStorage.setItem('lang', l);
    html.setAttribute('lang', l);
    btn.textContent = l === 'tr' ? 'EN' : 'TR';
    const dict = translations[l];

    // data-i18n key-based
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });

    // data-i18n-tr / data-i18n-en direct text pairs
    document.querySelectorAll('[data-i18n-tr]').forEach(el => {
      const text = el.getAttribute(`data-i18n-${l}`);
      if (text) el.textContent = text;
    });

    // placeholder translations
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key && dict[key]) (el as HTMLInputElement).placeholder = dict[key];
    });

    // option translations
    document.querySelectorAll('option[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });
  }

  applyLang(lang);

  btn.addEventListener('click', () => {
    applyLang(lang === 'tr' ? 'en' : 'tr');
  });
</script>
