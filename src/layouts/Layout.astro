---
import '../styles/global.css';
import { t } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KarbonGameStudios — game guides, news and content archive' } = Astro.props;
---

<!doctype html>
<html lang="tr" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — karbonkafa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="background:#0a0a0a; color:#e5e5e5; margin:0;">
    <nav style="border-bottom: 1px solid #222; padding: 0 24px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #0a0a0a; z-index: 100;">
      <a href="/" style="font-weight: 600; font-size: 15px; letter-spacing: -0.02em;">
        karbon<span style="color: #e5c46b;">kafa</span>
      </a>
      <div style="display: flex; align-items: center; gap: 28px; font-size: 14px; color: #666;">
        <a href="/lists" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">Listeler</a>
        <a href="/guides" data-i18n="nav.guides" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">{t.tr['nav.guides']}</a>
        <a href="/news" data-i18n="nav.news" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">{t.tr['nav.news']}</a>
        <a href="/schedule" style="transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#666'">Akış</a>
        <a href="/quiz" style="transition: color 0.15s; color: #e5c46b44;" onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#e5c46b44'">Quiz</a>
        <!-- Auth -->
        <div id="navAuth" style="display: flex; align-items: center; gap: 12px; position: relative;">
          <a id="navLogin" href="/auth/login" style="font-size: 12px; border: 1px solid #333; color: #555; padding: 4px 12px; font-family: 'JetBrains Mono', monospace; transition: all 0.15s; display: none;"
            onmouseover="this.style.borderColor='#555';this.style.color='#aaa'" onmouseout="this.style.borderColor='#333';this.style.color='#555'">Giriş</a>
          <div id="navProfileWrap" style="display: none; position: relative;">
            <button id="navProfileBtn" style="display: flex; align-items: center; gap: 6px; background: none; border: none; cursor: pointer; padding: 0;">
              <div id="navAvatar" style="width: 26px; height: 26px; border-radius: 50%; overflow: hidden; background: #222; border: 1px solid #333; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #e5c46b;"></div>
            </button>
            <div id="navDropdown" style="display: none; position: absolute; top: calc(100% + 8px); right: 0; background: #111; border: 1px solid #222; min-width: 140px; z-index: 100; box-shadow: 0 8px 24px rgba(0,0,0,0.5);">
              <a id="navProfileLink" href="#" style="display: block; padding: 10px 16px; font-size: 13px; color: #ccc; text-decoration: none; border-bottom: 1px solid #1a1a1a; transition: background 0.1s;"
                onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='none'">Profil</a>
              <a href="/lists/create" style="display: block; padding: 10px 16px; font-size: 13px; color: #ccc; text-decoration: none; border-bottom: 1px solid #1a1a1a; transition: background 0.1s;"
                onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='none'">+ Yeni Liste</a>
              <a href="/u/edit" style="display: block; padding: 10px 16px; font-size: 13px; color: #ccc; text-decoration: none; border-bottom: 1px solid #1a1a1a; transition: background 0.1s;"
                onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='none'">Profili Düzenle</a>
              <a href="/auth/logout" style="display: block; padding: 10px 16px; font-size: 13px; color: #666; text-decoration: none; transition: background 0.1s;"
                onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='none'">Çıkış Yap</a>
            </div>
          </div>
        </div>
        <!-- Lang toggle -->
        <button id="langToggle" style="background: none; border: 1px solid #e5c46b44; color: #e5c46b; font-size: 11px; padding: 3px 10px; cursor: pointer; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.08em; transition: all 0.15s;"
          onmouseover="this.style.background='#e5c46b22'"
          onmouseout="this.style.background='none'">
          EN
        </button>
      </div>
    </nav>

    <main style="max-width: 960px; margin: 0 auto; padding: 48px 24px;">
      <slot />
    </main>

    <footer style="border-top: 1px solid #222; padding: 24px; text-align: center; font-size: 13px; color: #444; margin-top: 80px;">
      KarbonGameStudios © {new Date().getFullYear()}
    </footer>
  </body>
</html>

<script define:vars={{ translations: t }}>
  const btn = document.getElementById('langToggle');
  const html = document.getElementById('html-root');
  let lang = localStorage.getItem('lang') || 'tr';

  function applyLang(l) {
    lang = l;
    localStorage.setItem('lang', l);
    html.setAttribute('lang', l);
    btn.textContent = l === 'tr' ? 'EN' : 'TR';
    const dict = translations[l];

    // data-i18n key-based
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });

    // data-i18n-tr / data-i18n-en direct text pairs
    document.querySelectorAll('[data-i18n-tr]').forEach(el => {
      const text = el.getAttribute(`data-i18n-${l}`);
      if (text) el.textContent = text;
    });

    // placeholder translations
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key && dict[key]) el.placeholder = dict[key];
    });

    // option translations
    document.querySelectorAll('option[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });
  }

  applyLang(lang);

  btn.addEventListener('click', () => {
    applyLang(lang === 'tr' ? 'en' : 'tr');
  });
</script>

<script>
  import { createClient } from '@supabase/supabase-js';
  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );
  const loginEl = document.getElementById('navLogin');
  const wrapEl = document.getElementById('navProfileWrap');
  const avatarEl = document.getElementById('navAvatar');
  const profileLinkEl = document.getElementById('navProfileLink') as HTMLAnchorElement | null;
  const dropdownEl = document.getElementById('navDropdown');
  const profileBtnEl = document.getElementById('navProfileBtn');

  sb.auth.getUser().then(async ({ data: { user } }) => {
    if (!user) {
      if (loginEl) loginEl.style.display = 'inline-flex';
      return;
    }
    const { data: profile } = await sb.from('profiles').select('username,display_name,avatar_url').eq('id', user.id).single();
    if (!profile || !wrapEl || !avatarEl) return;
    if (profileLinkEl) profileLinkEl.href = `/u/${profile.username}`;
    if (profile.avatar_url) {
      const img = document.createElement('img');
      img.src = profile.avatar_url;
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
      avatarEl.innerHTML = '';
      avatarEl.appendChild(img);
    } else {
      avatarEl.textContent = (profile.display_name || profile.username)[0].toUpperCase();
    }
    wrapEl.style.display = 'block';

    // Toggle dropdown
    profileBtnEl?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (dropdownEl) dropdownEl.style.display = dropdownEl.style.display === 'none' ? 'block' : 'none';
    });
    document.addEventListener('click', () => {
      if (dropdownEl) dropdownEl.style.display = 'none';
    });
  });
</script>
