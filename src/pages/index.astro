---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 7);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 9);
const featuredNews = latestNews.slice(0, 3);
const smallNews = latestNews.slice(3);
---

<Layout title="KARBON OS">

  <!-- Bento grid -->
  <div class="bento">

    <!-- LISTS -->
    <div class="bento-lists px-window">
      <div class="px-titlebar" style="border-left-color: #e5c46b;">
        <a class="px-title" href="/lists" style="color:#e5c46b;text-decoration:none;transition:opacity 0.1s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">📋 LİSTELER.EXE</a>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div style="display: flex; flex-direction: column;">
        {lists.map(list => {
          const slugs = list.games.map((i: any) => i.slug);
          return (
            <a href={`/lists/${list.slug}`}
              style="display: block; padding: 8px 12px; border-bottom: 1px solid #1e1e2e; transition: background 0.15s;"
              onmouseover="this.style.background='#111118'" onmouseout="this.style.background='none'">
              <div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;">
                <p style="font-family:'VT323',monospace;font-size:18px;color:#ffffff;margin:0;letter-spacing:0.02em;line-height:1.2;">{list.title}</p>
                <span style="font-family:'VT323',monospace;font-size:13px;color:#444455;flex-shrink:0;">{list.games.length} oyun</span>
              </div>
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
                <div style="display:flex;gap:2px;flex-wrap:wrap;">
                  {slugs.slice(0, 17).map((slug: string) => {
                    const g = gmap[slug];
                    const cover = g?.coverUrl;
                    return cover ? (
                      <div style="width:40px;height:40px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
                        <img src={cover} alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" loading="lazy"/>
                      </div>
                    ) : <div style="width:40px;height:40px;background:#0d0d12;border:1px solid #1e1e2e;flex-shrink:0;"></div>;
                  })}
                </div>
                <div class="list-avatar" data-username={list.author.toLowerCase()}
                  style="width:40px;height:40px;background:#1a1a2a;border:1px solid #2a2a3a;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'VT323',monospace;font-size:14px;color:#e5c46b;flex-shrink:0;">
                  {list.author[0].toUpperCase()}
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <a href="/lists" style="display:block;padding:11px 14px;font-family:'VT323',monospace;font-size:16px;color:#555566;text-align:center;letter-spacing:0.06em;transition:color 0.1s;"
        onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#555566'">
        [ TÜM LİSTELER → ]
      </a>
    </div>

    <!-- NEWS -->
    <div class="bento-news px-window">
      <div class="px-titlebar">
        <a class="px-title" href="/news" style="text-decoration:none;transition:opacity 0.1s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">📰 HABERLER.LOG</a>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-bottom: 1px solid #1e1e2e;">
        {featuredNews.map((article, i) => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style={`display: block; padding: 14px; border-right: 1px solid #1e1e2e; transition: background 0.1s; ${i===2?'border-right:none':''}`}
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              {article.data.image && (
                <div style="width: 100%; height: 90px; overflow: hidden; margin-bottom: 10px; border: 1px solid #1e1e2e;">
                  <img src={article.data.image} alt="" loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.85;" />
                </div>
              )}
              <span style="font-family:'VT323',monospace;font-size:13px;color:#666677;display:block;margin-bottom:4px;">{dateStr}</span>
              <p style="font-size:13px;font-weight:500;color:#d0d0e0;margin:0 0 5px;line-height:1.35;">{article.data.title}</p>
              {article.data.excerpt && (
                <p style="font-size:12px;color:#778899;margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{article.data.excerpt}</p>
              )}
            </a>
          );
        })}
      </div>
      <div>
        {smallNews.map(article => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style="display: flex; align-items: baseline; gap: 12px; padding: 9px 14px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              <span style="font-family:'VT323',monospace;font-size:13px;color:#666677;white-space:nowrap;flex-shrink:0;">{dateStr}</span>
              <p style="font-size:13px;color:#aaa;margin:0;line-height:1.35;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">{article.data.title}</p>
            </a>
          );
        })}
        <a href="/news" style="display:block;padding:10px 14px;font-family:'VT323',monospace;font-size:15px;color:#666677;text-align:center;letter-spacing:0.06em;transition:color 0.1s;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#666677'">
          [ TÜM HABERLER → ]
        </a>
      </div>
    </div>

    <!-- WEATHER — full width -->
    <div id="weatherPanel" class="bento-weather px-window">
      <div class="px-titlebar" style="border-left-color:#06b6d4;">
        <span class="px-title" style="color:#06b6d4;">🌍 DÜNYA / HAVA</span>
        <div class="px-btns"><span class="px-btn">×</span></div>
      </div>
      <div id="worldWidget" style="display:flex;flex-wrap:wrap;gap:0;">
        <div style="padding:8px 12px;font-family:'VT323',monospace;font-size:16px;color:#778899;letter-spacing:0.04em;">YÜKLENİYOR...</div>
      </div>
    </div>

    <!-- QUIZ -->
    <a id="quizPanel" href="/quiz" class="bento-quiz px-window" style="text-decoration:none;display:flex;flex-direction:column;border-color:#22c55e44;transition:border-color 0.15s;"
      onmouseover="this.style.borderColor='#22c55e'" onmouseout="this.style.borderColor='#22c55e44'">
      <div class="px-titlebar" style="border-left-color:#22c55e;">
        <a class="px-title" href="/quiz" style="color:#22c55e;text-decoration:none;transition:opacity 0.1s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">🎮 QUİZ.EXE</a>
        <div class="px-btns"><span class="px-btn" style="color:#22c55e;">▶</span></div>
      </div>
      <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:12px;">
        <p style="font-family:'VT323',monospace;font-size:26px;color:#22c55e;margin:0;letter-spacing:0.06em;">[ BAŞLAT ]</p>
      </div>
    </a>

    <!-- GTA COUNTDOWN -->
    <div id="gtaPanel" class="bento-gta px-window" style="display:flex;flex-direction:column;border-color:#e5c46b44;">
      <div class="px-titlebar" style="border-left-color:#ef4444;">
        <span class="px-title" style="color:#ef4444;">📺 GTA VI SAYAÇ</span>
        <div class="px-btns"><span class="px-btn">×</span></div>
      </div>
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px;text-align:center;">
        <p style="font-family:'VT323',monospace;font-size:14px;color:#666677;margin:0 0 4px;letter-spacing:0.04em;">19 KASIM 2026'YA</p>
        <div id="gtaPixelCount" style="font-family:'VT323',monospace;font-size:34px;color:#e5c46b;line-height:1;margin-bottom:3px;">-- GÜN</div>
        <p style="font-family:'VT323',monospace;font-size:12px;color:#444455;margin:0;letter-spacing:0.04em;">GTA TARİHİ SEZONU</p>
      </div>
    </div>

    <!-- ARCADE -->
    <a id="arcadePanel" href="/arcade" class="bento-arcade px-window" style="text-decoration:none;display:flex;flex-direction:column;border-color:#f9731644;transition:border-color 0.15s;"
      onmouseover="this.style.borderColor='#f97316'" onmouseout="this.style.borderColor='#f9731644'">
      <div class="px-titlebar" style="border-left-color:#f97316;">
        <a class="px-title" href="/arcade" style="color:#f97316;text-decoration:none;transition:opacity 0.1s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">🕹 ARCADE.EXE</a>
        <div class="px-btns"><span class="px-btn" style="color:#f97316;">▶</span></div>
      </div>
      <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:12px;">
        <p style="font-family:'VT323',monospace;font-size:26px;color:#f97316;margin:0;letter-spacing:0.06em;">[ OYNA ]</p>
      </div>
    </a>

  </div>

</Layout>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-areas:
      "lists    lists    lists"
      "news     news     news"
      "weather  weather  weather"
      "quiz     gta      arcade";
    gap: 6px;
    align-items: stretch;
  }
  .bento-lists   { grid-area: lists; }
  .bento-news    { grid-area: news; }
  .bento-weather { grid-area: weather; }
  .bento-quiz    { grid-area: quiz; }
  .bento-gta     { grid-area: gta; }
  .bento-arcade  { grid-area: arcade; }

  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "lists   lists"
        "news    news"
        "weather weather"
        "quiz    gta"
        "arcade  arcade";
    }
  }
  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas: "lists" "news" "weather" "quiz" "gta" "arcade";
    }
    .icon-box { width: 44px; height: 44px; font-size: 22px; }
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';
  const _sb = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

  (async () => {
    const els = document.querySelectorAll<HTMLElement>('.list-avatar');
    const usernames = [...new Set([...els].map(el => el.dataset.username!).filter(Boolean))];
    if (!usernames.length) return;
    const { data: profiles } = await _sb.from('profiles').select('username,avatar_url').in('username', usernames);
    if (!profiles) return;
    profiles.forEach(p => {
      if (!p.avatar_url) return;
      document.querySelectorAll<HTMLElement>(`.list-avatar[data-username="${p.username}"]`).forEach(el => {
        el.innerHTML = `<img src="${p.avatar_url}" style="width:100%;height:100%;object-fit:cover;" />`;
      });
    });
  })();

  // GTA countdown
  const target = new Date('2026-11-19T10:00:00Z').getTime();
  const days = Math.ceil((target - Date.now()) / 86400000);
  const gtaEl = document.getElementById('gtaPixelCount');
  if (gtaEl) gtaEl.textContent = `${Math.max(0, days)} GÜN`;

  // World cities
  // Sorted west→east by UTC offset
  const CITIES = [
    { name: 'L.A.',     tz: 'America/Los_Angeles', lat: 34.05,  lon: -118.24, flag: '🇺🇸' },
    { name: 'NEW YORK', tz: 'America/New_York',    lat: 40.71,  lon: -74.01,  flag: '🇺🇸' },
    { name: 'LONDRA',   tz: 'Europe/London',       lat: 51.51,  lon: -0.13,   flag: '🇬🇧' },
    { name: 'MOSKOVA',  tz: 'Europe/Moscow',       lat: 55.76,  lon: 37.62,   flag: '🇷🇺' },
    { name: 'BANGKOK',  tz: 'Asia/Bangkok',        lat: 13.75,  lon: 100.52,  flag: '🇹🇭' },
    { name: 'SEUL',     tz: 'Asia/Seoul',          lat: 37.57,  lon: 126.98,  flag: '🇰🇷' },
    { name: 'TOKYO',    tz: 'Asia/Tokyo',          lat: 35.68,  lon: 139.69,  flag: '🇯🇵' },
  ];

  function getWeather(code: number) {
    if (code === 0)  return { icon: '☀', color: '#f7e700', label: 'AÇIK' };
    if (code <= 3)   return { icon: '⛅', color: '#aaa',    label: 'PARÇALI' };
    if (code <= 48)  return { icon: '🌫', color: '#888',    label: 'SİSLİ' };
    if (code <= 67)  return { icon: '🌧', color: '#3b82f6', label: 'YAĞMUR' };
    if (code <= 77)  return { icon: '❄', color: '#bfdbfe', label: 'KAR' };
    if (code <= 82)  return { icon: '🌦', color: '#60a5fa', label: 'SAĞANAK' };
    return                  { icon: '⛈', color: '#f59e0b', label: 'FIRTINA' };
  }

  function cityTime(tz: string) {
    return new Intl.DateTimeFormat('tr-TR', {
      hour: '2-digit', minute: '2-digit', timeZone: tz
    }).format(new Date());
  }

  const widget = document.getElementById('worldWidget');

  function renderCities(weatherData: Record<string, {temp: number, code: number}>) {
    if (!widget) return;
    widget.innerHTML = CITIES.map(city => {
      const w = weatherData[city.name];
      const wx = w ? getWeather(w.code) : null;
      const tempStr = w ? `${Math.round(w.temp)}°` : '---';
      const timeStr = cityTime(city.tz);
      return `
        <div class="city-row" data-tz="${city.tz}"
          style="display:flex;flex-direction:column;justify-content:space-between;gap:4px;padding:8px 12px;border-right:1px solid #1e1e2e;border-bottom:1px solid #1e1e2e;flex:1;min-width:100px;">
          <div style="display:flex;align-items:center;gap:5px;">
            <span style="font-size:14px;line-height:1;">${city.flag}</span>
            <span style="font-family:'VT323',monospace;font-size:14px;color:#888899;letter-spacing:0.04em;">${city.name}</span>
          </div>
          <div style="font-family:'VT323',monospace;font-size:18px;color:#c8c8e0;white-space:nowrap;" data-city-time="${city.tz}">${timeStr}</div>
          <div style="display:flex;align-items:center;gap:6px;">
            <span style="font-family:'VT323',monospace;font-size:16px;color:${wx ? wx.color : '#666677'};">${wx ? wx.icon + ' ' + tempStr : '---'}</span>
          </div>
        </div>
      `;
    }).join('');
  }

  function syncPanelHeights() {
    const weather = document.getElementById('weatherPanel');
    const panels = ['quizPanel', 'gtaPanel', 'arcadePanel'];
    if (!weather) return;
    const h = weather.offsetHeight;
    if (h === 0) return;
    panels.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.height = h + 'px';
    });
  }

  renderCities({});
  requestAnimationFrame(syncPanelHeights);

  setInterval(() => {
    document.querySelectorAll('[data-city-time]').forEach(el => {
      const tz = (el as HTMLElement).dataset.cityTime!;
      el.textContent = cityTime(tz);
    });
  }, 1000);

  async function fetchWeather() {
    const weatherData: Record<string, {temp: number, code: number}> = {};
    await Promise.all(CITIES.map(async city => {
      try {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${city.lat}&longitude=${city.lon}&current=temperature_2m,weathercode&timezone=auto&forecast_days=1`;
        const res = await fetch(url);
        if (!res.ok) return;
        const data = await res.json();
        weatherData[city.name] = { temp: data.current.temperature_2m, code: data.current.weathercode };
      } catch {}
    }));
    renderCities(weatherData);
    requestAnimationFrame(syncPanelHeights);
  }

  fetchWeather();
</script>
