---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 6);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const newsWithImage    = sorted.filter(a => a.data.image).slice(0, 6);
const newsWithoutImage = sorted.filter(a => !a.data.image).slice(0, 9);

const categoryColors: Record<string, string> = {
  'Duyuru':   '#4a9eed',
  'Çıkış':    '#22c55e',
  'Donanım':  '#f97316',
  'Endüstri': '#9b59b6',
  'Bağımsız': '#14b8a6',
  'Haftalık': '#e5c46b',
};
---

<Layout title="KARBON OS">

  <p class="os-path">C:\KARBON\</p>

  <!-- ── LİSTELER ─────────────────────────── -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
    <h2 style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;margin:0;letter-spacing:0.06em;">📋 LİSTELER.EXE</h2>
    <a href="/lists" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#555566;transition:color 0.1s;"
      onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#555566'">TÜM LİSTELER →</a>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:6px;margin-bottom:28px;">
    {lists.map(list => {
      const slugs = list.games.map((i: any) => i.slug);
      return (
        <a href={`/lists/${list.slug}`}
          style="display:block;background:#0d0d12;border:1px solid #e5c46b22;text-decoration:none;transition:border-color 0.15s;"
          onmouseover="this.style.borderColor='#e5c46b66'" onmouseout="this.style.borderColor='#e5c46b22'">
          <div style="padding:14px 16px;border-bottom:1px solid #1e1e2e;">
            <div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;">
              <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#ffffff;margin:0;line-height:1.2;">{list.title}</p>
              <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;flex-shrink:0;">{list.games.length} oyun</span>
            </div>
            {list.description && <p style="font-size:11px;color:#555566;margin:0;line-height:1.5;">{list.description}</p>}
          </div>
          <div style="padding:8px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
            <div style="display:flex;gap:2px;flex-wrap:wrap;">
              {slugs.slice(0,14).map((slug: string) => {
                const g = gmap[slug];
                return g?.coverUrl ? (
                  <div style="width:32px;height:32px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
                    <img src={g.coverUrl} alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" loading="lazy"/>
                  </div>
                ) : null;
              })}
            </div>
            <div class="list-avatar" data-username={list.author.toLowerCase()}
              style="width:32px;height:32px;background:#1a1a2a;border:1px solid #2a2a3a;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;flex-shrink:0;">
              {list.author[0].toUpperCase()}
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <!-- ── SON HABERLER ────────────────────── -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
    <h2 style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#aaaacc;margin:0;letter-spacing:0.06em;">📰 HABERLER.LOG</h2>
    <a href="/news" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#555566;transition:color 0.1s;"
      onmouseover="this.style.color='#aaaacc'" onmouseout="this.style.color='#555566'">TÜM HABERLER →</a>
  </div>

  <!-- Görselli haberler -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:6px;margin-bottom:6px;">
    {newsWithImage.map(article => {
      const color = categoryColors[article.data.category] || '#666677';
      const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
      return (
        <a href={`/news/${article.id}`}
          style={`display:flex;flex-direction:column;background:#0d0d12;border:1px solid ${color}22;text-decoration:none;transition:border-color 0.15s;`}
          onmouseover={`this.style.borderColor='${color}66'`} onmouseout={`this.style.borderColor='${color}22'`}>
          <div style="width:100%;height:120px;overflow:hidden;">
            <img src={article.data.image} alt="" loading="lazy"
              style="width:100%;height:100%;object-fit:cover;opacity:0.85;display:block;" />
          </div>
          <div style="padding:10px 12px;">
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;">
              <span style={`font-family:'IBM Plex Mono', monospace;font-size:12px;color:${color};border:1px solid ${color}44;padding:1px 6px;`}>{article.data.category}</span>
              <span style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#444455;">{dateStr}</span>
            </div>
            <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#ffffff;margin:0;line-height:1.2;letter-spacing:0.02em;">{article.data.title}</p>
          </div>
        </a>
      );
    })}
  </div>

  <!-- Görselsiz haberler -->
  <div style="display:flex;flex-direction:column;gap:0;margin-bottom:28px;">
    {newsWithoutImage.map(article => {
      const color = categoryColors[article.data.category] || '#666677';
      const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
      return (
        <a href={`/news/${article.id}`}
          style={`display:flex;align-items:baseline;gap:10px;padding:7px 12px;background:#0d0d12;border:1px solid ${color}11;border-top:none;text-decoration:none;transition:background 0.15s;`}
          onmouseover="this.style.background='#111118'" onmouseout="this.style.background='#0d0d12'">
          <span style={`font-family:'IBM Plex Mono', monospace;font-size:12px;color:${color};border:1px solid ${color}44;padding:0px 5px;flex-shrink:0;`}>{article.data.category}</span>
          <span style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#444455;flex-shrink:0;">{dateStr}</span>
          <p style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#ffffff;margin:0;line-height:1.2;letter-spacing:0.02em;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{article.data.title}</p>
        </a>
      );
    })}
  </div>

  <!-- ── ALT SATIR: Dünya/Hava + Kısayollar ── -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
    <h2 style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#06b6d4;margin:0;letter-spacing:0.06em;">🌍 DÜNYA / HAVA</h2>
  </div>

  <div id="weatherPanel" style="background:#0d0d12;border:1px solid #06b6d422;margin-bottom:6px;">
    <div id="worldWidget" style="display:flex;flex-wrap:wrap;gap:0;">
      <div style="padding:8px 12px;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#778899;">YÜKLENİYOR...</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:28px;">
    <!-- GTA -->
    <div id="gtaPanel" style="background:#0d0d12;border:1px solid #ef444422;text-align:center;padding:16px 12px;">
      <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#666677;margin:0 0 4px;letter-spacing:0.04em;">📺 GTA VI — 19 KASIM 2026</p>
      <div id="gtaPixelCount" style="font-family:'IBM Plex Mono', monospace;font-size:34px;color:#e5c46b;line-height:1;margin-bottom:2px;">-- GÜN</div>
      <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;margin:0;">GTA TARİHİ SEZONU</p>
    </div>
    <!-- QUIZ -->
    <a id="quizPanel" href="/quiz" style="display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0d0d12;border:1px solid #22c55e22;text-decoration:none;padding:16px;transition:border-color 0.15s;"
      onmouseover="this.style.borderColor='#22c55e66'" onmouseout="this.style.borderColor='#22c55e22'">
      <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#22c55e;margin:0 0 6px;letter-spacing:0.06em;">🎮 QUİZ.EXE</p>
      <p style="font-family:'IBM Plex Mono', monospace;font-size:24px;color:#22c55e;margin:0;">[ BAŞLAT ]</p>
    </a>
    <!-- ARCADE -->
    <a id="arcadePanel" href="/arcade" style="display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0d0d12;border:1px solid #f9731622;text-decoration:none;padding:16px;transition:border-color 0.15s;"
      onmouseover="this.style.borderColor='#f9731666'" onmouseout="this.style.borderColor='#f9731622'">
      <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#f97316;margin:0 0 6px;letter-spacing:0.06em;">🕹 ARCADE.EXE</p>
      <p style="font-family:'IBM Plex Mono', monospace;font-size:24px;color:#f97316;margin:0;">[ OYNA ]</p>
    </a>
  </div>

</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  const _sb = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

  // Avatar fetch
  (async () => {
    const els = document.querySelectorAll<HTMLElement>('.list-avatar');
    const usernames = [...new Set([...els].map(el => el.dataset.username!).filter(Boolean))];
    if (!usernames.length) return;
    const { data: profiles } = await _sb.from('profiles').select('username,avatar_url').in('username', usernames);
    if (!profiles) return;
    profiles.forEach(p => {
      if (!p.avatar_url) return;
      document.querySelectorAll<HTMLElement>(`.list-avatar[data-username="${p.username}"]`).forEach(el => {
        el.innerHTML = `<img src="${p.avatar_url}" style="width:100%;height:100%;object-fit:cover;" />`;
      });
    });
  })();

  // GTA countdown
  const days = Math.ceil((new Date('2026-11-19T10:00:00Z').getTime() - Date.now()) / 86400000);
  const gtaEl = document.getElementById('gtaPixelCount');
  if (gtaEl) gtaEl.textContent = `${Math.max(0, days)} GÜN`;

  // World cities
  const CITIES = [
    { name: 'L.A.',     tz: 'America/Los_Angeles', lat: 34.05,  lon: -118.24, flag: '🇺🇸' },
    { name: 'NEW YORK', tz: 'America/New_York',    lat: 40.71,  lon: -74.01,  flag: '🇺🇸' },
    { name: 'LONDRA',   tz: 'Europe/London',       lat: 51.51,  lon: -0.13,   flag: '🇬🇧' },
    { name: 'MOSKOVA',  tz: 'Europe/Moscow',       lat: 55.76,  lon: 37.62,   flag: '🇷🇺' },
    { name: 'BANGKOK',  tz: 'Asia/Bangkok',        lat: 13.75,  lon: 100.52,  flag: '🇹🇭' },
    { name: 'SEUL',     tz: 'Asia/Seoul',          lat: 37.57,  lon: 126.98,  flag: '🇰🇷' },
    { name: 'TOKYO',    tz: 'Asia/Tokyo',          lat: 35.68,  lon: 139.69,  flag: '🇯🇵' },
  ];

  function getWeather(code: number) {
    if (code === 0)  return { icon: '☀', color: '#f7e700' };
    if (code <= 3)   return { icon: '⛅', color: '#aaa' };
    if (code <= 48)  return { icon: '🌫', color: '#888' };
    if (code <= 67)  return { icon: '🌧', color: '#3b82f6' };
    if (code <= 77)  return { icon: '❄', color: '#bfdbfe' };
    if (code <= 82)  return { icon: '🌦', color: '#60a5fa' };
    return                  { icon: '⛈', color: '#f59e0b' };
  }

  function cityTime(tz: string) {
    return new Intl.DateTimeFormat('tr-TR', { hour: '2-digit', minute: '2-digit', timeZone: tz }).format(new Date());
  }

  function cityDay(tz: string) {
    return new Intl.DateTimeFormat('tr-TR', { weekday: 'short', timeZone: tz }).format(new Date()).toUpperCase();
  }

  const widget = document.getElementById('worldWidget');

  function syncPanelHeights() {
    const weather = document.getElementById('weatherPanel');
    ['quizPanel','gtaPanel','arcadePanel'].forEach(id => {
      const el = document.getElementById(id);
      if (el && weather) el.style.height = weather.offsetHeight + 'px';
    });
  }

  function renderCities(weatherData: Record<string, {temp: number, code: number}>) {
    if (!widget) return;
    widget.innerHTML = CITIES.map(city => {
      const w = weatherData[city.name];
      const wx = w ? getWeather(w.code) : null;
      const tempStr = w ? `${Math.round(w.temp)}°` : '---';
      return `
        <div class="city-row" data-tz="${city.tz}"
          style="display:flex;flex-direction:column;gap:3px;padding:8px 12px;border-right:1px solid #1e1e2e;border-bottom:1px solid #1e1e2e;flex:1;min-width:90px;">
          <div style="display:flex;align-items:center;gap:5px;">
            <span style="font-size:11px;">${city.flag}</span>
            <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#888899;">${city.name}</span>
          </div>
          <div style="display:flex;align-items:baseline;gap:5px;">
            <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;" data-city-day="${city.tz}">${cityDay(city.tz)}</span>
            <span style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#c8c8e0;" data-city-time="${city.tz}">${cityTime(city.tz)}</span>
          </div>
          <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:${wx ? wx.color : '#666677'};">${wx ? wx.icon + ' ' + tempStr : '---'}</span>
        </div>`;
    }).join('');
  }

  renderCities({});
  requestAnimationFrame(syncPanelHeights);

  setInterval(() => {
    document.querySelectorAll('[data-city-time]').forEach(el => {
      el.textContent = cityTime((el as HTMLElement).dataset.cityTime!);
    });
  }, 30000);

  async function fetchWeather() {
    const weatherData: Record<string, {temp: number, code: number}> = {};
    await Promise.all(CITIES.map(async city => {
      try {
        const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${city.lat}&longitude=${city.lon}&current=temperature_2m,weathercode&timezone=auto&forecast_days=1`);
        if (!res.ok) return;
        const data = await res.json();
        weatherData[city.name] = { temp: data.current.temperature_2m, code: data.current.weathercode };
      } catch {}
    }));
    renderCities(weatherData);
    requestAnimationFrame(syncPanelHeights);
  }

  fetchWeather();

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(async pos => {
      const { latitude: lat, longitude: lon } = pos.coords;
      try {
        const [geoRes, wxRes] = await Promise.all([
          fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&accept-language=tr`),
          fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weathercode&timezone=auto&forecast_days=1`)
        ]);
        const geoData = await geoRes.json();
        const wxData = await wxRes.json();
        const cityName = (geoData.address?.city || geoData.address?.town || 'KONUM').toUpperCase().slice(0, 10);
        const wx = getWeather(wxData.current.weathercode);
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const card = `<div class="city-row" data-tz="${tz}"
          style="display:flex;flex-direction:column;gap:3px;padding:8px 12px;border-right:1px solid #1e1e2e;border-bottom:1px solid #1e1e2e;flex:1;min-width:90px;">
          <div style="display:flex;align-items:center;gap:5px;">
            <span style="font-size:11px;">📍</span>
            <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#888899;">${cityName}</span>
          </div>
          <div style="display:flex;align-items:baseline;gap:5px;">
            <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;" data-city-day="${tz}">${cityDay(tz)}</span>
            <span style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#c8c8e0;" data-city-time="${tz}">${cityTime(tz)}</span>
          </div>
          <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:${wx.color};">${wx.icon} ${Math.round(wxData.current.temperature_2m)}°</span>
        </div>`;
        if (widget) { widget.insertAdjacentHTML('afterbegin', card); requestAnimationFrame(syncPanelHeights); }
      } catch {}
    }, () => {}, { timeout: 5000 });
  }
</script>
