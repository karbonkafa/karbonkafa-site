---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 3);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const apps = [
  { href: '/lists',    icon: '📋', label: 'LİSTELER' },
  { href: '/guides',   icon: '🏆', label: 'REHBERLER' },
  { href: '/news',     icon: '📰', label: 'HABERLER' },
  { href: '/schedule', icon: '📺', label: 'KARBON TV' },
  { href: '/muzik',    icon: '🎵', label: 'MÜZİK' },
  { href: '/yemek',    icon: '🍜', label: 'YEMEK' },
  { href: '/mekan',    icon: '📍', label: 'MEKAN' },
  { href: '/quiz',     icon: '🎮', label: 'QUİZ' },
];
---

<Layout title="KARBON OS">
  <div style="position: fixed; inset: 0; background: radial-gradient(ellipse at 20% 50%, #0a0a1a 0%, #050508 70%); pointer-events: none; z-index: -1;"></div>

  <!-- System bar -->
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; padding: 6px 0; border-bottom: 1px solid #1e1e2e;">
    <div style="display: flex; align-items: center; gap: 16px;">
      <span style="font-family: 'VT323', monospace; font-size: 22px; color: #e5c46b; letter-spacing: 0.1em;">KARBON OS</span>
      <span style="font-family: 'VT323', monospace; font-size: 14px; color: #2a2a3a;">v2026.07</span>
    </div>
    <div style="display: flex; align-items: center; gap: 20px;">
      <span id="osDate" style="font-family: 'VT323', monospace; font-size: 16px; color: #444455;"></span>
      <span id="osClock" style="font-family: 'VT323', monospace; font-size: 20px; color: #666677;"></span>
    </div>
  </div>

  <!-- Bento grid -->
  <div class="bento">

    <!-- NEWS — big left -->
    <div class="bento-news px-window">
      <div class="px-titlebar">
        <span class="px-title">📰 HABERLER.LOG</span>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0;">
        {latestNews.slice(0, 2).map(article => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style="display: block; padding: 16px; border-right: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              {article.data.image && (
                <div style="width: 100%; height: 80px; overflow: hidden; margin-bottom: 10px; border: 1px solid #1e1e2e;">
                  <img src={article.data.image} alt="" loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.8;" />
                </div>
              )}
              <span style="font-family: 'VT323', monospace; font-size: 12px; color: #3a3a5a; letter-spacing: 0.04em; display: block; margin-bottom: 5px;">{dateStr}</span>
              <p style="font-size: 14px; font-weight: 500; color: #d0d0e0; margin: 0 0 6px; line-height: 1.4;">{article.data.title}</p>
              {article.data.excerpt && (
                <p style="font-size: 12px; color: #555566; margin: 0; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">{article.data.excerpt}</p>
              )}
            </a>
          );
        })}
      </div>
      <!-- Smaller news list -->
      <div>
        {latestNews.slice(2).map(article => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style="display: flex; align-items: baseline; gap: 12px; padding: 10px 16px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              <span style="font-family: 'VT323', monospace; font-size: 12px; color: #2a2a3a; white-space: nowrap;">{dateStr}</span>
              <p style="font-size: 13px; color: #aaa; margin: 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">{article.data.title}</p>
            </a>
          );
        })}
        <a href="/news" style="display: block; padding: 10px 16px; font-family: 'VT323', monospace; font-size: 15px; color: #333344; text-align: center; letter-spacing: 0.06em; transition: color 0.1s;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#333344'">
          [ TÜM HABERLER → ]
        </a>
      </div>
    </div>

    <!-- APPS — right column, full height -->
    <div class="bento-apps">

      <!-- App icons window -->
      <div class="px-window" style="margin-bottom: 12px;">
        <div class="px-titlebar">
          <span class="px-title">💾 UYGULAMALAR</span>
          <div class="px-btns"><span class="px-btn">□</span></div>
        </div>
        <div style="padding: 10px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px;">
          {apps.map(app => (
            <a href={app.href} class="app-icon">
              <div class="icon-box">{app.icon}</div>
              <span class="icon-label">{app.label}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- About -->
      <div class="px-window" style="margin-bottom: 12px;">
        <div class="px-titlebar">
          <span class="px-title">📁 SİSTEM BİLGİSİ</span>
          <div class="px-btns"><span class="px-btn">×</span></div>
        </div>
        <div style="padding: 14px 16px; display: flex; flex-direction: column; gap: 5px;">
          <span style="font-family: 'VT323', monospace; font-size: 16px; color: #e5c46b; letter-spacing: 0.04em;">KARBON GAME STUDIOS</span>
          <span style="font-family: 'VT323', monospace; font-size: 13px; color: #333344;">ARŞIV: 1.481 OYUN</span>
          <span style="font-family: 'VT323', monospace; font-size: 13px; color: #333344;">DURUM: 7/24 YAYIN</span>
          <span style="font-family: 'VT323', monospace; font-size: 13px; color: #333344;">PLATFORM: KARBON OS</span>
        </div>
      </div>

      <!-- GTA Countdown -->
      <div class="px-window" style="border-color: #e5c46b44;">
        <div class="px-titlebar" style="border-left-color: #ef4444;">
          <span class="px-title" style="color: #ef4444;">📺 GTA VI SAYAÇ</span>
          <div class="px-btns"><span class="px-btn">×</span></div>
        </div>
        <div style="padding: 14px 16px; text-align: center;">
          <p style="font-family: 'VT323', monospace; font-size: 12px; color: #444; margin: 0 0 6px; letter-spacing: 0.04em;">19 KASIM 2026'YA</p>
          <div id="gtaPixelCount" style="font-family: 'VT323', monospace; font-size: 36px; color: #e5c46b; line-height: 1; margin-bottom: 4px;">-- GÜN</div>
          <p style="font-family: 'VT323', monospace; font-size: 11px; color: #2a2a2a; margin: 0; letter-spacing: 0.04em;">GTA TARİHİ SEZONU</p>
        </div>
      </div>
    </div>

    <!-- LISTS — bottom left -->
    <div class="bento-lists px-window">
      <div class="px-titlebar">
        <span class="px-title">📋 LİSTELER.EXE</span>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div>
        {lists.map(list => {
          const slugs = list.games.map((i: any) => i.slug);
          return (
            <a href={`/lists/${list.slug}`}
              style="display: block; padding: 14px 16px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin-bottom: 4px;">
                <p style="font-family: 'VT323', monospace; font-size: 17px; color: #c8c8e0; margin: 0; letter-spacing: 0.02em;">{list.title}</p>
                <span style="font-family: 'VT323', monospace; font-size: 12px; color: #333344; flex-shrink: 0;">{list.games.length} oyun</span>
              </div>
              <p style="font-size: 12px; color: #555566; margin: 0 0 8px; line-height: 1.45;">{list.description}</p>
              <div style="display: flex; gap: 2px; flex-wrap: wrap;">
                {slugs.slice(0, 20).map((slug: string) => {
                  const g = gmap[slug];
                  const cover = g?.coverUrl;
                  return cover ? (
                    <div style="width: 26px; height: 26px; overflow: hidden; border: 1px solid #1e1e2e;">
                      <img src={cover} alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" loading="lazy"/>
                    </div>
                  ) : <div style="width:26px;height:26px;background:#0d0d12;border:1px solid #1e1e2e;"></div>;
                })}
              </div>
            </a>
          );
        })}
        <a href="/lists" style="display: block; padding: 10px 16px; font-family: 'VT323', monospace; font-size: 15px; color: #333344; text-align: center; letter-spacing: 0.06em; transition: color 0.1s;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#333344'">
          [ TÜM LİSTELER → ]
        </a>
      </div>
    </div>

    <!-- QUIZ — bottom right -->
    <a href="/quiz" class="bento-quiz px-window" style="text-decoration: none; display: block; border-color: #22c55e44; transition: border-color 0.15s;"
      onmouseover="this.style.borderColor='#22c55e'" onmouseout="this.style.borderColor='#22c55e44'">
      <div class="px-titlebar" style="border-left-color: #22c55e;">
        <span class="px-title" style="color: #22c55e;">🎮 QUİZ.EXE</span>
        <div class="px-btns"><span class="px-btn" style="color:#22c55e;">▶</span></div>
      </div>
      <div style="padding: 20px 16px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; min-height: 100px;">
        <p style="font-family: 'VT323', monospace; font-size: 14px; color: #444; margin: 0; letter-spacing: 0.04em;">EKRAN GÖRÜNTÜSÜNDEN</p>
        <p style="font-family: 'VT323', monospace; font-size: 14px; color: #444; margin: 0; letter-spacing: 0.04em;">OYUNU TAHMİN ET</p>
        <p style="font-family: 'VT323', monospace; font-size: 28px; color: #22c55e; margin: 0; letter-spacing: 0.06em;">[ BAŞLAT ]</p>
      </div>
    </a>

  </div>

</Layout>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    grid-template-areas:
      "news news apps"
      "lists quiz apps";
    gap: 12px;
    align-items: start;
  }
  .bento-news  { grid-area: news; }
  .bento-apps  { grid-area: apps; display: flex; flex-direction: column; }
  .bento-lists { grid-area: lists; }
  .bento-quiz  { grid-area: quiz; }

  @media (max-width: 900px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "news news"
        "lists apps"
        "quiz apps";
    }
  }
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "news"
        "apps"
        "lists"
        "quiz";
    }
    .icon-box { width: 44px; height: 44px; font-size: 22px; }
  }
</style>

<script>
  function updateClock() {
    const now = new Date();
    const c = document.getElementById('osClock');
    const d = document.getElementById('osDate');
    if (c) c.textContent = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (d) d.textContent = now.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  const target = new Date('2026-11-19T10:00:00Z').getTime();
  const days = Math.ceil((target - Date.now()) / 86400000);
  const el = document.getElementById('gtaPixelCount');
  if (el) el.textContent = `${Math.max(0, days)} GÜN`;
</script>
