---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ana Sayfa">

  <!-- Hero -->
  <section style="padding: 64px 0 80px;">
    <p style="font-size: 13px; color: #e5c46b; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; font-family: 'JetBrains Mono', monospace;">KarbonGameStudios</p>
    <h1 style="font-size: clamp(32px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.1; margin: 0 0 20px;">
      Oyunları oynuyoruz.<br />
      <span style="color: #444;">Eksiksiz bitiriyoruz.</span>
    </h1>
    <p style="font-size: 16px; color: #666; max-width: 480px; line-height: 1.6; margin: 0;">
      1.640 oyunluk backlog. Önemli olanları başarımlarıyla bitiriyoruz.
      Rehberler, haberler ve içerik arşivi.
    </p>
  </section>

  <!-- Sections grid -->
  <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; border: 1px solid #222; margin-bottom: 80px;">

    <a href="/oyunlar" style="padding: 32px; background: #111; display: block; border-right: 1px solid #222; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Oyun Kartları</p>
      <h2 style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">Oyunlar</h2>
      <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Her oyun için store-page formatında bilgi kartı.</p>
    </a>

    <a href="/rehberler" style="padding: 32px; background: #111; display: block; border-right: 1px solid #222; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Başarım Rehberleri</p>
      <h2 style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">Rehberler</h2>
      <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">100% tamamlama için missable odaklı rehberler.</p>
    </a>

    <a href="/haberler" style="padding: 32px; background: #111; display: block; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Karbon News</p>
      <h2 style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">Haberler</h2>
      <p style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Haftalık oyun haberleri. Oyuncu perspektifinden.</p>
    </a>

  </section>

  <!-- GTA 6 countdown -->
  <section style="border: 1px solid #222; padding: 32px; background: #111; margin-bottom: 80px;">
    <p style="font-size: 11px; color: #e5c46b; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Rockstar Saati</p>
    <div style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
      <h2 style="font-size: 24px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">GTA 6 Konsol Lansmanı</h2>
      <span style="font-size: 14px; color: #666;">19 Kasım 2026</span>
    </div>
    <p style="font-size: 14px; color: #666; margin: 12px 0 0; line-height: 1.5;">
      GTA Tarihi sezonu bu güne yönelmiş. PC lansmanı sonrası tam playthrough + Karbon RP.
    </p>
  </section>

</Layout>
