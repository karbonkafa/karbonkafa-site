---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- Hero -->
  <section style="padding: 64px 0 80px;">
    <p data-i18n="hero.tagline" style="font-size: 13px; color: #e5c46b; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; font-family: 'JetBrains Mono', monospace;">KarbonGameStudios</p>
    <h1 style="font-size: clamp(32px, 5vw, 52px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.1; margin: 0 0 20px;">
      <span data-i18n="hero.title">We play games.</span><br />
      <span data-i18n="hero.title2" style="color: #444;">We finish them completely.</span>
    </h1>
    <p data-i18n="hero.desc" style="font-size: 16px; color: #666; max-width: 480px; line-height: 1.6; margin: 0;">
      1,640 game backlog. Completing the important ones with all achievements.
    </p>
  </section>

  <!-- Sections grid -->
  <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1px; border: 1px solid #222; margin-bottom: 80px;">

    <a href="/games" style="padding: 32px; background: #111; display: block; border-right: 1px solid #222; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p data-i18n="section.games" style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Game Cards</p>
      <h2 data-i18n="nav.games" style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">Games</h2>
      <p data-i18n="section.games.desc" style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Store-page format info card for each game.</p>
    </a>

    <a href="/guides" style="padding: 32px; background: #111; display: block; border-right: 1px solid #222; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p data-i18n="section.guides" style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Achievement Guides</p>
      <h2 data-i18n="nav.guides" style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">Guides</h2>
      <p data-i18n="section.guides.desc" style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Missable-focused guides for 100% completion.</p>
    </a>

    <a href="/news" style="padding: 32px; background: #111; display: block; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
      <p style="font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Karbon News</p>
      <h2 data-i18n="nav.news" style="font-size: 20px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em;">News</h2>
      <p data-i18n="section.news.desc" style="font-size: 14px; color: #666; margin: 0; line-height: 1.5;">Weekly gaming news. From a player's perspective.</p>
    </a>

  </section>

  <!-- GTA 6 countdown -->
  <section style="border: 1px solid #222; padding: 32px; background: #111; margin-bottom: 80px;">
    <p data-i18n="rockstar.title" style="font-size: 11px; color: #e5c46b; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Rockstar Hour</p>
    <div style="display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;">
      <h2 data-i18n="rockstar.launch" style="font-size: 24px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">GTA 6 Console Launch</h2>
      <span style="font-size: 14px; color: #666;">November 19, 2026</span>
    </div>
    <p data-i18n="rockstar.desc" style="font-size: 14px; color: #666; margin: 12px 0 0; line-height: 1.5;">
      GTA History season leads to this day. Full playthrough + Karbon RP after PC launch.
    </p>
  </section>

</Layout>
