---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 7);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 9);
const featuredNews = latestNews.slice(0, 3);  // 3 big with images
const smallNews = latestNews.slice(3);         // rest as list

const apps = [
  { href: '/lists',    icon: '📋', label: 'LİSTELER' },
  { href: '/guides',   icon: '🏆', label: 'REHBERLER' },
  { href: '/news',     icon: '📰', label: 'HABERLER' },
  { href: '/schedule', icon: '📺', label: 'KARBON TV' },
  { href: '/muzik',    icon: '🎵', label: 'MÜZİK' },
  { href: '/yemek',    icon: '🍜', label: 'YEMEK' },
  { href: '/mekan',    icon: '📍', label: 'MEKAN' },
  { href: '/quiz',     icon: '🎮', label: 'QUİZ' },
  { href: '/arcade',   icon: '🕹', label: 'ARCADE' },
];
---

<Layout title="KARBON OS">
  <div style="position: fixed; inset: 0; background: radial-gradient(ellipse at 20% 50%, #0a0a1a 0%, #050508 70%); pointer-events: none; z-index: -1;"></div>

  <!-- System bar -->
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; padding: 6px 0; border-bottom: 1px solid #1e1e2e;">
    <div style="display: flex; align-items: center; gap: 16px;">
      <span style="font-family: 'VT323', monospace; font-size: 22px; color: #e5c46b; letter-spacing: 0.1em;">KARBON OS</span>
      <span style="font-family: 'VT323', monospace; font-size: 14px; color: #555566;">v2026.07</span>
    </div>
    <div style="display: flex; align-items: center; gap: 20px;">
      <span id="osDate" style="font-family: 'VT323', monospace; font-size: 16px; color: #777788;"></span>
      <span id="osClock" style="font-family: 'VT323', monospace; font-size: 20px; color: #666677;"></span>
    </div>
  </div>

  <!-- Radio widget -->
  <div class="px-window" style="margin-bottom: 12px; border-color: #3b82f644;">
    <div class="px-titlebar" style="border-left-color: #3b82f6;">
      <span class="px-title" style="color: #3b82f6;">🎧 RADYO.EXE</span>
      <div class="px-btns">
        <span class="px-btn" id="radio-min">─</span>
        <span class="px-btn" id="radio-close" style="cursor:pointer;">×</span>
      </div>
    </div>
    <div id="radio-body" style="padding: 12px 16px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
      <button id="radio-play"
        style="font-family:'VT323',monospace;font-size:22px;background:#0d0d12;border:2px solid #3b82f6;color:#3b82f6;padding:6px 18px;cursor:pointer;letter-spacing:0.06em;transition:all 0.15s;flex-shrink:0;"
        onmouseover="this.style.background='#0a1020'" onmouseout="this.style.background='#0d0d12'">
        ▶ BAŞLAT
      </button>
      <div id="radio-status" style="display:flex;align-items:center;gap:6px;">
        <span id="radio-dot" style="width:7px;height:7px;border-radius:50%;background:#333344;display:inline-block;flex-shrink:0;"></span>
        <span id="radio-label" style="font-family:'VT323',monospace;font-size:15px;color:#555566;letter-spacing:0.04em;">HAZIR</span>
      </div>
      <input id="radio-vol" type="range" min="0" max="100" value="70"
        style="width:80px;accent-color:#3b82f6;flex-shrink:0;" />
    </div>
  </div>

  <!-- Bento grid -->
  <div class="bento">

    <!-- APPS — full width top row -->
    <div class="bento-apps px-window">
      <div class="px-titlebar">
        <span class="px-title">💾 UYGULAMALAR</span>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div style="padding: 8px 12px; display: flex; gap: 0; flex-wrap: nowrap; overflow-x: auto;">
        {apps.map(app => (
          <a href={app.href} class="app-icon" style="flex: 1; min-width: 64px;">
            <div class="icon-box" style="width: 44px; height: 44px; font-size: 22px;">{app.icon}</div>
            <span class="icon-label">{app.label}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- NEWS — big left -->
    <div class="bento-news px-window">
      <div class="px-titlebar">
        <span class="px-title">📰 HABERLER.LOG</span>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <!-- 3 featured news with images -->
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-bottom: 1px solid #1e1e2e;">
        {featuredNews.map((article, i) => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style={`display: block; padding: 14px; border-right: 1px solid #1e1e2e; transition: background 0.1s; ${i===2?'border-right:none':''}`}
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              {article.data.image && (
                <div style="width: 100%; height: 90px; overflow: hidden; margin-bottom: 10px; border: 1px solid #1e1e2e;">
                  <img src={article.data.image} alt="" loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.85;" />
                </div>
              )}
              <span style="font-family:'VT323',monospace;font-size:13px;color:#666677;display:block;margin-bottom:4px;">{dateStr}</span>
              <p style="font-size:13px;font-weight:500;color:#d0d0e0;margin:0 0 5px;line-height:1.35;">{article.data.title}</p>
              {article.data.excerpt && (
                <p style="font-size:12px;color:#778899;margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{article.data.excerpt}</p>
              )}
            </a>
          );
        })}
      </div>
      <!-- Remaining news as compact list -->
      <div>
        {smallNews.map(article => {
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
          return (
            <a href={`/news/${article.id}`}
              style="display: flex; align-items: baseline; gap: 12px; padding: 9px 14px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
              onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
              <span style="font-family:'VT323',monospace;font-size:13px;color:#666677;white-space:nowrap;flex-shrink:0;">{dateStr}</span>
              <p style="font-size:13px;color:#aaa;margin:0;line-height:1.35;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">{article.data.title}</p>
            </a>
          );
        })}
        <a href="/news" style="display:block;padding:10px 14px;font-family:'VT323',monospace;font-size:15px;color:#666677;text-align:center;letter-spacing:0.06em;transition:color 0.1s;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#666677'">
          [ TÜM HABERLER → ]
        </a>
      </div>
    </div>

    <!-- LISTS -->
    <div class="bento-lists px-window">
      <div class="px-titlebar" style="border-left-color: #e5c46b;">
        <span class="px-title" style="color: #e5c46b;">📋 LİSTELER.EXE</span>
        <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0;">
        {lists.map(list => {
          const slugs = list.games.map((i: any) => i.slug);
          return (
            <a href={`/lists/${list.slug}`}
              style="display: block; padding: 16px; border-right: 1px solid #1e1e2e; border-bottom: 1px solid #1e1e2e; transition: background 0.15s;"
              onmouseover="this.style.background='#111118'" onmouseout="this.style.background='none'">
              <p style="font-family:'VT323',monospace;font-size:20px;color:#ffffff;margin:0 0 3px;letter-spacing:0.02em;line-height:1.2;">{list.title}</p>
              <p style="font-size:12px;color:#666677;margin:0 0 10px;line-height:1.4;font-family:'VT323',monospace;">{list.author} · {list.games.length} oyun</p>
              <div style="display: flex; gap: 2px; flex-wrap: wrap;">
                {slugs.slice(0, 18).map((slug: string) => {
                  const g = gmap[slug];
                  const cover = g?.coverUrl;
                  return cover ? (
                    <div style="width: 44px; height: 44px; overflow: hidden; border: 1px solid #2a2a3a; flex-shrink: 0;">
                      <img src={cover} alt="" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" loading="lazy"/>
                    </div>
                  ) : <div style="width:44px;height:44px;background:#0d0d12;border:1px solid #1e1e2e;flex-shrink:0;"></div>;
                })}
              </div>
            </a>
          );
        })}
      </div>
      <a href="/lists" style="display:block;padding:11px 14px;font-family:'VT323',monospace;font-size:16px;color:#555566;text-align:center;letter-spacing:0.06em;transition:color 0.1s;"
        onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#555566'">
        [ TÜM LİSTELER → ]
      </a>
    </div>

    <!-- WEATHER -->
    <div class="bento-right px-window">
      <div class="px-titlebar" style="border-left-color: #06b6d4;">
        <span class="px-title" style="color: #06b6d4;">🌍 DÜNYA / HAVA</span>
        <div class="px-btns"><span class="px-btn">×</span></div>
      </div>
      <div id="worldWidget" style="display: flex; flex-direction: column;">
        <div style="padding: 8px 12px; font-family: 'VT323', monospace; font-size: 16px; color: #778899; letter-spacing: 0.04em;">YÜKLENİYOR...</div>
      </div>
    </div>

    <!-- QUIZ -->
    <a href="/quiz" class="bento-quiz px-window" style="text-decoration: none; display: block; border-color: #22c55e44; transition: border-color 0.15s;"
      onmouseover="this.style.borderColor='#22c55e'" onmouseout="this.style.borderColor='#22c55e44'">
      <div class="px-titlebar" style="border-left-color: #22c55e;">
        <span class="px-title" style="color: #22c55e;">🎮 QUİZ.EXE</span>
        <div class="px-btns"><span class="px-btn" style="color:#22c55e;">▶</span></div>
      </div>
      <div style="padding: 20px 16px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; min-height: 100px;">
        <p style="font-family: 'VT323', monospace; font-size: 28px; color: #22c55e; margin: 0; letter-spacing: 0.06em;">[ BAŞLAT ]</p>
      </div>
    </a>

    <!-- GTA COUNTDOWN -->
    <div class="bento-gta px-window" style="border-color: #e5c46b44;">
      <div class="px-titlebar" style="border-left-color: #ef4444;">
        <span class="px-title" style="color: #ef4444;">📺 GTA VI SAYAÇ</span>
        <div class="px-btns"><span class="px-btn">×</span></div>
      </div>
      <div style="padding: 16px; text-align: center;">
        <p style="font-family: 'VT323', monospace; font-size: 15px; color: #666677; margin: 0 0 6px; letter-spacing: 0.04em;">19 KASIM 2026'YA</p>
        <div id="gtaPixelCount" style="font-family: 'VT323', monospace; font-size: 36px; color: #e5c46b; line-height: 1; margin-bottom: 4px;">-- GÜN</div>
        <p style="font-family: 'VT323', monospace; font-size: 12px; color: #444455; margin: 0; letter-spacing: 0.04em;">GTA TARİHİ SEZONU</p>
      </div>
    </div>

  </div>

</Layout>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-areas:
      "apps   apps   apps"
      "lists  lists  lists"
      "news   news   news"
      "right  quiz   gta";
    gap: 12px;
    align-items: start;
  }
  .bento-apps  { grid-area: apps; }
  .bento-lists { grid-area: lists; margin-top: 8px; }
  .bento-news  { grid-area: news; margin-top: 8px; }
  .bento-right { grid-area: right; }
  .bento-quiz  { grid-area: quiz; }
  .bento-gta   { grid-area: gta; }

  @media (max-width: 700px) {
    .bento {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "apps   apps"
        "lists  lists"
        "news   news"
        "right  quiz"
        "gta    gta";
    }
  }
  @media (max-width: 480px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "apps" "lists" "news" "right" "quiz" "gta";
    }
    .icon-box { width: 44px; height: 44px; font-size: 22px; }
  }
</style>

<script>
  // System clock
  function updateClock() {
    const now = new Date();
    const c = document.getElementById('osClock');
    const d = document.getElementById('osDate');
    if (c) c.textContent = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (d) d.textContent = now.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // GTA countdown
  const target = new Date('2026-11-19T10:00:00Z').getTime();
  const days = Math.ceil((target - Date.now()) / 86400000);
  const gtaEl = document.getElementById('gtaPixelCount');
  if (gtaEl) gtaEl.textContent = `${Math.max(0, days)} GÜN`;

  // World cities config
  const CITIES = [
    { name: 'İSTANBUL', tz: 'Europe/Istanbul',   lat: 41.01,  lon: 28.98,  flag: '🇹🇷' },
    { name: 'TOKYO',    tz: 'Asia/Tokyo',          lat: 35.68,  lon: 139.69, flag: '🇯🇵' },
    { name: 'NEW YORK', tz: 'America/New_York',    lat: 40.71,  lon: -74.01, flag: '🇺🇸' },
    { name: 'LONDRA',   tz: 'Europe/London',       lat: 51.51,  lon: -0.13,  flag: '🇬🇧' },
    { name: 'SEUL',     tz: 'Asia/Seoul',          lat: 37.57,  lon: 126.98, flag: '🇰🇷' },
    { name: 'MOSKOVA',  tz: 'Europe/Moscow',       lat: 55.76,  lon: 37.62,  flag: '🇷🇺' },
    { name: 'L.A.',     tz: 'America/Los_Angeles', lat: 34.05,  lon: -118.24,flag: '🇺🇸' },
  ];

  // WMO code → pixel art icon + label
  function getWeather(code: number) {
    if (code === 0)              return { icon: '☀', color: '#f7e700', label: 'AÇIK' };
    if (code <= 3)               return { icon: '⛅', color: '#aaa', label: 'PARÇALI' };
    if (code <= 48)              return { icon: '🌫', color: '#888', label: 'SİSLİ' };
    if (code <= 67)              return { icon: '🌧', color: '#3b82f6', label: 'YAĞMUR' };
    if (code <= 77)              return { icon: '❄', color: '#bfdbfe', label: 'KAR' };
    if (code <= 82)              return { icon: '🌦', color: '#60a5fa', label: 'SAĞANAK' };
    return                              { icon: '⛈', color: '#f59e0b', label: 'FIRTINA' };
  }

  // City time formatter
  function cityTime(tz: string) {
    return new Intl.DateTimeFormat('tr-TR', {
      hour: '2-digit', minute: '2-digit', timeZone: tz
    }).format(new Date());
  }

  const widget = document.getElementById('worldWidget');

  function renderCities(weatherData: Record<string, {temp: number, code: number}>) {
    if (!widget) return;
    widget.innerHTML = CITIES.map(city => {
      const w = weatherData[city.name];
      const wx = w ? getWeather(w.code) : null;
      const tempStr = w ? `${Math.round(w.temp)}°` : '---';
      const timeStr = cityTime(city.tz);
      return `
        <div class="city-row" data-tz="${city.tz}"
          style="display:grid;grid-template-columns:28px 1fr auto auto;gap:6px;align-items:center;padding:7px 12px;border-bottom:1px solid #1e1e2e;">
          <span style="font-size:16px;line-height:1;text-align:center;">${city.flag}</span>
          <div>
            <div style="font-family:'VT323',monospace;font-size:14px;color:#888899;letter-spacing:0.04em;">${city.name}</div>
            ${wx ? `<div style="font-family:'VT323',monospace;font-size:11px;color:${wx.color};">${wx.icon} ${wx.label}</div>` : ''}
          </div>
          <div style="font-family:'VT323',monospace;font-size:17px;color:#c8c8e0;text-align:right;white-space:nowrap;" data-city-time="${city.tz}">${timeStr}</div>
          <div style="font-family:'VT323',monospace;font-size:17px;min-width:36px;text-align:right;white-space:nowrap;color:${wx ? getWeather(w!.code).color : '#666677'};">${tempStr}</div>
        </div>
      `;
    }).join('');
  }

  // Initial render without weather
  renderCities({});

  // Live clock update for city times
  setInterval(() => {
    document.querySelectorAll('[data-city-time]').forEach(el => {
      const tz = (el as HTMLElement).dataset.cityTime!;
      el.textContent = cityTime(tz);
    });
  }, 1000);

  // Fetch weather for all cities
  async function fetchWeather() {
    const weatherData: Record<string, {temp: number, code: number}> = {};
    await Promise.all(CITIES.map(async city => {
      try {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${city.lat}&longitude=${city.lon}&current=temperature_2m,weathercode&timezone=auto&forecast_days=1`;
        const res = await fetch(url);
        if (!res.ok) return;
        const data = await res.json();
        weatherData[city.name] = {
          temp: data.current.temperature_2m,
          code: data.current.weathercode,
        };
      } catch {}
    }));
    renderCities(weatherData);
  }

  fetchWeather();

  // ── RADIO ──────────────────────────────────────────────────
  const STREAMS = [
    'https://ice1.somafm.com/illstreet-128-mp3',   // SomaFM Ill Street Blues
    'https://ice4.somafm.com/beatblender-128-mp3', // SomaFM Beat Blender
    'https://ice2.somafm.com/thetrip-128-mp3',     // SomaFM The Trip
    'https://ice2.somafm.com/groovesalad-256-mp3', // SomaFM Groove Salad
  ];

  let audio: HTMLAudioElement | null = null;
  let playing = false;

  const playBtn  = document.getElementById('radio-play')!;
  const dot      = document.getElementById('radio-dot')!;
  const lbl      = document.getElementById('radio-label')!;
  const vol      = document.getElementById('radio-vol') as HTMLInputElement;
  const closeBtn = document.getElementById('radio-close');
  const body     = document.getElementById('radio-body');

  function setStatus(state: 'playing'|'loading'|'stopped'|'error') {
    const map = {
      playing: { color:'#22c55e', text:'YAYIN — CANLI', btn:'■ DURDUR' },
      loading: { color:'#f59e0b', text:'BAĞLANIYOR...', btn:'...' },
      stopped: { color:'#333344', text:'HAZIR',          btn:'▶ BAŞLAT' },
      error:   { color:'#ef4444', text:'HATA — YENİDEN DENE', btn:'▶ BAŞLAT' },
    };
    const s = map[state];
    dot.style.background = s.color;
    lbl.style.color = s.color;
    lbl.textContent = s.text;
    playBtn.textContent = s.btn;
    if (state === 'playing') {
      dot.style.animation = 'pulse 2s infinite';
    } else {
      dot.style.animation = '';
    }
  }

  function tryStream(idx: number) {
    if (idx >= STREAMS.length) { setStatus('error'); playing = false; return; }
    if (audio) { audio.pause(); audio.src = ''; }
    audio = new Audio();
    audio.crossOrigin = 'anonymous';
    audio.volume = Number(vol.value) / 100;
    audio.src = STREAMS[idx];
    setStatus('loading');
    audio.play().then(() => {
      setStatus('playing'); playing = true;
    }).catch(() => tryStream(idx + 1));
    audio.onerror = () => tryStream(idx + 1);
  }

  playBtn.addEventListener('click', () => {
    if (playing) {
      audio?.pause();
      playing = false;
      setStatus('stopped');
    } else {
      tryStream(0);
    }
  });

  vol.addEventListener('input', () => {
    if (audio) audio.volume = Number(vol.value) / 100;
  });

  closeBtn?.addEventListener('click', () => {
    audio?.pause(); playing = false;
    const card = closeBtn.closest('.px-window') as HTMLElement;
    if (card) card.style.display = 'none';
  });
</script>
