---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 2);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const apps = [
  { href: '/lists',    icon: '📋', label: 'LİSTELER' },
  { href: '/guides',   icon: '🏆', label: 'REHBERLER' },
  { href: '/news',     icon: '📰', label: 'HABERLER' },
  { href: '/schedule', icon: '📺', label: 'KARBON TV' },
  { href: '/muzik',    icon: '🎵', label: 'MÜZİK' },
  { href: '/yemek',    icon: '🍜', label: 'YEMEK' },
  { href: '/mekan',    icon: '📍', label: 'MEKAN' },
  { href: '/quiz',     icon: '🎮', label: 'QUİZ' },
];
---

<Layout title="KARBON OS">

  <!-- Desktop background pattern -->
  <div style="position: fixed; inset: 0; background: radial-gradient(ellipse at 20% 50%, #0a0a2a 0%, #050508 70%); pointer-events: none; z-index: -1;"></div>

  <!-- Desktop grid -->
  <div style="min-height: calc(100vh - 200px); padding-bottom: 40px;">

    <!-- System bar -->
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; padding: 6px 0; border-bottom: 1px solid #1e1e2e;">
      <div style="display: flex; align-items: center; gap: 16px;">
        <span style="font-family: 'VT323', monospace; font-size: 20px; color: #e5c46b; letter-spacing: 0.1em;">KARBON OS</span>
        <span style="font-family: 'VT323', monospace; font-size: 14px; color: #3a3a5a;">v2026.07</span>
      </div>
      <div style="display: flex; align-items: center; gap: 20px;">
        <span id="osDate" style="font-family: 'VT323', monospace; font-size: 16px; color: #555566;"></span>
        <span id="osClock" style="font-family: 'VT323', monospace; font-size: 18px; color: #888899;"></span>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; align-items: start;">

      <!-- LEFT: App icons + about window -->
      <div style="display: flex; flex-direction: column; gap: 16px;">

        <!-- About window -->
        <div class="px-window">
          <div class="px-titlebar">
            <span class="px-title">📁 HAKKINDA.TXT</span>
            <div class="px-btns">
              <span class="px-btn">─</span>
              <span class="px-btn">□</span>
              <span class="px-btn">×</span>
            </div>
          </div>
          <div style="padding: 16px 18px;">
            <p style="font-family: 'VT323', monospace; font-size: 17px; color: #e5c46b; margin: 0 0 10px; letter-spacing: 0.04em;">KARBON GAME STUDIOS</p>
            <p style="font-size: 13px; color: #666; margin: 0 0 10px; line-height: 1.6;">
              1.400+ oyunluk arşiv. Küratörlenmiş listeler. Başarım rehberleri. Bir içerik üreticisinin oyun dünyasına bakışı.
            </p>
            <div style="border-top: 1px solid #1e1e2e; padding-top: 10px; display: flex; flex-direction: column; gap: 4px;">
              <span style="font-family: 'VT323', monospace; font-size: 13px; color: #3a3a5a;">SİSTEM: Karbon OS 2026</span>
              <span style="font-family: 'VT323', monospace; font-size: 13px; color: #3a3a5a;">DURUM: 7/24 YAYIN</span>
              <span style="font-family: 'VT323', monospace; font-size: 13px; color: #3a3a5a;">ARŞIV: 1.481 OYUN</span>
            </div>
          </div>
        </div>

        <!-- App icons -->
        <div class="px-window">
          <div class="px-titlebar">
            <span class="px-title">💾 UYGULAMALAR</span>
            <div class="px-btns">
              <span class="px-btn">─</span>
              <span class="px-btn">□</span>
              <span class="px-btn">×</span>
            </div>
          </div>
          <div style="padding: 12px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;">
            {apps.map(app => (
              <a href={app.href} class="app-icon">
                <div class="icon-box">{app.icon}</div>
                <span class="icon-label">{app.label}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- GTA Countdown window -->
        <div class="px-window" style="border-color: #e5c46b55;">
          <div class="px-titlebar" style="background: linear-gradient(90deg, #1a0a00, #3a1a00);">
            <span class="px-title" style="color: #e5c46b;">📺 GTA VI SAYAÇ</span>
            <div class="px-btns"><span class="px-btn">×</span></div>
          </div>
          <div style="padding: 14px 16px; text-align: center;">
            <p style="font-family: 'VT323', monospace; font-size: 13px; color: #666; margin: 0 0 8px; letter-spacing: 0.06em;">19 KASIM 2026 KONSOL LANSMANINA</p>
            <div id="gtaPixelCount" style="font-family: 'VT323', monospace; font-size: 32px; color: #e5c46b; line-height: 1; margin-bottom: 4px;">-- GÜN</div>
            <p style="font-family: 'VT323', monospace; font-size: 12px; color: #3a3a3a; margin: 0;">GTA TARIHI SEZONU DEVAM EDIYOR</p>
          </div>
        </div>

      </div>

      <!-- MIDDLE: Lists window -->
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <div class="px-window">
          <div class="px-titlebar">
            <span class="px-title">📋 LİSTELER.EXE</span>
            <div class="px-btns">
              <span class="px-btn">─</span>
              <span class="px-btn">□</span>
              <span class="px-btn">×</span>
            </div>
          </div>
          <div style="padding: 0;">
            {lists.map(list => {
              const slugs = list.games.map((i: any) => i.slug);
              return (
                <a href={`/lists/${list.slug}`}
                  style="display: block; padding: 14px 16px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
                  onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
                  <p style="font-family: 'VT323', monospace; font-size: 16px; color: #c8c8e0; margin: 0 0 4px; letter-spacing: 0.02em;">{list.title}</p>
                  <p style="font-size: 11px; color: #555566; margin: 0 0 10px; line-height: 1.4;">{list.description}</p>
                  <div style="display: flex; gap: 2px; flex-wrap: wrap;">
                    {slugs.slice(0, 16).map((slug: string) => {
                      const g = gmap[slug];
                      const cover = g?.coverUrl;
                      return cover ? (
                        <div style="width: 28px; height: 28px; overflow: hidden; border: 1px solid #1e1e2e; image-rendering: pixelated;">
                          <img src={cover} alt="" style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; image-rendering: pixelated;" loading="lazy" />
                        </div>
                      ) : <div style="width: 28px; height: 28px; background: #0d0d12; border: 1px solid #1e1e2e;"></div>;
                    })}
                  </div>
                </a>
              );
            })}
            <a href="/lists" style="display: block; padding: 10px 16px; font-family: 'VT323', monospace; font-size: 14px; color: #3a3a5a; transition: color 0.1s; text-align: center; letter-spacing: 0.06em;"
              onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#3a3a5a'">
              [ TÜM LİSTELER → ]
            </a>
          </div>
        </div>

        <!-- Quiz shortcut -->
        <a href="/quiz" class="px-window" style="text-decoration: none; display: block; transition: border-color 0.15s; border-color: #22c55e44;"
          onmouseover="this.style.borderColor='#22c55e'" onmouseout="this.style.borderColor='#22c55e44'">
          <div class="px-titlebar" style="background: linear-gradient(90deg, #0a1a0a, #0a2a0a);">
            <span class="px-title" style="color: #22c55e;">🎮 QUİZ.EXE — OYUNU BİL</span>
            <div class="px-btns"><span class="px-btn">▶</span></div>
          </div>
          <div style="padding: 14px 16px; text-align: center;">
            <p style="font-family: 'VT323', monospace; font-size: 14px; color: #555566; margin: 0 0 6px; letter-spacing: 0.04em;">EKRAN GÖRÜNTÜSÜNDEN OYUNU TAHMİN ET</p>
            <p style="font-family: 'VT323', monospace; font-size: 24px; color: #22c55e; margin: 0; letter-spacing: 0.06em;">[ BAŞLAT ]</p>
          </div>
        </a>
      </div>

      <!-- RIGHT: News window -->
      <div class="px-window">
        <div class="px-titlebar">
          <span class="px-title">📰 HABERLER.LOG</span>
          <div class="px-btns">
            <span class="px-btn">─</span>
            <span class="px-btn">□</span>
            <span class="px-btn">×</span>
          </div>
        </div>
        <div>
          {latestNews.map(article => {
            const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
            return (
              <a href={`/news/${article.id}`}
                style="display: block; padding: 12px 14px; border-bottom: 1px solid #1e1e2e; transition: background 0.1s;"
                onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">
                {article.data.image && (
                  <div style="width: 100%; height: 60px; overflow: hidden; margin-bottom: 8px; border: 1px solid #1e1e2e; image-rendering: pixelated;">
                    <img src={article.data.image} alt="" loading="lazy"
                      style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.75; image-rendering: auto;" />
                  </div>
                )}
                <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 4px;">
                  <span style="font-family: 'VT323', monospace; font-size: 11px; color: #3a3a5a; letter-spacing: 0.04em;">{dateStr}</span>
                </div>
                <p style="font-size: 12px; color: #c8c8e0; margin: 0; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{article.data.title}</p>
              </a>
            );
          })}
          <a href="/news" style="display: block; padding: 10px 14px; font-family: 'VT323', monospace; font-size: 14px; color: #3a3a5a; text-align: center; letter-spacing: 0.06em; transition: color 0.1s;"
            onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#3a3a5a'">
            [ TÜM HABERLER → ]
          </a>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  // System clock
  function updateClock() {
    const now = new Date();
    const time = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const date = now.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric' });
    const c = document.getElementById('osClock');
    const d = document.getElementById('osDate');
    if (c) c.textContent = time;
    if (d) d.textContent = date;
  }
  updateClock();
  setInterval(updateClock, 1000);

  // GTA countdown
  const target = new Date('2026-11-19T10:00:00Z').getTime();
  const days = Math.ceil((target - Date.now()) / 86400000);
  const el = document.getElementById('gtaPixelCount');
  if (el) el.textContent = `${Math.max(0, days)} GÜN`;
</script>
