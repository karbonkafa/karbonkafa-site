---
import Layout from '../layouts/Layout.astro';
import listsData from '../data/lists.json';
import gamesData from '../data/games.json';
import { getCollection } from 'astro:content';

const lists = (listsData as any[]).slice(0, 3);
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  'Duyuru': '#4a9eed', 'Çıkış': '#22c55e', 'Donanım': '#f97316',
  'Endüstri': '#9b59b6', 'Bağımsız': '#14b8a6', 'Haftalık': '#e5c46b',
};

function getBanner(slug: string): string {
  const g = gmap[slug];
  if (!g) return '';
  const sid = g.stores?.steam?.uid;
  return sid
    ? `https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/${sid}/header.jpg`
    : g.coverUrl || '';
}
---

<Layout title="Home">

  <!-- Hero -->
  <section style="padding: 72px 0 80px;">
    <p style="font-size: 12px; color: #e5c46b; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; font-family: 'JetBrains Mono', monospace;">KarbonGameStudios</p>
    <h1 style="font-size: clamp(32px, 5vw, 56px); font-weight: 600; letter-spacing: -0.04em; line-height: 1.08; margin: 0 0 24px;">
      <span>Oyunlar için</span><br />
      <span style="color: #444;">bir bakış açısı.</span>
    </h1>
    <p style="font-size: 16px; color: #555; max-width: 520px; line-height: 1.7; margin: 0 0 32px;">
      1.400+ oyunluk arşiv. Küratörlenmiş listeler. Başarım rehberleri.
      Bir içerik üreticisinin oyun dünyasına bakışı.
    </p>
    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
      <a href="/lists" style="background: #e5c46b; color: #0a0a0a; padding: 12px 24px; font-size: 14px; font-weight: 600; font-family: 'JetBrains Mono', monospace; transition: opacity 0.15s; text-decoration: none;"
        onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
        Listeler →
      </a>
      <a href="/quiz" style="border: 1px solid #333; color: #666; padding: 12px 24px; font-size: 14px; font-family: 'JetBrains Mono', monospace; transition: all 0.15s; text-decoration: none;"
        onmouseover="this.style.borderColor='#666';this.style.color='#e5e5e5'" onmouseout="this.style.borderColor='#333';this.style.color='#666'">
        Quiz Oyna
      </a>
    </div>
  </section>

  <!-- Featured Lists -->
  <section style="margin-bottom: 72px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px;">
      <p style="font-size: 12px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0;">Öne Çıkan Listeler</p>
      <a href="/lists" style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace; transition: color 0.15s; text-decoration: none;"
        onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">tümü →</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      {lists.map(list => (
        <a href={`/lists/${list.slug}`}
          style="display: block; background: #111; border: 1px solid #1a1a1a; padding: 20px 22px; transition: border-color 0.15s;"
          onmouseover="this.style.borderColor='#333'" onmouseout="this.style.borderColor='#1a1a1a'">
          <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 4px;">
            <h3 style="font-size: 15px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">{list.title}</h3>
            <span style="font-size: 10px; color: #444; font-family: 'JetBrains Mono', monospace; flex-shrink: 0;">{list.games.length} oyun</span>
          </div>
          <p style="font-size: 12px; color: #555; margin: 0 0 12px; line-height: 1.5;">{list.description}</p>
          <div style="display: flex; gap: 3px; flex-wrap: wrap;">
            {list.games.map((item: any) => {
              const g = gmap[item.slug];
              const cover = g?.coverUrl;
              return cover ? (
                <div style="width: 48px; height: 48px; overflow: hidden; border: 1px solid #1a1a1a; flex-shrink: 0;">
                  <img src={cover} alt="" loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block;" />
                </div>
              ) : <div style="width: 48px; height: 48px; background: #0d0d0d; border: 1px solid #111; flex-shrink: 0;"></div>;
            })}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest News -->
  <section style="margin-bottom: 72px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px;">
      <p style="font-size: 12px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0;">Son Haberler</p>
      <a href="/news" style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace; transition: color 0.15s; text-decoration: none;"
        onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">tümü →</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      {latestNews.map(article => {
        const color = categoryColors[article.data.category] || '#666';
        const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' });
        return (
          <a href={`/news/${article.id}`}
            style="display: grid; grid-template-columns: auto 1fr; gap: 0; background: #111; border: 1px solid #1a1a1a; transition: border-color 0.15s;"
            onmouseover="this.style.borderColor='#333'" onmouseout="this.style.borderColor='#1a1a1a'">
            {article.data.image && (
              <div style="width: 120px; overflow: hidden; flex-shrink: 0;">
                <img src={article.data.image} alt="" loading="lazy"
                  style="width: 120px; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.8;" />
              </div>
            )}
            <div style="padding: 16px 20px; display: flex; flex-direction: column; gap: 6px;">
              <div style="display: flex; align-items: center; gap: 8px;">
                <span style={`font-size: 9px; border: 1px solid ${color}44; color: ${color}; padding: 1px 6px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.06em;`}>
                  {article.data.category}
                </span>
                <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{dateStr}</span>
              </div>
              <p style="font-size: 14px; font-weight: 500; margin: 0; line-height: 1.35; color: #ccc;">{article.data.title}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Quick links row -->
  <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1px; background: #1a1a1a; border: 1px solid #1a1a1a; margin-bottom: 72px;">
    {[
      { href: '/guides', label: 'Rehberler', sub: '%100 tamamlama için', icon: '🏆' },
      { href: '/schedule', label: 'Yayın Akışı', sub: 'Bu hafta ne yayınlanıyor', icon: '📅' },
      { href: '/quiz', label: 'Quiz', sub: 'Ekran görüntüsünden tahmin et', icon: '🎮' },
    ].map(item => (
      <a href={item.href}
        style="padding: 28px 24px; background: #111; display: flex; flex-direction: column; gap: 8px; transition: background 0.15s; text-decoration: none;"
        onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
        <span style="font-size: 20px;">{item.icon}</span>
        <h3 style="font-size: 16px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">{item.label}</h3>
        <p style="font-size: 13px; color: #555; margin: 0;">{item.sub}</p>
      </a>
    ))}
  </section>

  <!-- GTA 6 countdown -->
  <section style="border: 1px solid #2a2200; padding: 28px 32px; background: #0d0b00; margin-bottom: 48px; position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, #e5c46b44, #e5c46b, #e5c46b44);"></div>
    <p style="font-size: 11px; color: #e5c46b; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px; font-family: 'JetBrains Mono', monospace;">Rockstar Saati</p>
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; margin-bottom: 16px;">
      <div>
        <h2 style="font-size: 22px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.02em;">GTA 6 Konsol Lansmanı</h2>
        <p style="font-size: 13px; color: #666; margin: 0; font-family: 'JetBrains Mono', monospace;">19 Kasım 2026</p>
      </div>
      <!-- Countdown -->
      <div id="gta6countdown" style="display: flex; gap: 16px; font-family: 'JetBrains Mono', monospace;">
        {['gün', 'saat', 'dak', 'sn'].map(unit => (
          <div style="text-align: center; min-width: 48px;">
            <div id={`cd-${unit}`} style="font-size: 28px; font-weight: 600; color: #e5c46b; line-height: 1;">--</div>
            <div style="font-size: 9px; color: #555; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px;">{unit}</div>
          </div>
        ))}
      </div>
    </div>
    <p style="font-size: 13px; color: #555; margin: 0; line-height: 1.5;">
      GTA Tarihi sezonu bu güne yönelmiş. PC lansmanı sonrası tam playthrough + Karbon RP.
    </p>
  </section>

  <script>
    const target = new Date('2026-11-19T10:00:00Z').getTime();
    const els = {
      'gün': document.getElementById('cd-gün'),
      'saat': document.getElementById('cd-saat'),
      'dak': document.getElementById('cd-dak'),
      'sn': document.getElementById('cd-sn'),
    };
    function update() {
      const now = Date.now();
      const diff = target - now;
      if (diff <= 0) {
        Object.values(els).forEach(el => { if (el) el.textContent = '00'; });
        return;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      if (els['gün']) els['gün'].textContent = String(d);
      if (els['saat']) els['saat'].textContent = String(h).padStart(2,'0');
      if (els['dak']) els['dak'].textContent = String(m).padStart(2,'0');
      if (els['sn']) els['sn'].textContent = String(s).padStart(2,'0');
    }
    update();
    setInterval(update, 1000);
  </script>

</Layout>
