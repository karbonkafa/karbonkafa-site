---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';
import gamesData from '../../../data/games.json';
import igdbData from '../../../data/igdb.json';

const { id } = Astro.params;

const { data: list } = await supabase
  .from('lists')
  .select('*, profiles(username, display_name, avatar_url)')
  .eq('id', id)
  .single();

if (!list) return Astro.redirect('/lists');

const { data: items } = await supabase
  .from('list_items')
  .select('*')
  .eq('list_id', id)
  .order('position');

const gmap: Record<string, any> = {};
for (const g of gamesData as any[]) gmap[g.slug] = g;
const igdb = igdbData as Record<string, any>;

const dateStr = new Date(list.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
const author = list.profiles;
---

<Layout title={list.title}>

  <!-- Breadcrumb -->
  <div style="margin-bottom: 40px; font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace;">
    <a href="/lists" style="color: #444; transition: color 0.15s;" onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">listeler</a>
    <span style="margin: 0 8px;">/</span>
    <span style="color: #888;">{list.title}</span>
  </div>

  <!-- Header -->
  <div style="margin-bottom: 40px;">
    <h1 style="font-size: clamp(22px, 3vw, 36px); font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">{list.title}</h1>
    {list.description && <p style="font-size: 15px; color: #888; margin: 0 0 16px; line-height: 1.65; max-width: 600px;">{list.description}</p>}
    <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
      {author && (
        <a href={`/u/${author.username}`} style="display: flex; align-items: center; gap: 8px; text-decoration: none;">
          <div style="width: 24px; height: 24px; border-radius: 50%; overflow: hidden; background: #222; flex-shrink: 0;">
            {author.avatar_url
              ? <img src={author.avatar_url} style="width: 100%; height: 100%; object-fit: cover;" />
              : <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #e5c46b;">{(author.display_name || author.username)[0].toUpperCase()}</div>
            }
          </div>
          <span style="font-size: 12px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">{author.display_name || author.username}</span>
        </a>
      )}
      <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{dateStr}</span>
      <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{(items || []).length} oyun</span>
    </div>
  </div>

  <div style="border-top: 1px solid #222; margin-bottom: 32px;"></div>

  <!-- Edit button (shown if own list) -->
  <div id="editActions" style="display: none; margin-bottom: 24px;">
    <a href={`/lists/u/${id}/edit`}
      style="font-size: 12px; border: 1px solid #333; color: #666; padding: 6px 14px; font-family: 'JetBrains Mono', monospace; text-decoration: none; transition: all 0.15s;"
      onmouseover="this.style.borderColor='#555';this.style.color='#aaa'" onmouseout="this.style.borderColor='#333';this.style.color='#666'">
      Düzenle
    </a>
  </div>

  <!-- Games -->
  <div style="display: flex; flex-direction: column; gap: 0;">
    {(items || []).map((item, idx) => {
      const game = gmap[item.game_slug];
      if (!game) return null;
      const igdbEntry = igdb[item.game_slug] || {};
      const devs = igdbEntry.mainDevs?.length > 0 ? igdbEntry.mainDevs : (game.developer ? [game.developer] : []);
      const mc = game.metacriticScore;
      const mcColor = mc >= 75 ? '#22c55e' : mc >= 50 ? '#eab308' : '#ef4444';
      return (
        <div style="border-bottom: 1px solid #1a1a1a; padding: 20px 0; display: grid; grid-template-columns: 28px 72px 1fr; gap: 16px; align-items: start;">
          <div style="font-size: 18px; font-weight: 600; color: #2a2a2a; font-family: 'JetBrains Mono', monospace; padding-top: 6px; text-align: right;">
            {String(idx + 1).padStart(2, '0')}
          </div>
          <a href={`/games/${item.game_slug}`} style="display: block; width: 72px; height: 72px; overflow: hidden; border: 1px solid #1a1a1a; flex-shrink: 0; transition: border-color 0.15s;"
            onmouseover="this.style.borderColor='#444'" onmouseout="this.style.borderColor='#1a1a1a'">
            {game.coverUrl ? (
              <img src={game.coverUrl.replace('t_cover_big/', 't_cover_big_2x/')} alt={game.title} loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block;" />
            ) : <div style="width: 100%; height: 100%; background: #0d0d0d;"></div>}
          </a>
          <div style="display: flex; flex-direction: column; gap: 5px; padding-top: 2px;">
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
              <a href={`/games/${item.game_slug}`}
                style="font-size: 16px; font-weight: 600; letter-spacing: -0.02em; color: #e5e5e5; line-height: 1.3; transition: color 0.15s;"
                onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#e5e5e5'">
                {game.title}
              </a>
              {mc && <span style={`font-size: 11px; font-family: 'JetBrains Mono', monospace; font-weight: 600; color: ${mcColor}; flex-shrink: 0; padding-top: 3px;`}>{mc}</span>}
            </div>
            {devs.length > 0 && (
              <p style="font-size: 11px; color: #555; margin: 0; font-family: 'JetBrains Mono', monospace;">{devs.join(', ')}{game.releaseYear ? ` · ${game.releaseYear}` : ''}</p>
            )}
            {item.note && (
              <p style="font-size: 13px; color: #777; margin: 4px 0 0; line-height: 1.6; border-left: 2px solid #e5c46b33; padding-left: 10px; font-style: italic;">
                "{item.note}"
              </p>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <div style="margin-top: 48px;">
    <a href="/lists" style="font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace; transition: color 0.15s;"
      onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">← listeler</a>
  </div>

</Layout>

<script define:vars={{ listUserId: list.user_id }}>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  supabase.auth.getUser().then(({ data: { user } }) => {
    if (user?.id === listUserId) {
      document.getElementById('editActions')!.style.display = 'block';
    }
  });
</script>
