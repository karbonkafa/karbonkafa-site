---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';
import gamesData from '../../../data/games.json';
import { entityHref, entitySubtitle, typeInfo } from '../../../lib/entities';

const { id } = Astro.params;

const { data: list } = await supabase
  .from('lists')
  .select('*, profiles!lists_user_id_fkey(username, display_name, avatar_url)')
  .eq('id', id)
  .single();

if (!list) return Astro.redirect('/lists');

const { data: items } = await supabase
  .from('list_items')
  .select('*, entity:entities(id, type, source, source_id, slug, title, image_url, year, meta)')
  .eq('list_id', id)
  .order('position');

const gmap: Record<string, any> = {};
for (const g of gamesData as any[]) gmap[g.slug] = g;

// Build a unified view per item: entity row wins, legacy game_slug falls back.
function itemView(item: any) {
  const e = item.entity;
  if (e) {
    return { title: e.title, image: e.image_url, sub: entitySubtitle(e), href: entityHref(e), icon: typeInfo(e.type).icon };
  }
  const g = gmap[item.game_slug];
  if (g) {
    const dev = Array.isArray(g.developer) ? g.developer[0] : g.developer;
    return {
      title: g.title,
      image: g.coverUrl ? g.coverUrl.replace('t_cover_big/', 't_cover_big_2x/') : null,
      sub: [dev, g.releaseYear].filter(Boolean).join(' · '),
      href: `/games/${item.game_slug}`,
      icon: '🎮',
    };
  }
  return null;
}

const dateStr = new Date(list.created_at).toLocaleDateString('tr-TR', {
  day: 'numeric', month: 'long', year: 'numeric'
});
const author = list.profiles as any;
const itemCount = (items || []).length;
---

<Layout title={list.title}>

  <!-- Header window -->
  <div class="px-window" style="margin-bottom:12px;">
    <div class="px-titlebar" style="border-left-color:#e5c46b;">
      <div style="display:flex;align-items:center;gap:8px;min-width:0;">
        <span class="px-title" style="color:#e5c46b;">📋 LİSTELER.EXE</span>
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;">›</span>
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{list.title.toUpperCase()}</span>
      </div>
      <div class="px-btns">
        <span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span>
      </div>
    </div>
    <div style="padding:16px;">
      <!-- Breadcrumb -->
      <div style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;margin-bottom:10px;letter-spacing:0.06em;">
        <a href="/lists" style="color:#444455;transition:color 0.1s;"
          onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#444455'">LİSTELER</a>
        <span style="margin:0 6px;color:#2a2a3a;">›</span>
        <span style="color:#888899;">{list.title.toUpperCase()}</span>
      </div>

      <h1 style="font-family:'IBM Plex Mono', monospace;font-size:30px;color:#ffffff;margin:0 0 8px;letter-spacing:0.02em;line-height:1.15;">
        {list.title}
      </h1>

      {list.description && (
        <p style="font-size:11px;color:#888899;line-height:1.7;margin:0 0 12px;max-width:640px;">{list.description}</p>
      )}

      <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
        {author && (
          <a href={`/u/${author.username}`} style="display:flex;align-items:center;gap:7px;text-decoration:none;transition:opacity 0.1s;"
            onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
            <div style="width:22px;height:22px;border-radius:50%;overflow:hidden;background:#1a1a2a;border:1px solid #2a2a3a;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;">
              {author.avatar_url
                ? <img src={author.avatar_url} style="width:100%;height:100%;object-fit:cover;" />
                : (author.display_name || author.username)[0].toUpperCase()
              }
            </div>
            <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;">{author.username}</span>
          </a>
        )}
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">{dateStr}</span>
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">{itemCount} öğe</span>

        <!-- Edit button — shown client-side if own list -->
        <a id="editBtn" href={`/lists/u/${id}/edit`} style="display:none;font-family:'IBM Plex Mono', monospace;font-size:11px;border:1px solid #1e1e2e;color:#555566;padding:2px 10px;text-decoration:none;transition:all 0.1s;"
          onmouseover="this.style.color='#e5c46b';this.style.borderColor='#e5c46b'" onmouseout="this.style.color='#555566';this.style.borderColor='#1e1e2e'">
          DÜZENLE
        </a>
      </div>
    </div>
  </div>

  <!-- Game list window -->
  <div class="px-window">
    <div class="px-titlebar">
      <span class="px-title">📚 {itemCount} ÖĞE</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>

    <div style="display:flex;flex-direction:column;">
      {(items || []).map((item: any, idx: number) => {
        const v = itemView(item);
        if (!v) return null;
        const cover = (
          <div style="width:64px;height:64px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;background:#0d0d12;">
            {v.image
              ? <img src={v.image} alt={v.title} loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" />
              : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:24px;">{v.icon}</div>
            }
          </div>
        );
        return (
          <div style="border-bottom:1px solid #1e1e2e;padding:14px 16px;display:grid;grid-template-columns:32px 64px 1fr;gap:14px;align-items:start;transition:background 0.1s;"
            onmouseover="this.style.background='#0d0d18'" onmouseout="this.style.background='none'">
            <div style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#2a2a3a;padding-top:4px;text-align:right;">
              {String(idx + 1).padStart(2, '0')}
            </div>
            {v.href
              ? <a href={v.href} style="display:block;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">{cover}</a>
              : cover}
            <div style="display:flex;flex-direction:column;gap:4px;padding-top:2px;">
              <div style="display:flex;align-items:flex-start;gap:8px;">
                <span style="font-size:13px;flex-shrink:0;line-height:1.2;">{v.icon}</span>
                {v.href
                  ? <a href={v.href} style="font-size:11px;font-weight:600;letter-spacing:-0.02em;color:#e5e5e5;line-height:1.3;transition:color 0.15s;"
                      onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#e5e5e5'">{v.title}</a>
                  : <span style="font-size:11px;font-weight:600;letter-spacing:-0.02em;color:#e5e5e5;line-height:1.3;">{v.title}</span>}
              </div>
              {v.sub && (
                <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#555566;margin:0;">{v.sub}</p>
              )}
              {item.note && (
                <p style="font-size:11px;color:#778899;margin:4px 0 0;line-height:1.6;border-left:2px solid #e5c46b33;padding-left:10px;font-style:italic;">
                  "{item.note}"
                </p>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Back link -->
  <div style="margin-top:12px;">
    <a href="/lists" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;transition:color 0.1s;"
      onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#444455'">← LİSTELER</a>
  </div>

</Layout>

<!-- Pass list owner ID via data attribute, no inline import needed -->
<div id="__listMeta" data-user-id={list.user_id} style="display:none;"></div>

<script>
  import { createClient } from '@supabase/supabase-js';

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const listUserId = (document.getElementById('__listMeta') as HTMLElement).dataset.userId;

  sb.auth.getUser().then(({ data: { user } }) => {
    if (user?.id === listUserId) {
      const btn = document.getElementById('editBtn');
      if (btn) btn.style.display = 'inline-block';
    }
  });
</script>
