---
import Layout from '../../layouts/Layout.astro';
import listsData from '../../data/lists.json';
import gamesData from '../../data/games.json';

const lists = listsData as any[];
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;
---

<Layout title="Lists" description="KarbonGameStudios curated game lists.">

  <div style="margin-bottom: 48px;">
    <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Koleksiyonlar</p>
    <h1 style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Listeler</h1>
    <p style="font-size: 15px; color: #666; margin: 0;">Küratörlenmiş oyun koleksiyonları. Veritabanı değil, bakış açısı.</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 8px;">
    {lists.map(list => (
      <a href={`/lists/${list.slug}`}
        style="display: block; background: #111; border: 1px solid #1a1a1a; padding: 20px 22px; transition: border-color 0.15s;"
        onmouseover="this.style.borderColor='#333'" onmouseout="this.style.borderColor='#1a1a1a'">
        <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 4px;">
          <h2 style="font-size: 15px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">{list.title}</h2>
          <div style="display: flex; align-items: center; gap: 10px; flex-shrink: 0;">
            <span style="font-size: 10px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">{list.author}</span>
            <span style="font-size: 10px; color: #444; font-family: 'JetBrains Mono', monospace;">{list.games.length} oyun</span>
          </div>
        </div>
        <p style="font-size: 12px; color: #555; margin: 0 0 12px; line-height: 1.5;">{list.description}</p>
        <div style="display: flex; gap: 3px; flex-wrap: wrap;">
          {list.games.map((item: any) => {
            const g = gmap[item.slug];
            const cover = g?.coverUrl;
            return cover ? (
              <div style="width: 48px; height: 48px; overflow: hidden; border: 1px solid #1a1a1a; flex-shrink: 0;" title={g?.title || ''}>
                <img src={cover} alt="" loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block;" />
              </div>
            ) : <div style="width: 48px; height: 48px; background: #0d0d0d; border: 1px solid #111; flex-shrink: 0;"></div>;
          })}
        </div>
      </a>
    ))}
  </div>

</Layout>
