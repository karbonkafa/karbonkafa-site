---
import Layout from '../../layouts/Layout.astro';
import listsData from '../../data/lists.json';
import gamesData from '../../data/games.json';

const lists = listsData as any[];
const games = gamesData as any[];
const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;
---

<Layout title="Lists" description="KarbonGameStudios curated game lists.">

  <div style="margin-bottom: 48px;">
    <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Koleksiyonlar</p>
    <h1 style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Listeler</h1>
    <p style="font-size: 15px; color: #666; margin: 0;">Küratörlenmiş oyun koleksiyonları. Veritabanı değil, bakış açısı.</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 1px; background: #1a1a1a; border: 1px solid #1a1a1a;">
    {lists.map(list => {
      const coverGame = gmap[list.coverGame] || gmap[list.games[0]?.slug];
      const steamId = coverGame?.stores?.steam?.uid;
      const coverUrl = steamId
        ? `https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/${steamId}/header.jpg`
        : coverGame?.coverUrl;
      const gameCount = list.games.length;
      const dateStr = new Date(list.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
      return (
        <a href={`/lists/${list.slug}`}
          style="display: grid; grid-template-columns: 300px 1fr; background: #111; transition: background 0.15s; min-height: 110px;"
          onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
          <!-- Cover strip: 3 game thumbnails stacked horizontally -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #0a0a0a; overflow: hidden;">
            {list.games.slice(0, 3).map((item: any) => {
              const g = gmap[item.slug];
              const sid = g?.stores?.steam?.uid;
              const imgUrl = sid
                ? `https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/${sid}/header.jpg`
                : g?.coverUrl;
              return imgUrl ? (
                <div style="overflow: hidden;">
                  <img src={imgUrl} alt="" loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; opacity: 0.8;" />
                </div>
              ) : <div style="background: #0d0d0d;"></div>;
            })}
          </div>
          <!-- Info -->
          <div style="padding: 20px 24px; display: flex; flex-direction: column; justify-content: center; gap: 8px;">
            <h2 style="font-size: 18px; font-weight: 600; margin: 0; letter-spacing: -0.02em; line-height: 1.25;">{list.title}</h2>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{list.description}</p>
            <div style="display: flex; align-items: center; gap: 12px; margin-top: 4px;">
              <span style="font-size: 11px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">{list.author}</span>
              {list.authorRole && <span style="font-size: 10px; color: #444; font-family: 'JetBrains Mono', monospace;">{list.authorRole}</span>}
              <span style="font-size: 10px; color: #444; font-family: 'JetBrains Mono', monospace; margin-left: auto;">{gameCount} oyun</span>
            </div>
          </div>
        </a>
      );
    })}
  </div>

</Layout>
