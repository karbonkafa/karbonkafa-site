---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Listeler" description="Karbon OS — topluluk listeleri.">

  <div class="px-window">
    <div class="px-titlebar" style="border-left-color:#e5c46b;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span class="px-title" style="color:#e5c46b;">📋 LİSTELER</span>
        <span id="listCount" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;"></span>
      </div>
      <a href="/lists/create" style="font-family:'IBM Plex Mono', monospace;font-size:11px;background:#e5c46b22;border:1px solid #e5c46b44;color:#e5c46b;padding:2px 10px;text-decoration:none;transition:all 0.1s;"
        onmouseover="this.style.background='#e5c46b33'" onmouseout="this.style.background='#e5c46b22'">
        + YENİ LİSTE
      </a>
    </div>

    <div id="allLists" style="display:flex;flex-direction:column;">
      <div style="padding:24px;text-align:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;letter-spacing:0.04em;">
        YÜKLENİYOR...
      </div>
    </div>
  </div>

</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const esc = (s: string) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

  (async () => {
    const { data: lists } = await sb
      .from('lists')
      .select('id, title, description, created_at, profiles!lists_user_id_fkey(username, avatar_url), list_items(entity:entities(image_url)), list_likes(count)')
      .eq('is_public', true)
      .order('created_at', { ascending: false })
      .limit(50);

    const el = document.getElementById('allLists') as HTMLElement;
    const countEl = document.getElementById('listCount') as HTMLElement;

    if (!lists || lists.length === 0) {
      el.innerHTML = `
        <div style="padding:32px;text-align:center;">
          <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;margin:0 0 12px;letter-spacing:0.04em;">HENÜZ LİSTE YOK — İLKİNİ SEN OLUŞTUR</p>
          <a href="/lists/create" style="font-family:'IBM Plex Mono', monospace;font-size:11px;background:#e5c46b;color:#0a0a0a;padding:6px 18px;text-decoration:none;letter-spacing:0.06em;">LİSTE OLUŞTUR →</a>
        </div>`;
      return;
    }

    countEl.textContent = lists.length + ' LİSTE';

    el.innerHTML = lists.map((list: any) => {
      const author = list.profiles;
      const items: any[] = list.list_items || [];
      const covers = items.map(i => i.entity?.image_url).filter(Boolean).slice(0, 6);
      const likeCount = list.list_likes?.[0]?.count ?? 0;
      const dateStr = new Date(list.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' });

      const mosaic = covers.map(c =>
        `<div style="width:64px;height:64px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
          <img src="${esc(c)}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;"/>
        </div>`).join('');

      const avatar = author?.avatar_url
        ? `<img src="${esc(author.avatar_url)}" style="width:100%;height:100%;object-fit:cover;" />`
        : (author?.username?.[0] || '?').toUpperCase();

      return `
        <a href="/lists/u/${list.id}"
          style="display:block;padding:16px;border-bottom:1px solid #1e1e2e;transition:background 0.15s;"
          onmouseover="this.style.background='#111118'" onmouseout="this.style.background='none'">
          <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:4px;">
            <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#ffffff;margin:0;letter-spacing:0.02em;line-height:1.2;">${esc(list.title)}</p>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
              ${author ? `<span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#3b82f6;">${esc(author.username)}</span>` : ''}
              <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">${items.length} öğe</span>
              ${likeCount > 0 ? `<span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;">♥ ${likeCount}</span>` : ''}
            </div>
          </div>
          ${list.description ? `<p style="font-size:12px;color:#666677;margin:0 0 8px;line-height:1.5;">${esc(list.description)}</p>` : ''}
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px;">
            <div style="display:flex;gap:2px;flex-wrap:wrap;">${mosaic}</div>
            <div style="width:64px;height:64px;background:#1a1a2a;border:1px solid #2a2a3a;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono', monospace;font-size:12px;color:#e5c46b;flex-shrink:0;">${avatar}</div>
          </div>
        </a>`;
    }).join('');
  })();
</script>
