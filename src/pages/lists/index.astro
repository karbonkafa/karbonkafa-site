---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Listeler" description="Karbon OS — topluluk listeleri.">

  <p class="os-path">C:\\KARBON\\LISTELER\\</p>

  <!-- ── LİSTELER ─────────────────────────── -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:12px;">
    <div style="display:flex;align-items:baseline;gap:10px;">
      <h2 style="font-family:'IBM Plex Mono', monospace;font-size:13px;color:#ffc20a;margin:0;letter-spacing:0.04em;">📋 LİSTELER.LOG</h2>
      <span id="listCount" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;"></span>
    </div>
    <a href="/lists/create" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#555566;transition:color 0.1s;"
      onmouseover="this.style.color='#ffc20a'" onmouseout="this.style.color='#555566'">+ YENİ LİSTE</a>
  </div>

  <div id="allLists" class="list-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:6px;margin-bottom:24px;">
    <div style="grid-column:1/-1;padding:24px;text-align:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;letter-spacing:0.04em;">
      YÜKLENİYOR...
    </div>
  </div>

</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const esc = (s: string) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

  (async () => {
    const { data: lists } = await sb
      .from('lists')
      .select('id, title, description, created_at, profiles!lists_user_id_fkey(username, avatar_url), list_items(entity:entities(image_url)), list_likes(count)')
      .eq('is_public', true)
      .order('created_at', { ascending: false })
      .limit(60);

    const el = document.getElementById('allLists') as HTMLElement;
    const countEl = document.getElementById('listCount') as HTMLElement;

    if (!lists || lists.length === 0) {
      el.innerHTML = `
        <div style="grid-column:1/-1;padding:32px;text-align:center;">
          <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#333344;margin:0 0 12px;letter-spacing:0.04em;">HENÜZ LİSTE YOK — İLKİNİ SEN OLUŞTUR</p>
          <a href="/lists/create" style="font-family:'IBM Plex Mono', monospace;font-size:11px;background:#ffc20a;color:#0a0a0a;padding:6px 18px;text-decoration:none;letter-spacing:0.06em;">LİSTE OLUŞTUR →</a>
        </div>`;
      return;
    }

    countEl.textContent = lists.length + ' LİSTE';

    el.innerHTML = lists.map((list: any) => {
      const author = list.profiles;
      const items: any[] = list.list_items || [];
      const covers = items.map(i => i.entity?.image_url).filter(Boolean).slice(0, 14);
      const likeCount = list.list_likes?.[0]?.count ?? 0;

      const thumbs = covers.map(c =>
        `<div style="width:32px;height:32px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
          <img src="${esc(c)}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;"/>
        </div>`).join('');

      const avatar = author?.avatar_url
        ? `<img src="${esc(author.avatar_url)}" style="width:100%;height:100%;object-fit:cover;" />`
        : (author?.username?.[0] || '?').toUpperCase();

      return `
        <a href="/lists/u/${list.id}"
          style="display:block;background:#0d0d12;border:1px solid #ffc20a22;text-decoration:none;transition:border-color 0.15s;"
          onmouseover="this.style.borderColor='#ffc20a66'" onmouseout="this.style.borderColor='#ffc20a22'">
          <div style="padding:14px 16px;border-bottom:1px solid #1e1e2e;">
            <div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;">
              <p style="font-family:'IBM Plex Mono', monospace;font-size:13px;color:#ffffff;margin:0;line-height:1.2;">${esc(list.title)}</p>
              <span style="font-family:'IBM Plex Mono', monospace;font-size:10px;color:#444455;flex-shrink:0;white-space:nowrap;">${items.length} öğe${likeCount > 0 ? ` · <span style="color:#ffc20a;">♥${likeCount}</span>` : ''}</span>
            </div>
            ${list.description ? `<p style="font-size:11px;color:#555566;margin:0;line-height:1.5;">${esc(list.description)}</p>` : ''}
          </div>
          <div style="padding:8px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
            <div style="display:flex;gap:2px;flex-wrap:wrap;">${thumbs}</div>
            <div style="width:32px;height:32px;background:#1a1a2a;border:1px solid #2a2a3a;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#ffc20a;flex-shrink:0;">${avatar}</div>
          </div>
        </a>`;
    }).join('');
  })();
</script>
