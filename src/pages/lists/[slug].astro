---
import Layout from '../../layouts/Layout.astro';
import listsData from '../../data/lists.json';
import gamesData from '../../data/games.json';
import igdbData from '../../data/igdb.json';

export function getStaticPaths() {
  return (listsData as any[]).map(list => ({
    params: { slug: list.slug },
    props: { list },
  }));
}

const { list } = Astro.props as { list: any };
const games = gamesData as any[];
const igdb = igdbData as Record<string, any>;

const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const dateStr = new Date(list.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

function getBannerUrl(slug: string): string {
  const g = gmap[slug];
  if (!g) return '';
  const steamId = g.stores?.steam?.uid;
  if (steamId) return `https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/${steamId}/header.jpg`;
  return g.coverUrl || '';
}

function getMetacritic(slug: string): number | null {
  return gmap[slug]?.metacriticScore || null;
}
---

<Layout title={list.title} description={list.description}>

  <p class="os-path">C:\KARBON\LISTELER\{list.slug?.toUpperCase()}</p>

  <!-- Breadcrumb -->
  <div style="margin-bottom: 40px; font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace;">
    <a href="/lists" style="color: #444; transition: color 0.15s;"
      onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">listeler</a>
    <span style="margin: 0 8px;">/</span>
    <span style="color: #888;">{list.title}</span>
  </div>

  <!-- Header -->
  <div style="margin-bottom: 48px;">
    <h1 class="os-title">{list.title}</h1>
    <p style="font-size: 15px; color: #888; line-height: 1.7; margin: 0 0 20px; max-width: 640px;">{list.description}</p>
    <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 12px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">{list.author}</span>
        {list.authorRole && <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">· {list.authorRole}</span>}
      </div>
      <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{dateStr}</span>
      <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{list.games.length} oyun</span>
    </div>
  </div>

  <div style="border-top: 1px solid #222; margin-bottom: 40px;"></div>

  <!-- Game list -->
  <div style="display: flex; flex-direction: column; gap: 0;">
    {list.games.map((item: any, idx: number) => {
      const game = gmap[item.slug];
      if (!game) return null;
      const bannerUrl = getBannerUrl(item.slug);
      const mc = getMetacritic(item.slug);
      const mcColor = mc >= 75 ? '#22c55e' : mc >= 50 ? '#eab308' : '#ef4444';
      const igdbEntry = igdb[item.slug] || {};
      const devs = igdbEntry.mainDevs?.length > 0 ? igdbEntry.mainDevs : (game.developer ? [game.developer] : []);
      return (
        <div style="border-bottom: 1px solid #1a1a1a; padding: 20px 0; display: grid; grid-template-columns: 28px 72px 1fr; gap: 16px; align-items: start;">
          <!-- Number -->
          <div style="font-size: 18px; font-weight: 600; color: #2a2a2a; font-family: 'JetBrains Mono', monospace; padding-top: 6px; text-align: right;">
            {String(idx + 1).padStart(2, '0')}
          </div>
          <!-- Square cover -->
          <a href={`/games/${item.slug}`} style="display: block; width: 72px; height: 72px; overflow: hidden; border: 1px solid #1a1a1a; flex-shrink: 0; transition: border-color 0.15s;"
            onmouseover="this.style.borderColor='#444'" onmouseout="this.style.borderColor='#1a1a1a'">
            {game.coverUrl ? (
              <img src={game.coverUrl.replace('t_cover_big/', 't_cover_big_2x/')} alt={game.title} loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; transition: transform 0.2s;"
                onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'" />
            ) : (
              <div style="width: 100%; height: 100%; background: #0d0d0d;"></div>
            )}
          </a>
          <!-- Info -->
          <div style="display: flex; flex-direction: column; gap: 5px; padding-top: 2px;">
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
              <a href={`/games/${item.slug}`}
                style="font-size: 16px; font-weight: 600; letter-spacing: -0.02em; color: #e5e5e5; line-height: 1.3; transition: color 0.15s;"
                onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#e5e5e5'">
                {game.title}
              </a>
              {mc && (
                <span style={`font-size: 11px; font-family: 'JetBrains Mono', monospace; font-weight: 600; color: ${mcColor}; flex-shrink: 0; padding-top: 3px;`}>{mc}</span>
              )}
            </div>
            {devs.length > 0 && (
              <p style="font-size: 11px; color: #555; margin: 0; font-family: 'JetBrains Mono', monospace;">{devs.join(', ')}{game.releaseYear ? ` · ${game.releaseYear}` : ''}</p>
            )}
            {item.note && (
              <p style="font-size: 13px; color: #777; margin: 4px 0 0; line-height: 1.6; border-left: 2px solid #e5c46b33; padding-left: 10px; font-style: italic;">
                "{item.note}"
              </p>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Back -->
  <div style="margin-top: 48px;">
    <a href="/lists" style="font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace; transition: color 0.15s;"
      onmouseover="this.style.color='#e5e5e5'" onmouseout="this.style.color='#444'">
      ← listeler
    </a>
  </div>

</Layout>
