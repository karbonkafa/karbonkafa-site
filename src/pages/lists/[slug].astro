---
import Layout from '../../layouts/Layout.astro';
import listsData from '../../data/lists.json';
import gamesData from '../../data/games.json';
import igdbData from '../../data/igdb.json';

export function getStaticPaths() {
  return (listsData as any[]).map(list => ({
    params: { slug: list.slug },
    props: { list },
  }));
}

const { list } = Astro.props as { list: any };
const games = gamesData as any[];
const igdb = igdbData as Record<string, any>;

const gmap: Record<string, any> = {};
for (const g of games) gmap[g.slug] = g;

const dateStr = new Date(list.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

function getMetacritic(slug: string): number | null {
  return gmap[slug]?.metacriticScore || null;
}
---

<Layout title={list.title} description={list.description}>

  <!-- Header -->
  <div class="px-window" style="margin-bottom: 12px;">
    <div class="px-titlebar" style="border-left-color: #e5c46b;">
      <span class="px-title" style="color: #e5c46b;">📋 LİSTELER.EXE</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>
    <div style="padding: 16px;">
      <div style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;letter-spacing:0.06em;margin-bottom:8px;">
        <a href="/lists" style="color:#444455;transition:color 0.1s;" onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#444455'">LİSTELER</a>
        <span style="margin:0 6px;color:#2a2a3a;">›</span>
        <span style="color:#888899;">{list.title.toUpperCase()}</span>
      </div>
      <h1 style="font-family:'IBM Plex Mono', monospace;font-size:30px;color:#ffffff;margin:0 0 8px;letter-spacing:0.02em;line-height:1.15;">{list.title}</h1>
      {list.description && (
        <p style="font-size:11px;color:#888899;line-height:1.7;margin:0 0 12px;max-width:640px;">{list.description}</p>
      )}
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <a href={`/u/${list.author}`} style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;text-decoration:none;transition:opacity 0.1s;"
          onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">{list.author}</a>
        {list.authorRole && <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">· {list.authorRole}</span>}
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">{dateStr}</span>
        <span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#444455;">{list.games.length} oyun</span>
      </div>
    </div>
  </div>

  <!-- Game list -->
  <div class="px-window">
    <div class="px-titlebar">
      <span class="px-title">🎮 {list.games.length} OYUN</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>

    <div style="display: flex; flex-direction: column;">
      {list.games.map((item: any, idx: number) => {
        const game = gmap[item.slug];
        if (!game) return null;
        const mc = getMetacritic(item.slug);
        const mcColor = mc >= 75 ? '#22c55e' : mc >= 50 ? '#eab308' : '#ef4444';
        const igdbEntry = igdb[item.slug] || {};
        const devs = igdbEntry.mainDevs?.length > 0 ? igdbEntry.mainDevs : (game.developer ? [game.developer] : []);
        return (
          <div style="border-bottom: 1px solid #1e1e2e; padding: 14px 16px; display: grid; grid-template-columns: 32px 64px 1fr; gap: 14px; align-items: start; transition: background 0.1s;"
            onmouseover="this.style.background='#0d0d18'" onmouseout="this.style.background='none'">
            <!-- Number -->
            <div style="font-family:'IBM Plex Mono', monospace;font-size:12px;color:#2a2a3a;padding-top:4px;text-align:right;">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <!-- Cover -->
            <a href={`/games/${item.slug}`} style="display:block;width:64px;height:64px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;transition:border-color 0.15s;"
              onmouseover="this.style.borderColor='#e5c46b'" onmouseout="this.style.borderColor='#2a2a3a'">
              {game.coverUrl ? (
                <img src={game.coverUrl.replace('t_cover_big/', 't_cover_big_2x/')} alt={game.title} loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" />
              ) : (
                <div style="width:100%;height:100%;background:#0d0d12;"></div>
              )}
            </a>
            <!-- Info -->
            <div style="display:flex;flex-direction:column;gap:4px;padding-top:2px;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                <a href={`/games/${item.slug}`}
                  style="font-size:11px;font-weight:600;letter-spacing:-0.02em;color:#e5e5e5;line-height:1.3;transition:color 0.15s;"
                  onmouseover="this.style.color='#e5c46b'" onmouseout="this.style.color='#e5e5e5'">
                  {game.title}
                </a>
                {mc && (
                  <span style={`font-family:'IBM Plex Mono', monospace;font-size:11px;font-weight:600;color:${mcColor};flex-shrink:0;padding-top:2px;`}>{mc}</span>
                )}
              </div>
              {devs.length > 0 && (
                <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#555566;margin:0;">{devs.join(', ')}{game.releaseYear ? ` · ${game.releaseYear}` : ''}</p>
              )}
              {item.note && (
                <p style="font-size:11px;color:#778899;margin:4px 0 0;line-height:1.6;border-left:2px solid #e5c46b33;padding-left:10px;font-style:italic;">
                  "{item.note}"
                </p>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

</Layout>
