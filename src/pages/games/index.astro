---
import Layout from '../../layouts/Layout.astro';
import gamesData from '../../data/games.json';

const games = gamesData as any[];

const statusLabel: Record<string, string> = {
  active: 'Active',
  backlog: 'Backlog',
  paused: 'Paused',
  completed: 'Completed',
};

const statusColor: Record<string, string> = {
  active: '#22c55e',
  backlog: '#666',
  paused: '#eab308',
  completed: '#e5c46b',
};

const storePlatforms = ['Steam', 'Epic', 'GOG', 'PSN', 'Xbox'];

const stats = {
  total: games.length,
  active: games.filter(g => g.status === 'active').length,
  backlog: games.filter(g => g.status === 'backlog').length,
  paused: games.filter(g => g.status === 'paused').length,
  completed: games.filter(g => g.status === 'completed').length,
};
---

<Layout title="Game Archive" description="KarbonGameStudios 1,640 game archive — backlog, active and completed games.">

  <div style="margin-bottom: 40px;">
    <p data-i18n="archive.title" style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Oyun Arşivi</p>
    <h1 data-i18n="nav.games" style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Oyunlar</h1>
    <p data-i18n="archive.desc" style="font-size: 15px; color: #666; margin: 0;">Tüm kütüphane. Oynanan, bekleyen, tamamlanan.</p>
  </div>

  <!-- Stats -->
  <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; border: 1px solid #222; margin-bottom: 40px;">
    {[
      { key: 'archive.total', label: 'Total', value: stats.total, color: '#e5e5e5' },
      { key: 'archive.active', label: 'Active', value: stats.active, color: '#22c55e' },
      { key: 'archive.backlog', label: 'Backlog', value: stats.backlog, color: '#666' },
      { key: 'archive.paused', label: 'Paused', value: stats.paused, color: '#eab308' },
      { key: 'archive.completed', label: 'Completed', value: stats.completed, color: '#e5c46b' },
    ].map(s => (
      <div style="padding: 20px 16px; background: #111; text-align: center;">
        <p style={`font-size: 24px; font-weight: 600; margin: 0 0 4px; color: ${s.color}; font-family: 'JetBrains Mono', monospace;`}>{s.value}</p>
        <p data-i18n={s.key} style="font-size: 11px; color: #444; margin: 0; text-transform: uppercase; letter-spacing: 0.08em;">{s.label}</p>
      </div>
    ))}
  </div>

  <!-- Filters -->
  <div style="margin-bottom: 24px; display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
    <input
      type="text"
      id="search"
      data-i18n-placeholder="archive.search"
      placeholder="Oyun ara..."
      style="background: #111; border: 1px solid #222; color: #e5e5e5; padding: 8px 14px; font-size: 14px; outline: none; flex: 1; min-width: 200px; font-family: inherit;"
    />
    <select id="statusFilter" style="background: #111; border: 1px solid #222; color: #e5e5e5; padding: 8px 14px; font-size: 14px; outline: none; font-family: inherit;">
      <option value="" data-i18n="archive.allStatus">Tüm Durumlar</option>
      <option value="active" data-i18n="archive.active">Aktif</option>
      <option value="backlog" data-i18n="archive.backlog">Backlog</option>
      <option value="paused" data-i18n="archive.paused">Duraklatıldı</option>
      <option value="completed" data-i18n="archive.completed">Tamamlandı</option>
    </select>
    <select id="platformFilter" style="background: #111; border: 1px solid #222; color: #e5e5e5; padding: 8px 14px; font-size: 14px; outline: none; font-family: inherit;">
      <option value="" data-i18n="archive.allPlatforms">Tüm Platformlar</option>
      {storePlatforms.map(p => <option value={p.toLowerCase()}>{p}</option>)}
    </select>
    <span style="font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace; white-space: nowrap;"><span id="count">{games.length}</span> <span data-i18n="archive.gamesCount">oyun</span></span>
  </div>

  <!-- Game Grid -->
  <div id="gameGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 8px;">
    {games.map(game => {
      const mc = game.metacriticScore;
      const mcColor = mc >= 75 ? '#22c55e' : mc >= 50 ? '#eab308' : '#ef4444';
      return (
        <a
          href={`/games/${game.slug}`}
          class="game-card"
          data-title={game.title.toLowerCase()}
          data-status={game.status}
          data-stores={Object.keys(game.stores || {}).join(',')}
          style="background: #111; display: flex; flex-direction: column; border: 1px solid #1a1a1a; overflow: hidden; cursor: pointer; transition: border-color 0.15s;"
        >
          <!-- Cover -->
          <div style="position: relative; aspect-ratio: 3/4; overflow: hidden;">
            {game.coverUrl ? (
              <img
                src={game.coverUrl?.replace('t_cover_big/', 't_cover_big_2x/')}
                alt={game.title}
                loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.2s;"
                class="card-img"
              />
            ) : (
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 12px; text-align: center;">
                <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">{game.title}</span>
              </div>
            )}
            <!-- Status dot -->
            <div style={`position: absolute; top: 7px; right: 7px; width: 6px; height: 6px; border-radius: 50%; background: ${statusColor[game.status] || '#666'};`}></div>
          </div>
          <!-- Info below cover -->
          <div style="padding: 8px 9px; display: flex; align-items: flex-start; justify-content: space-between; gap: 6px;">
            <p style="font-size: 11px; color: #ccc; margin: 0; line-height: 1.35; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{game.title}</p>
            {mc && (
              <span style={`font-size: 10px; font-family: 'JetBrains Mono', monospace; font-weight: 600; color: ${mcColor}; flex-shrink: 0; padding-top: 1px;`}>{mc}</span>
            )}
          </div>
        </a>
      );
    })}
  </div>

  <!-- No results -->
  <div id="noResults" style="display: none; border: 1px solid #222; padding: 48px; text-align: center; color: #444; font-family: 'JetBrains Mono', monospace; font-size: 14px; margin-top: 1px;">
    <span data-i18n="archive.noResults">sonuç bulunamadı</span>
  </div>

</Layout>

<style>
  .game-card:hover {
    border-color: #333 !important;
  }
  .game-card:hover .card-img {
    transform: scale(1.04);
  }
</style>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const statusFilter = document.getElementById('statusFilter') as HTMLSelectElement;
  const platformFilter = document.getElementById('platformFilter') as HTMLSelectElement;
  const cards = document.querySelectorAll('.game-card') as NodeListOf<HTMLElement>;
  const countEl = document.getElementById('count')!;
  const noResults = document.getElementById('noResults')!;

  // URL'den q parametresini oku
  const urlParams = new URLSearchParams(window.location.search);
  const urlQ = urlParams.get('q');
  if (urlQ) search.value = urlQ;

  function filter() {
    const q = search.value.toLowerCase();
    const status = statusFilter.value;
    const platform = platformFilter.value;
    let visible = 0;

    cards.forEach(card => {
      const matchTitle = card.dataset.title?.includes(q) ?? true;
      const matchStatus = !status || card.dataset.status === status;
      const stores = card.dataset.stores || '';
      const matchPlatform = !platform || stores.split(',').includes(platform);
      const show = matchTitle && matchStatus && matchPlatform;
      card.style.display = show ? 'block' : 'none';
      if (show) visible++;
    });

    countEl.textContent = String(visible);
    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  search.addEventListener('input', filter);
  statusFilter.addEventListener('change', filter);
  platformFilter.addEventListener('change', filter);
</script>
