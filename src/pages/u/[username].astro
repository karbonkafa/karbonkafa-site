---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import gamesData from '../../data/games.json';

const { username } = Astro.params;

// Fetch profile
const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('username', username)
  .single();

if (!profile) {
  return Astro.redirect('/lists');
}

// Fetch user's public lists with item counts
const { data: lists } = await supabase
  .from('lists')
  .select('*, list_items(count)')
  .eq('user_id', profile.id)
  .eq('is_public', true)
  .order('updated_at', { ascending: false });

// Fetch list items for cover icons
const listIds = (lists || []).map(l => l.id);
const { data: allItems } = listIds.length > 0
  ? await supabase.from('list_items').select('list_id, game_slug, position').in('list_id', listIds).order('position')
  : { data: [] };

// Group items by list
const itemsByList: Record<string, string[]> = {};
for (const item of (allItems || [])) {
  if (!itemsByList[item.list_id]) itemsByList[item.list_id] = [];
  itemsByList[item.list_id].push(item.game_slug);
}

// Game cover lookup
const gmap: Record<string, any> = {};
for (const g of gamesData as any[]) gmap[g.slug] = g;

const joinDate = new Date(profile.created_at).toLocaleDateString('tr-TR', { month: 'long', year: 'numeric' });
---

<Layout title={`${profile.display_name || profile.username} — Listeler`}>

  <!-- Profile header -->
  <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 48px; padding-bottom: 40px; border-bottom: 1px solid #1a1a1a;">
    <div style="width: 72px; height: 72px; border-radius: 50%; overflow: hidden; background: #111; border: 2px solid #222; flex-shrink: 0;">
      {profile.avatar_url ? (
        <img src={profile.avatar_url} alt={profile.username} style="width: 100%; height: 100%; object-fit: cover;" />
      ) : (
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 600; color: #e5c46b;">
          {(profile.display_name || profile.username)[0].toUpperCase()}
        </div>
      )}
    </div>
    <div>
      <h1 style="font-size: 22px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.02em;">{profile.display_name || profile.username}</h1>
      <p style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace; margin: 0 0 8px;">@{profile.username}</p>
      <p style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace; margin: 0;">{(lists || []).length} liste · {joinDate}'dan beri</p>
    </div>
    <div id="ownActions" style="display: none; margin-left: auto;">
      <a href="/lists/create"
        style="background: #e5c46b; color: #0a0a0a; padding: 10px 20px; font-size: 12px; font-weight: 600; font-family: 'JetBrains Mono', monospace; text-decoration: none; transition: opacity 0.15s;"
        onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
        + Yeni Liste
      </a>
    </div>
  </div>

  <!-- Lists -->
  {(!lists || lists.length === 0) ? (
    <div style="text-align: center; padding: 64px 0; color: #444; font-family: 'JetBrains Mono', monospace; font-size: 14px;">
      Henüz liste yok.
    </div>
  ) : (
    <div style="display: flex; flex-direction: column; gap: 8px;">
      {lists.map(list => {
        const slugs = itemsByList[list.id] || [];
        const count = slugs.length;
        return (
          <a href={`/lists/u/${list.id}`}
            style="display: block; background: #111; border: 1px solid #1a1a1a; padding: 20px 22px; transition: border-color 0.15s;"
            onmouseover="this.style.borderColor='#333'" onmouseout="this.style.borderColor='#1a1a1a'">
            <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 4px;">
              <h2 style="font-size: 15px; font-weight: 600; margin: 0; letter-spacing: -0.02em;">{list.title}</h2>
              <span style="font-size: 10px; color: #444; font-family: 'JetBrains Mono', monospace; flex-shrink: 0;">{count} oyun</span>
            </div>
            {list.description && (
              <p style="font-size: 12px; color: #555; margin: 0 0 12px; line-height: 1.5;">{list.description}</p>
            )}
            {slugs.length > 0 && (
              <div style="display: flex; gap: 3px; flex-wrap: wrap;">
                {slugs.slice(0, 20).map(slug => {
                  const g = gmap[slug];
                  const cover = g?.coverUrl;
                  return cover ? (
                    <div style="width: 36px; height: 36px; overflow: hidden; border: 1px solid #1a1a1a; flex-shrink: 0;">
                      <img src={cover} alt="" loading="lazy"
                        style="width: 100%; height: 100%; object-fit: cover; object-position: top; display: block;" />
                    </div>
                  ) : <div style="width: 36px; height: 36px; background: #0d0d0d; border: 1px solid #111;"></div>;
                })}
              </div>
            )}
          </a>
        );
      })}
    </div>
  )}

</Layout>

<script define:vars={{ profileId: profile.id }}>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );
  supabase.auth.getUser().then(({ data: { user } }) => {
    if (user && user.id === profileId) {
      document.getElementById('ownActions')!.style.display = 'block';
    }
  });
</script>
