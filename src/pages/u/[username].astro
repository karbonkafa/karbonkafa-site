---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { entityHref, typeInfo } from '../../lib/entities';
import { titleById, TITLES } from '../../lib/titles';

const STATUS_BADGE: Record<string, { label: string; color: string }> = {
  want:    { label: 'İSTİYOR',  color: '#e5c46b' },
  active:  { label: 'AKTİF',    color: '#3b82f6' },
  done:    { label: 'BİTTİ',    color: '#22c55e' },
  dropped: { label: 'BIRAKTI',  color: '#ef4444' },
};

const { username } = Astro.params;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('username', username)
  .single();

if (!profile) return Astro.redirect('/lists');

// Parallel fetch (no games.json import): lists, library entries, replay count
const [listsRes, entriesRes, replayRes] = await Promise.all([
  supabase.from('lists').select('id, title, description, updated_at, list_likes(count)')
    .eq('user_id', profile.id).eq('is_public', true)
    .order('updated_at', { ascending: false }),
  supabase.from('entries').select('status, rating, entity:entities(id, type, source_id, slug, title, image_url)')
    .eq('user_id', profile.id).order('logged_at', { ascending: false }),
  supabase.from('logs').select('id', { count: 'exact', head: true })
    .eq('user_id', profile.id).eq('is_replay', true),
]);
const lists = listsRes.data || [];
const library = (entriesRes.data || []).filter((e: any) => e.entity);
const replayCount = replayRes.count ?? 0;

// List covers + counts (entity images only — everything is entity-backed now)
const listIds = lists.map(l => l.id);
const { data: allItems } = listIds.length > 0
  ? await supabase.from('list_items').select('list_id, entity:entities(id, image_url)')
      .in('list_id', listIds).order('position')
  : { data: [] };

const coversByList: Record<string, string[]> = {};
const countByList: Record<string, number> = {};
for (const item of (allItems || []) as any[]) {
  countByList[item.list_id] = (countByList[item.list_id] || 0) + 1;
  const cover = item.entity?.image_url ?? null;
  if (cover) (coversByList[item.list_id] ||= []).push(cover);
}
const totalItems = new Set((allItems || []).map((i: any) => i.entity?.id).filter(Boolean)).size;

const likesByList: Record<string, number> = {};
for (const l of lists as any[]) likesByList[l.id] = l.list_likes?.[0]?.count ?? 0;

const joinDate = new Date(profile.created_at).toLocaleDateString('tr-TR', { month: 'long', year: 'numeric' });
const displayName = profile.display_name || profile.username;
const initials = displayName[0].toUpperCase();

const titleStats = {
  logged: library.length,
  types: new Set(library.map((e: any) => e.entity?.type).filter(Boolean)).size,
  lists: (lists || []).length,
  replays: replayCount ?? 0,
};
const shownTitle = (() => {
  const t = titleById(profile.display_title);
  return t && t.earned(titleStats) ? t : null;
})();

// Hero background: first cover available
const heroCover = Object.values(coversByList)[0]?.[0] ?? library[0]?.entity?.image_url ?? null;
---

<Layout title={`${displayName} — Profil`}>

  <!-- Hero -->
  <div style="position: relative; padding: 32px 24px; overflow: hidden; min-height: 180px; display: flex; align-items: flex-end; border: 1px solid #1e1e2e;">
    <!-- Background blur -->
    {heroCover && (
      <div style={`position: absolute; inset: 0; background-image: url('${heroCover}'); background-size: cover; background-position: center; filter: blur(40px) brightness(0.25); transform: scale(1.1);`}></div>
    )}
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0.7) 60%, #0a0a0a 100%);"></div>

    <!-- Profile info -->
    <div style="position: relative; display: flex; align-items: flex-end; gap: 28px; width: 100%; flex-wrap: wrap;">
      <!-- Avatar -->
      <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; background: #111; border: 3px solid rgba(255,255,255,0.1); flex-shrink: 0; box-shadow: 0 8px 32px rgba(0,0,0,0.6);">
        {profile.avatar_url ? (
          <img src={profile.avatar_url} alt={displayName} style="width: 100%; height: 100%; object-fit: cover;" />
        ) : (
          <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 700; color: #e5c46b; background: #111;">
            {initials}
          </div>
        )}
      </div>
      <!-- Name + stats -->
      <div style="flex: 1; min-width: 200px;">
        <p style="font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 0.12em; font-family: 'IBM Plex Mono', monospace; margin: 0 0 8px;">Profil</p>
        <h1 style="font-family: 'IBM Plex Mono', monospace; font-size: clamp(24px, 4vw, 40px); font-weight: 400; letter-spacing: 0.01em; margin: 0 0 12px; line-height: 1.05; text-shadow: 0 2px 16px rgba(0,0,0,0.5);">{displayName}</h1>
        {shownTitle && (
          <p style="display: inline-block; font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: #e5c46b; background: #e5c46b14; border: 1px solid #e5c46b33; padding: 2px 10px; margin: 0 0 12px; letter-spacing: 0.06em;">&gt; rank: {shownTitle.label}</p>
        )}
        <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
          <span style="font-size: 13px; color: #aaa;">
            <strong style="color: #e5e5e5;">{(lists || []).length}</strong> liste
          </span>
          {totalItems > 0 && (
            <span style="font-size: 13px; color: #aaa;">
              <strong style="color: #e5e5e5;">{totalItems}</strong> öğe
            </span>
          )}
          {library.length > 0 && (
            <span style="font-size: 13px; color: #aaa;">
              <strong style="color: #e5e5e5;">{library.length}</strong> loglandı
            </span>
          )}
          <span style="font-size: 12px; color: #555; font-family: 'IBM Plex Mono', monospace;">{joinDate}'dan beri</span>
        </div>
      </div>
      <!-- Own profile actions -->
      <div id="ownActions" style="display: none; align-self: center; gap: 10px; flex-wrap: wrap;">
        <a href="/lists/create"
          style="background: #e5c46b; color: #0a0a0a; padding: 10px 22px; font-size: 13px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; text-decoration: none; letter-spacing: 0.02em; transition: opacity 0.15s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          + Yeni Liste
        </a>
        <a href="/auth/logout"
          style="border: 1px solid #333; color: #555; padding: 10px 16px; font-size: 12px; font-family: 'IBM Plex Mono', monospace; text-decoration: none; transition: all 0.15s;"
          onmouseover="this.style.borderColor='#555';this.style.color='#888'" onmouseout="this.style.borderColor='#333';this.style.color='#555'">
          Çıkış
        </a>
      </div>
    </div>
  </div>

  <!-- Achievements (titles) section -->
  <div style="margin-top: 40px;">
    <p style="font-size: 12px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'IBM Plex Mono', monospace; margin: 0 0 16px;">
      Başarımlar <span style="color:#e5c46b;">{TITLES.filter(t => t.earned(titleStats)).length}/{TITLES.length}</span>
    </p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:6px;">
      {TITLES.map(t => {
        const earned = t.earned(titleStats);
        const col = earned ? '#e5c46b' : '#3a3a44';
        return (
          <div style={`background:#0d0d12;border:1px solid ${earned ? '#e5c46b33' : '#1e1e2e'};padding:10px 12px;${earned ? '' : 'opacity:0.6;'}`}>
            <p style={`font-family:'IBM Plex Mono', monospace;font-size:11px;color:${col};margin:0 0 4px;letter-spacing:0.04em;`}>{earned ? '◆' : '◇'} {t.label}</p>
            <p style="font-size:11px;color:#555566;margin:0;line-height:1.4;">{t.desc}</p>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Lists section -->
  <div style="margin-top: 48px;">
    <p style="font-size: 12px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'IBM Plex Mono', monospace; margin: 0 0 20px;">
      Genel Listeler
    </p>

    {(!lists || lists.length === 0) ? (
      <div style="text-align: center; padding: 80px 0; color: #333; font-family: 'IBM Plex Mono', monospace; font-size: 14px;">
        Henüz liste yok.
      </div>
    ) : (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:6px;">
        {lists.map(list => {
          const covers = (coversByList[list.id] || []).slice(0, 14);
          const itemTotal = countByList[list.id] || 0;
          const likeCount = likesByList[list.id] || 0;
          return (
            <a href={`/lists/u/${list.id}`}
              style="display:block;background:#0d0d12;border:1px solid #e5c46b22;text-decoration:none;transition:border-color 0.15s;"
              onmouseover="this.style.borderColor='#e5c46b66'" onmouseout="this.style.borderColor='#e5c46b22'">
              <div style="padding:14px 16px;border-bottom:1px solid #1e1e2e;">
                <div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px;margin-bottom:4px;">
                  <p style="font-family:'IBM Plex Mono', monospace;font-size:13px;color:#ffffff;margin:0;line-height:1.2;">{list.title}</p>
                  <span style="font-family:'IBM Plex Mono', monospace;font-size:10px;color:#444455;flex-shrink:0;white-space:nowrap;">{itemTotal} öğe{likeCount > 0 ? ` · ♥${likeCount}` : ''}</span>
                </div>
                {list.description && <p style="font-size:11px;color:#555566;margin:0;line-height:1.5;">{list.description}</p>}
              </div>
              <div style="padding:8px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                <div style="display:flex;gap:2px;flex-wrap:wrap;">
                  {covers.map((c: string) => (
                    <div style="width:32px;height:32px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
                      <img src={c} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" />
                    </div>
                  ))}
                </div>
                <div style="width:32px;height:32px;background:#1a1a2a;border:1px solid #2a2a3a;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;flex-shrink:0;">
                  {profile.avatar_url
                    ? <img src={profile.avatar_url} alt="" style="width:100%;height:100%;object-fit:cover;" />
                    : initials}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

  <!-- Library section -->
  {library.length > 0 && (
    <div style="margin-top: 48px;">
      <p style="font-size: 12px; color: #444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'IBM Plex Mono', monospace; margin: 0 0 16px;">
        Kütüphane
      </p>

      <!-- Type filter tabs -->
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:18px;">
        <button class="lib-tab" data-type="all"
          style="font-family:'IBM Plex Mono', monospace;font-size:11px;padding:4px 12px;background:#0d0d12;border:1px solid #3b82f6;color:#3b82f6;cursor:pointer;transition:all 0.1s;letter-spacing:0.04em;">TÜMÜ</button>
        {[...new Set(library.map((e: any) => e.entity.type))].map((t: any) => (
          <button class="lib-tab" data-type={t}
            style="font-family:'IBM Plex Mono', monospace;font-size:11px;padding:4px 12px;background:#0d0d12;border:1px solid #1e1e2e;color:#555566;cursor:pointer;transition:all 0.1s;letter-spacing:0.04em;">
            {typeInfo(t).icon} {typeInfo(t).label.toUpperCase()}
          </button>
        ))}
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;">
        {library.map((e: any) => {
          const ent = e.entity;
          const href = entityHref(ent);
          const badge = STATUS_BADGE[e.status] || null;
          const inner = (
            <>
              <div style="aspect-ratio:2/3;overflow:hidden;background:#0d0d12;position:relative;">
                {ent.image_url
                  ? <img src={ent.image_url} alt={ent.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                  : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:36px;">{typeInfo(ent.type).icon}</div>}
                {badge && (
                  <div style={`position:absolute;top:5px;left:5px;font-family:'IBM Plex Mono', monospace;font-size:10px;color:#000;background:${badge.color};padding:1px 5px;letter-spacing:0.04em;`}>{badge.label}</div>
                )}
                {e.rating && (
                  <div style="position:absolute;bottom:5px;right:5px;font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5c46b;background:rgba(5,5,8,0.85);padding:1px 5px;">{e.rating}/10</div>
                )}
              </div>
              <div style="padding:7px 4px 0;">
                <p style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#e5e5e5;margin:0;line-height:1.2;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{typeInfo(ent.type).icon} {ent.title}</p>
              </div>
            </>
          );
          return href
            ? <a class="lib-card" data-type={ent.type} href={href} style="text-decoration:none;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.82'" onmouseout="this.style.opacity='1'">{inner}</a>
            : <div class="lib-card" data-type={ent.type}>{inner}</div>;
        })}
      </div>
    </div>
  )}

</Layout>

<style>
  /* Hero bleeds to the container edges (matches Layout's 24px side padding) */
</style>

<script define:vars={{ profileId: profile.id }}>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );
  supabase.auth.getUser().then(({ data: { user } }) => {
    if (user?.id === profileId) {
      const el = document.getElementById('ownActions');
      if (el) el.style.display = 'flex';
    }
  });

  // Library type filter
  const libTabs = document.querySelectorAll<HTMLElement>('.lib-tab');
  const libCards = document.querySelectorAll<HTMLElement>('.lib-card');
  libTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const t = tab.dataset.type!;
      libTabs.forEach(b => { b.style.color = '#555566'; b.style.borderColor = '#1e1e2e'; });
      tab.style.color = '#3b82f6'; tab.style.borderColor = '#3b82f6';
      libCards.forEach(card => {
        card.style.display = (t === 'all' || card.dataset.type === t) ? '' : 'none';
      });
    });
  });
</script>
