---
export const prerender = false;
---
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Yönlendiriliyor...</title>
</head>
<body style="background:#0a0a0a;color:#e5e5e5;font-family:'JetBrains Mono',monospace;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;flex-direction:column;gap:16px;">
  <p style="font-size:14px;color:#666;margin:0;">Giriş yapılıyor...</p>
</body>
</html>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  async function handleCallback() {
    const { data: { session } } = await supabase.auth.getSession();

    if (session?.user) {
      // Ensure profile exists
      const user = session.user;
      const meta = user.user_metadata || {};
      const username = meta.user_name || meta.preferred_username || user.email?.split('@')[0] || user.id.slice(0, 8);

      const { data: existing } = await supabase
        .from('profiles')
        .select('username')
        .eq('id', user.id)
        .single();

      if (!existing) {
        await supabase.from('profiles').insert({
          id: user.id,
          username,
          display_name: meta.full_name || meta.name || username,
          avatar_url: meta.avatar_url || meta.picture || null,
        });
      }

      window.location.href = `/u/${existing?.username || username}`;
    } else {
      window.location.href = '/auth/login';
    }
  }

  handleCallback();
</script>
