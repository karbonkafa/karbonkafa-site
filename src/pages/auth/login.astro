---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Giriş Yap">
  <div style="max-width: 400px; margin: 40px auto;">
    <p class="os-path">C:\\KARBON\\AUTH</p>
    <h1 class="os-title">🔐 GİRİŞ.EXE</h1>
    <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Hesap</p>
    <h1 style="font-size: 28px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 8px;">Giriş Yap</h1>
    

    <!-- Email magic link -->
    <div style="background: #111; border: 1px solid #222; padding: 28px;">
      <p style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px; text-transform: uppercase; letter-spacing: 0.06em;">E-posta ile devam et</p>
      <input id="emailInput" type="email" placeholder="ornek@mail.com"
        style="width: 100%; background: #0a0a0a; border: 1px solid #333; color: #e5e5e5; padding: 12px 14px; font-size: 14px; font-family: inherit; outline: none; box-sizing: border-box; margin-bottom: 12px; transition: border-color 0.15s;"
        onfocus="this.style.borderColor='#555'" onblur="this.style.borderColor='#333'"
      />
      <button id="magicBtn"
        style="width: 100%; background: #e5c46b; border: none; color: #0a0a0a; padding: 12px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: inherit; transition: opacity 0.15s;"
        onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
        Bağlantı Gönder →
      </button>
      <p id="magicStatus" style="font-size: 12px; color: #555; margin: 12px 0 0; font-family: 'JetBrains Mono', monospace; display: none;"></p>
    </div>

    <!-- Divider -->
    <div style="display: flex; align-items: center; gap: 12px; margin: 20px 0;">
      <div style="flex: 1; height: 1px; background: #1a1a1a;"></div>
      <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace;">veya</span>
      <div style="flex: 1; height: 1px; background: #1a1a1a;"></div>
    </div>

    <!-- OAuth buttons -->
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <button id="discordBtn"
        style="width: 100%; background: #111; border: 1px solid #333; color: #aaa; padding: 12px; font-size: 13px; cursor: pointer; font-family: 'JetBrains Mono', monospace; transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px;"
        onmouseover="this.style.borderColor='#5865F2';this.style.color='#5865F2'" onmouseout="this.style.borderColor='#333';this.style.color='#aaa'">
        <svg width="16" height="12" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
        Discord ile devam et
      </button>
      <button id="googleBtn"
        style="width: 100%; background: #111; border: 1px solid #333; color: #aaa; padding: 12px; font-size: 13px; cursor: pointer; font-family: 'JetBrains Mono', monospace; transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px;"
        onmouseover="this.style.borderColor='#666';this.style.color='#ccc'" onmouseout="this.style.borderColor='#333';this.style.color='#aaa'">
        <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Google ile devam et
      </button>
      <a href="/auth/steam"
        style="width: 100%; background: #1b2838; border: 1px solid #2a475e; color: #c6d4df; padding: 12px; font-size: 13px; font-family: 'JetBrains Mono', monospace; transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; box-sizing: border-box;"
        onmouseover="this.style.borderColor='#4c9ebe';this.style.color='#fff'" onmouseout="this.style.borderColor='#2a475e';this.style.color='#c6d4df'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39l3.04-6.3a3.5 3.5 0 0 1-1.25-2.59 3.5 3.5 0 0 1 3.5-3.5 3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5h-.15l-2.8 3.38C11.03 21 11.5 21 12 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-4.5 14a2 2 0 0 0 2 2 2 2 0 0 0 2-2 2 2 0 0 0-2-2 2 2 0 0 0-2 2z"/></svg>
        Steam ile devam et
      </a>
    </div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const SITE = window.location.origin;

  // Magic link
  document.getElementById('magicBtn')?.addEventListener('click', async () => {
    const email = (document.getElementById('emailInput') as HTMLInputElement).value.trim();
    if (!email) return;
    const btn = document.getElementById('magicBtn') as HTMLButtonElement;
    const status = document.getElementById('magicStatus')!;
    btn.textContent = 'Gönderiliyor...';
    btn.disabled = true;
    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: `${SITE}/auth/callback` }
    });
    if (error) {
      status.textContent = 'Hata: ' + error.message;
      status.style.color = '#ef4444';
    } else {
      status.textContent = `✓ Bağlantı gönderildi → ${email}`;
      status.style.color = '#22c55e';
    }
    status.style.display = 'block';
    btn.textContent = 'Bağlantı Gönder →';
    btn.disabled = false;
  });

  // Discord
  document.getElementById('discordBtn')?.addEventListener('click', async () => {
    await supabase.auth.signInWithOAuth({
      provider: 'discord',
      options: { redirectTo: `${SITE}/auth/callback` }
    });
  });

  // Google
  document.getElementById('googleBtn')?.addEventListener('click', async () => {
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: `${SITE}/auth/callback` }
    });
  });
</script>
