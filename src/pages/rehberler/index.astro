---
import Layout from '../../layouts/Layout.astro';

const rehberler = [
  {
    slug: 'witcher-3',
    title: 'The Witcher 3: Wild Hunt',
    platform: 'PS5',
    trophy: 'Platinum',
    missable: 19,
    sure: '150–200 saat',
    durum: 'Aktif',
  }
];
---

<Layout title="Rehberler">

  <div style="margin-bottom: 48px;">
    <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Başarım Rehberleri</p>
    <h1 style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Rehberler</h1>
    <p style="font-size: 15px; color: #666; margin: 0;">100% tamamlama için missable odaklı rehberler. Her oyun için tek sayfa, oynayınca yanında açık tut.</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
    {rehberler.map(r => (
      <a href={`/rehberler/${r.slug}`} style="padding: 24px 28px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
        <div>
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 6px;">
            <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.08em;">{r.platform}</span>
            <span style="font-size: 11px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">🏆 {r.trophy}</span>
          </div>
          <h2 style="font-size: 17px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.01em;">{r.title}</h2>
          <p style="font-size: 13px; color: #666; margin: 0;">{r.missable} missable trophy · {r.sure}</p>
        </div>
        <span style={`font-size: 12px; padding: 4px 10px; border: 1px solid ${r.durum === 'Aktif' ? '#e5c46b44' : '#222'}; color: ${r.durum === 'Aktif' ? '#e5c46b' : '#444'}; font-family: 'JetBrains Mono', monospace;`}>{r.durum}</span>
      </a>
    ))}
  </div>

</Layout>
