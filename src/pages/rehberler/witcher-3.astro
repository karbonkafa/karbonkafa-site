---
import Layout from '../../layouts/Layout.astro';

const missableBase = [
  { name: 'Assassin of Kings', risk: 'cok-yuksek', aciklama: 'Radovid suikastı — "Reason of State" zinciri, Isle of Mists öncesi bitmeli' },
  { name: 'Full Crew', risk: 'cok-yuksek', aciklama: '7 müttefiki Kaer Morhen\'e topla — Keira ve Triss en çok kaçırılan' },
  { name: 'Card Collector', risk: 'yuksek', aciklama: '10 missable Gwent kartı var — her tüccar ve hancıyla Gwent oyna' },
  { name: 'Gwent Master', risk: 'yuksek', aciklama: 'Novigrad Gwent turnuvasında Tybalt\'ı yen' },
  { name: 'Friends With Benefits', risk: 'yuksek', aciklama: 'Keira Metz alt hikayesini bitir — onu öldürme' },
  { name: 'The Doppler Effect', risk: 'yuksek', aciklama: 'Novigrad\'daki doppler sorununu çöz' },
  { name: 'Woodland Spirit', risk: 'yuksek', aciklama: 'Woodland Spirit kontratında doğru seçimi yap' },
  { name: 'Kingmaker', risk: 'orta', aciklama: 'Skellige kral seçimi alt hikayesini tamamla' },
  { name: 'Brawl Master', risk: 'orta', aciklama: '3 bölgedeki tüm yumruk dövüşü görevlerini bitir' },
  { name: 'Fast and Furious', risk: 'orta', aciklama: '11 at yarışını kazan — Crows Perch yarışı Isle of Mists öncesi yapılmalı' },
  { name: 'Fist of the South Star', risk: 'dusuk', aciklama: 'Hasar almadan bir yumruk dövüşü kazan' },
];

const missableHoS = [
  { name: 'Let the Good Times Roll!', risk: 'orta', aciklama: 'Belirli quest seçimi gerektirir' },
  { name: 'Shopaholic', risk: 'dusuk', aciklama: 'Hearts of Stone tüccarlarından alışveriş yap' },
  { name: 'Curator of Nightmares', risk: 'yuksek', aciklama: 'Quest seçimine bağlı — dikkatli oku' },
  { name: "When It's Many Against One...", risk: 'orta', aciklama: 'Tüm kabuslara aynı anda meydan oku' },
];

const missableBaW = [
  { name: 'Last Action Hero', risk: 'orta', aciklama: 'Belirli combat koşulu' },
  { name: 'Kling of the Clink', risk: 'orta', aciklama: 'Hapse girme senaryosu — doğru seçim yap' },
  { name: 'A Knight to Remember', risk: 'yuksek', aciklama: 'Şövalyelik seçimlerine bağlı' },
  { name: 'Embodiment of the Five Virtues', risk: 'cok-yuksek', aciklama: 'Tüm oyun boyunca 5 erdemi karşıla — en çok kaçırılan BaW trophy' },
  { name: 'The Grapes of Wrath Stomped', risk: 'dusuk', aciklama: 'Üzüm çiğneme mini oyunu' },
  { name: 'David and Goylat', risk: 'orta', aciklama: 'Belirli düşman koşulu' },
];

const riskColor = (risk: string) => {
  if (risk === 'cok-yuksek') return '#ef4444';
  if (risk === 'yuksek') return '#f97316';
  if (risk === 'orta') return '#eab308';
  return '#22c55e';
};

const riskLabel = (risk: string) => {
  if (risk === 'cok-yuksek') return '⛔ Çok Yüksek';
  if (risk === 'yuksek') return '🔴 Yüksek';
  if (risk === 'orta') return '🟡 Orta';
  return '🟢 Düşük';
};
---

<Layout title="Witcher 3 Platinum Rehberi" description="The Witcher 3 Wild Hunt PS5 Platinum trophy rehberi — missable trophyler, Full Crew, Assassin of Kings ve oynanış sırası.">

  <!-- Breadcrumb -->
  <div style="margin-bottom: 40px; font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace;">
    <a href="/rehberler" style="color: #444;">rehberler</a>
    <span style="margin: 0 8px;">/</span>
    <span style="color: #e5e5e5;">witcher-3</span>
  </div>

  <!-- Header -->
  <div style="margin-bottom: 48px;">
    <div style="display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap;">
      <span style="font-size: 12px; color: #666; border: 1px solid #222; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">PS5 Pro</span>
      <span style="font-size: 12px; color: #e5c46b; border: 1px solid #e5c46b44; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">🏆 Platinum</span>
      <span style="font-size: 12px; color: #666; border: 1px solid #222; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">150–200 saat</span>
      <span style="font-size: 12px; color: #22c55e; border: 1px solid #22c55e44; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">NG+ gerekmez</span>
    </div>
    <h1 style="font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">The Witcher 3: Wild Hunt</h1>
    <p style="font-size: 15px; color: #666; margin: 0; line-height: 1.6;">GOTY Edition — 78 trophy (52 base + 13 Hearts of Stone + 13 Blood and Wine). Tek playthrough yeterli.</p>
  </div>

  <!-- Uyarılar -->
  <div style="border: 1px solid #e5c46b44; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #e5c46b; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">⚠️ Oyuna Başlamadan Önce</p>
    <ol style="margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 10px; font-size: 14px; color: #aaa; line-height: 1.6;">
      <li><strong style="color: #e5e5e5;">Zorluk: Death March</strong> — baştan seç, sonradan değiştirme. "Ran the Gauntlet" için şart.</li>
      <li><strong style="color: #e5e5e5;">Her Gwent oyuncusuna karşı ilk maçı kazan</strong> — kaybedersen kart gider, satın alamazsın.</li>
      <li><strong style="color: #e5e5e5;">Her tüccar, her hancıyla konuş</strong> — Gwent kartı satıyor olabilir, atla.</li>
      <li><strong style="color: #e5e5e5;">Isle of Mists öncesi kontrol et</strong> — Full Crew ve Assassin of Kings zinciri bitmeli.</li>
      <li><strong style="color: #e5e5e5;">Kritik anlarda manuel kayıt al</strong> — missable trophy öncesi yedekle.</li>
    </ol>
  </div>

  <!-- Missable — Ana Oyun -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophy'ler — Ana Oyun <span style="font-size: 14px; color: #666; font-weight: 400;">({missableBase.length} adet)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableBase.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.aciklama}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Full Crew Detay -->
  <div style="border: 1px solid #ef444444; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #ef4444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">Full Crew — Detay</p>
    <p style="font-size: 14px; color: #aaa; margin: 0 0 16px; line-height: 1.6;">7 kişiyi Kaer Morhen'e toplamalısın:</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; margin-bottom: 16px;">
      {['Keira Metz', 'Triss Merigold', 'Vernon Roche', 'Ves', 'Zoltan Chivay', 'Hjalmar an Craite', 'Ermion'].map(k => (
        <div style="padding: 10px 14px; background: #0a0a0a; border: 1px solid #222; font-size: 13px; display: flex; align-items: center; gap: 8px;">
          <span style="color: #666;">□</span> {k}
        </div>
      ))}
    </div>
    <p style="font-size: 13px; color: #888; margin: 0; line-height: 1.6; border-top: 1px solid #222; padding-top: 12px;">
      <strong style="color: #ef4444;">Keira:</strong> "A Favor for a Friend" görevini bitir, Kaer Morhen'e gönder — öldürme.<br />
      <strong style="color: #ef4444;">Triss:</strong> "Now or Never" görevinde Novigrad'da bırak, gemiye bindirme.
    </p>
  </div>

  <!-- Assassin of Kings Detay -->
  <div style="border: 1px solid #ef444444; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #ef4444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">Assassin of Kings — Zincir</p>
    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 14px; font-family: 'JetBrains Mono', monospace;">
      {['1. "A Deadly Plot" — Novigrad', '2. "Redania\'s Most Wanted" — Novigrad', '3. "An Eye for an Eye" — Roche ile', '4. "Reason of State" — zincir tamamlanınca tetiklenir'].map((s, i) => (
        <div style={`padding: 10px 14px; background: #0a0a0a; border: 1px solid #222; font-size: 13px; color: ${i === 3 ? '#e5c46b' : '#aaa'};`}>{s}</div>
      ))}
    </div>
    <p style="font-size: 13px; color: #ef4444; margin: 12px 0 0; line-height: 1.5;">⛔ Isle of Mists'e gitmeden önce bu zincirin tamamlanmış olması lazım — sonradan dönüş yok.</p>
  </div>

  <!-- Hearts of Stone -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophy'ler — Hearts of Stone <span style="font-size: 14px; color: #666; font-weight: 400;">({missableHoS.length} adet)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableHoS.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.aciklama}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Blood and Wine -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophy'ler — Blood and Wine <span style="font-size: 14px; color: #666; font-weight: 400;">({missableBaW.length} adet)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableBaW.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.aciklama}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Oynanış Sırası -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">Optimum Oynanış Sırası</h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222; font-family: 'JetBrains Mono', monospace; font-size: 13px;">
      {[
        { bolge: 'White Orchard', notlar: ['Hancıyla Gwent oyna, kartı al', 'Tüm NPC\'lerle konuş'] },
        { bolge: 'Velen', notlar: ['Keira Metz görevlerini hemen yap → Kaer Morhen\'e gönder', 'Yumruk dövüşlerini ve at yarışlarını gördüğünde yap', 'Gwent: her tüccar / hancı kontrol'] },
        { bolge: 'Novigrad', notlar: ['Triss → "Now or Never" → Novigrad\'da bırak', 'Gwent turnuvası → Tybalt\'ı yen', 'Radovid zinciri başlat: Deadly Plot → Redania\'s Most Wanted', 'The Doppler Effect görevini yap'] },
        { bolge: 'Skellige', notlar: ['Kingmaker alt hikayesi', 'Hjalmar + Ermion', 'Gwent temizle'] },
        { bolge: '⛔ Isle of Mists öncesi kontrol', notlar: ['Full Crew: 7/7 mı?', 'Reason of State zinciri bitti mi?', 'Tüm at yarışları ve yumruk dövüşleri bitti mi?'] },
        { bolge: 'Ana hikaye finali', notlar: ['Assassin of Kings — doğru seçimler'] },
        { bolge: 'Hearts of Stone', notlar: ['Level 32+ önerilir'] },
        { bolge: 'Blood and Wine', notlar: ['En sona bırak', 'Embodiment of the Five Virtues için dikkatli ol'] },
      ].map((adim, i) => (
        <div style={`padding: 16px 20px; background: #111; border-left: 2px solid ${adim.bolge.startsWith('⛔') ? '#ef4444' : '#222'};`}>
          <p style={`font-size: 13px; font-weight: 500; margin: 0 0 8px; color: ${adim.bolge.startsWith('⛔') ? '#ef4444' : '#e5e5e5'};`}>{i + 1}. {adim.bolge}</p>
          <ul style="margin: 0; padding-left: 16px; display: flex; flex-direction: column; gap: 4px;">
            {adim.notlar.map(n => (
              <li style="font-size: 12px; color: #666; line-height: 1.5;">{n}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Takip Listesi -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">Takip Listesi</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">

      <div>
        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Ana Oyun</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Assassin of Kings', 'Full Crew', 'Card Collector', 'Gwent Master', 'Friends With Benefits', 'The Doppler Effect', 'Woodland Spirit', 'Kingmaker', 'Brawl Master', 'Fast and Furious'].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>
      </div>

      <div>
        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Hearts of Stone</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Let the Good Times Roll!', 'Shopaholic', 'Curator of Nightmares', "When It's Many Against One..."].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>

        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 24px 0 12px;">Blood and Wine</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Last Action Hero', 'Kling of the Clink', 'A Knight to Remember', 'Embodiment of the Five Virtues', 'The Grapes of Wrath Stomped', 'David and Goylat'].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Platinum banner -->
  <div style="border: 1px solid #e5c46b44; background: #111; padding: 32px; text-align: center;">
    <p style="font-size: 32px; margin: 0 0 8px;">🏆</p>
    <p style="font-size: 18px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.01em;">The Witcher 3: Wild Hunt</p>
    <p style="font-size: 14px; color: #e5c46b; margin: 0; font-family: 'JetBrains Mono', monospace;">Platinum Trophy</p>
  </div>

</Layout>
