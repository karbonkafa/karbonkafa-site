  },
  {
    title: "The Land of Wine",
    game: "The Witcher 3: Blood and Wine",
    mood: "Orkestral / Avrupa Folk",
    color: "#c6a84b",
    tracks: [
      { name: "Priscilla's Song", duration: "2:58" },
      { name: "Silver for Monsters", duration: "3:44" },
