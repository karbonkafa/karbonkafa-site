      { name: "A Vast Golden Sky", duration: "2:55" },
    ],
    youtube: "https://www.youtube.com/watch?v=CnkT5iKxDXQ"
  },
  {
    title: "Hollow Knight — Silksong Beklentisi",
    game: "Hollow Knight",
    mood: "Orkestral / Melankoli",
    color: "#22c55e",
    tracks: [
      { name: "Hollow Knight", duration: "3:41" },
      { name: "Dirtmouth", duration: "2:12" },
      { name: "White Palace", duration: "3:55" },
      { name: "Gods & Glory", duration: "4:08" },
      { name: "Pale Court", duration: "5:22" },
    ],
    youtube: "https://www.youtube.com/watch?v=Otn_64O1GgM"
  },
  {
    title: "GTA Tarihi Radyo",
    game: "GTA Serisi",
    mood: "Radio / Mixed",
    color: "#ef4444",
    tracks: [
      { name: "K-DST — Fleetwood Mac", duration: "Sonsuz" },
      { name: "Radio Los Santos — Dr. Dre", duration: "Sonsuz" },
      { name: "Liberty City Radio — Deftones", duration: "Sonsuz" },
      { name: "Vice City FM — A Flock of Seagulls", duration: "Sonsuz" },
      { name: "BlueArk Radio — Bob Marley", duration: "Sonsuz" },
    ],
    youtube: "https://www.youtube.com/watch?v=_EHLjnJMGoE"
  },
  {
    title: "Lo-Fi Gaming Session",
    game: "Genel",
    mood: "Lo-Fi / Chill",
    color: "#3b82f6",
    tracks: [
      { name: "Late Night Homework", duration: "Canlı" },
      { name: "Study & Relax", duration: "Canlı" },
      { name: "Chilled Cow Beats", duration: "Canlı" },
