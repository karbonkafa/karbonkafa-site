---

<Layout title="Müzik — Karbon TV">

  <p class="os-path">C:\\KARBON\\MUZIK</p>
  <h1 class="os-title">🎵 MÜZİK.EXE</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 8px;">
    {playlists.map(pl => (
      <div style={`background: #111; border: 1px solid ${pl.color}33; display: flex; flex-direction: column;`}>
        <!-- Header -->
        <div style={`padding: 16px 18px; border-bottom: 1px solid ${pl.color}22;`}>
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 6px;">
            <h2 style="font-size: 15px; font-weight: 600; margin: 0; letter-spacing: -0.01em;">{pl.title}</h2>
            <a href={pl.youtube} target="_blank" rel="noopener"
              style={`font-size: 14px; background: ${pl.color}22; border: 1px solid ${pl.color}66; color: ${pl.color}; padding: 1px 8px; font-family: 'IBM Plex Mono', monospace; text-decoration: none; flex-shrink: 0; letter-spacing: 0.04em;`}
              onmouseover={`this.style.background='${pl.color}44'`} onmouseout={`this.style.background='${pl.color}22'`}>
              ▶ YOUTUBE
            </a>
          </div>
          <p style="font-size: 15px; color: #555566; margin: 0; font-family: 'IBM Plex Mono', monospace;">{pl.game}  ·  {pl.mood}</p>
        </div>
        <!-- Track list -->
        <div style="flex: 1;">
          {pl.tracks.map((track, i) => (
            <div style={`display: flex; align-items: center; justify-content: space-between; padding: 8px 18px; border-bottom: 1px solid #1a1a1a;`}>
              <div style="display: flex; align-items: center; gap: 10px;">
                <span style="font-size: 14px; color: #444455; font-family: 'IBM Plex Mono', monospace; min-width: 20px;">{i + 1}</span>
                <span style="font-size: 12px; color: #888;">{track.name}</span>
              </div>
              <span style="font-size: 14px; color: #555566; font-family: 'IBM Plex Mono', monospace;">{track.duration}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

</Layout>
