---
import Layout from '../layouts/Layout.astro';
import quizPool from '../data/quiz-pool.json';

const pool = (quizPool as any[]).filter(g => g.screenshots && g.screenshots.length >= 2);
const titles = pool.map(g => g.title);
---

<Layout title="Quiz.EXE — Karbon OS">

  <p class="os-path">C:\KARBON\QUIZ</p>

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
    <h1 class="os-title" style="margin:0;">🎮 QUİZ.EXE</h1>
    <div style="display:flex;align-items:center;gap:16px;font-family:'IBM Plex Mono', monospace;">
      <div style="text-align:center;">
        <div id="scoreVal" style="font-size:28px;font-weight:600;color:#22c55e;">0</div>
        <div style="font-size:12px;color:#444455;letter-spacing:0.06em;">DOĞRU</div>
      </div>
      <div style="text-align:center;">
        <div id="streakVal" style="font-size:28px;font-weight:600;color:#ffc20a;">0</div>
        <div style="font-size:12px;color:#444455;letter-spacing:0.06em;">SERİ</div>
      </div>
      <div style="text-align:center;">
        <div id="totalVal" style="font-size:28px;font-weight:600;color:#555566;">0</div>
        <div style="font-size:12px;color:#444455;letter-spacing:0.06em;">TOPLAM</div>
      </div>
    </div>
  </div>

  <div class="px-window">
    <div class="px-titlebar">
      <span class="px-title">📸 EKRAN KESİTİ — TAHMİN ET</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span></div>
    </div>

    <!-- Canvas -->
    <div style="position:relative;background:#0a0907;">
      <canvas id="quizCanvas" style="display:block;width:100%;max-height:420px;image-rendering:pixelated;cursor:crosshair;"></canvas>
      <!-- Level indicator -->
      <div style="position:absolute;top:10px;left:10px;display:flex;gap:4px;" id="levelDots"></div>
      <!-- Lives -->
      <div style="position:absolute;top:10px;right:10px;font-family:'IBM Plex Mono', monospace;font-size:11px;" id="livesDisplay"></div>
      <!-- Reveal overlay -->
      <div id="revealOverlay" style="display:none;position:absolute;inset:0;background:rgba(5,5,8,0.88);flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:24px;text-align:center;">
        <div id="revealIcon" style="font-size:52px;"></div>
        <div id="revealTitle" style="font-family:'IBM Plex Mono', monospace;font-size:28px;color:#fff;letter-spacing:0.04em;"></div>
        <div id="revealMeta" style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#666677;"></div>
        <div id="revealCta" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:4px;"></div>
      </div>
    </div>

    <!-- Controls -->
    <div style="padding:16px;display:flex;flex-direction:column;gap:10px;">
      <!-- Guess input -->
      <div style="position:relative;">
        <input id="guessInput" type="text" placeholder="Oyun adını yaz..."
          autocomplete="off" spellcheck="false"
          style="width:100%;background:#120e08;border:2px solid #2a1c0c;color:#e5e5e5;padding:12px 14px;font-size:11px;font-family:inherit;outline:none;box-sizing:border-box;transition:border-color 0.15s;"
          onfocus="this.style.borderColor='#444'" onblur="this.style.borderColor='#2a1c0c'" />
        <div id="suggestions" style="display:none;position:absolute;top:100%;left:0;right:0;background:#120e08;border:2px solid #2a1c0c;border-top:none;z-index:20;max-height:200px;overflow-y:auto;"></div>
      </div>
      <!-- Buttons row -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        <button id="hintBtn"
          style="font-family:'IBM Plex Mono', monospace;font-size:12px;background:#120e08;border:2px solid #2a1c0c;color:#666677;padding:7px 16px;cursor:pointer;transition:all 0.1s;letter-spacing:0.04em;"
          onmouseover="this.style.borderColor='#555566';this.style.color='#aaa'" onmouseout="this.style.borderColor='#2a1c0c';this.style.color='#666677'">
          💡 İPUCU
        </button>
        <button id="skipBtn"
          style="font-family:'IBM Plex Mono', monospace;font-size:12px;background:#120e08;border:2px solid #2a1c0c;color:#666677;padding:7px 16px;cursor:pointer;transition:all 0.1s;letter-spacing:0.04em;"
          onmouseover="this.style.borderColor='#555566';this.style.color='#aaa'" onmouseout="this.style.borderColor='#2a1c0c';this.style.color='#666677'">
          ✕ BİLMİYORUM
        </button>
        <button id="nextBtn" style="display:none;font-family:'IBM Plex Mono', monospace;font-size:12px;background:#ffc20a;border:none;color:#0a0a0a;padding:7px 20px;cursor:pointer;letter-spacing:0.06em;margin-left:auto;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          SONRAKI →
        </button>
        <!-- Wrong guesses -->
        <div id="wrongGuesses" style="display:flex;gap:4px;flex-wrap:wrap;margin-left:auto;"></div>
      </div>
    </div>
  </div>

  <!-- History dots -->
  <div id="historyDots" style="display:flex;gap:4px;flex-wrap:wrap;margin-top:12px;"></div>

</Layout>

<script define:vars={{ pool, titles }}>
const MAX_LIVES = 5;
const CROPS = [0.15, 0.22, 0.32, 0.45, 0.62, 1.0];
const IMG_BASE = 'https://images.igdb.com/igdb/image/upload/t_screenshot_big/';

let shuffled = [...pool].sort(() => Math.random() - 0.5);
let idx = 0;
let score = 0, streak = 0, totalCount = 0;
let lives = MAX_LIVES;
let level = 0;
let revealed = false;
let wrongGuesses = [];

const canvas = document.getElementById('quizCanvas');
const ctx = canvas.getContext('2d');
canvas.width = 800; canvas.height = 450;

const guessInput = document.getElementById('guessInput');
const suggestionsEl = document.getElementById('suggestions');
const hintBtn = document.getElementById('hintBtn');
const skipBtn = document.getElementById('skipBtn');
const nextBtn = document.getElementById('nextBtn');
const levelDots = document.getElementById('levelDots');
const livesEl = document.getElementById('livesDisplay');
const wrongEl = document.getElementById('wrongGuesses');
const overlay = document.getElementById('revealOverlay');
const historyEl = document.getElementById('historyDots');

function game() { return shuffled[idx % shuffled.length]; }

function normalize(s) {
  return s.toLowerCase().replace(/[^\w\s]/g,'').replace(/\s+/g,' ').trim();
}

function renderLives() {
  livesEl.innerHTML = Array.from({length: MAX_LIVES}, (_, i) =>
    `<span style="color:${i < lives ? '#ef4444' : '#2a1c0c'}">♥</span>`
  ).join('');
}

function renderLevelDots() {
  levelDots.innerHTML = Array.from({length: CROPS.length - 1}, (_, i) =>
    `<div style="width:8px;height:8px;border-radius:50%;background:${i < level ? '#22c55e' : i === level ? '#ffc20a' : '#2a1c0c'};"></div>`
  ).join('');
}

function renderWrong() {
  wrongEl.innerHTML = wrongGuesses.map(w =>
    `<span style="font-family:'IBM Plex Mono', monospace;font-size:11px;color:#ef444466;background:#1a0808;border:1px solid #ef444433;padding:1px 6px;text-decoration:line-through;">${w}</span>`
  ).join('');
}

function addHistory(result) {
  const colors = { correct:'#22c55e', wrong:'#ef4444', skip:'#444455' };
  const dot = document.createElement('div');
  dot.style.cssText = `width:9px;height:9px;border-radius:50%;background:${colors[result]};flex-shrink:0;`;
  historyEl.appendChild(dot);
}

function drawCrop(screenshotId, cropFrac) {
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    const sw = img.width * cropFrac;
    const sh = img.height * cropFrac;
    const sx = Math.random() * Math.max(0, img.width - sw);
    const sy = Math.random() * Math.max(0, img.height - sh);

    ctx.fillStyle = '#0a0907';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.imageSmoothingEnabled = cropFrac > 0.5;
    ctx.drawImage(img, sx, sy, sw, sh, 0, 0, canvas.width, canvas.height);

    ctx.fillStyle = 'rgba(0,0,0,0.12)';
    for (let y = 0; y < canvas.height; y += 4) ctx.fillRect(0, y, canvas.width, 1);

    ctx.fillStyle = 'rgba(5,5,8,0.7)';
    ctx.fillRect(0, canvas.height - 28, canvas.width, 28);
    ctx.fillStyle = '#333344';
    ctx.font = '14px VT323';
    ctx.textAlign = 'left';
    ctx.fillText(`KESİT ${level + 1}/${CROPS.length - 1}  •  ZOOM: ${Math.round(cropFrac * 100)}%`, 10, canvas.height - 8);
  };
  img.onerror = () => {
    ctx.fillStyle = '#120e08';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#333344';
    ctx.font = '20px VT323';
    ctx.textAlign = 'center';
    ctx.fillText('GÖRSEL YÜKLENEMEDI', canvas.width / 2, canvas.height / 2);
  };
  img.src = IMG_BASE + screenshotId + '.jpg';
}

function loadGame() {
  revealed = false;
  lives = MAX_LIVES;
  level = 0;
  wrongGuesses = [];
  guessInput.value = '';
  guessInput.disabled = false;
  guessInput.style.borderColor = '#2a1c0c';
  suggestionsEl.style.display = 'none';
  overlay.style.display = 'none';
  nextBtn.style.display = 'none';
  hintBtn.style.display = '';
  skipBtn.style.display = '';

  const g = game();
  drawCrop(g.screenshots[0], CROPS[0]);
  renderLives();
  renderLevelDots();
  renderWrong();
}

function giveHint() {
  if (revealed || level >= CROPS.length - 2) {
    hintBtn.textContent = '— İPUCU KALMADI —';
    hintBtn.disabled = true;
    return;
  }
  level++;
  const g = game();
  drawCrop(g.screenshots[Math.min(level, g.screenshots.length - 1)], CROPS[level]);
  renderLevelDots();
  if (level >= CROPS.length - 2) { hintBtn.textContent = '— İPUCU KALMADI —'; hintBtn.disabled = true; }
}

function reveal(correct) {
  if (revealed) return;
  revealed = true;
  totalCount++;

  const g = game();
  drawCrop(g.screenshots[g.screenshots.length - 1], 1.0);

  guessInput.disabled = true;
  suggestionsEl.style.display = 'none';
  hintBtn.style.display = 'none';
  skipBtn.style.display = 'none';
  nextBtn.style.display = 'inline-block';

  if (correct) { score++; streak++; addHistory('correct'); }
  else { streak = 0; addHistory('skip'); }

  document.getElementById('scoreVal').textContent = String(score);
  document.getElementById('streakVal').textContent = String(streak);
  document.getElementById('totalVal').textContent = String(totalCount);

  overlay.style.display = 'flex';
  const icon = document.getElementById('revealIcon');
  const titleEl = document.getElementById('revealTitle');
  const meta = document.getElementById('revealMeta');
  const cta = document.getElementById('revealCta');

  icon.textContent = correct ? '✓' : '?';
  icon.style.color = correct ? '#22c55e' : '#ffc20a';
  icon.style.fontSize = '56px';
  titleEl.textContent = g.title;
  titleEl.style.color = correct ? '#22c55e' : '#e5e5e5';
  meta.textContent = [
    g.developer && g.developer[0],
    g.genres && g.genres.slice(0,2).join(' / '),
  ].filter(Boolean).join('  ·  ');

  cta.innerHTML = '';
  if (!correct) {
    const btn = document.createElement('a');
    btn.href = `/games/${g.slug}`;
    btn.textContent = 'OYNAMALISIN →';
    btn.style.cssText = 'background:#ffc20a;color:#0a0a0a;padding:8px 18px;font-family:"VT323",monospace;font-size:12px;font-weight:700;text-decoration:none;letter-spacing:0.06em;';
    cta.appendChild(btn);
  }
  const infoBtn = document.createElement('a');
  infoBtn.href = `/games/${g.slug}`;
  infoBtn.textContent = 'OYUN SAYFASI';
  infoBtn.style.cssText = 'border:2px solid #2a1c0c;color:#888899;padding:8px 18px;font-family:"VT323",monospace;font-size:12px;text-decoration:none;letter-spacing:0.06em;';
  cta.appendChild(infoBtn);
}

function checkGuess(val) {
  if (revealed || !val.trim()) return;
  const g = game();
  if (normalize(val) === normalize(g.title)) {
    guessInput.style.borderColor = '#22c55e';
    reveal(true);
  } else {
    lives--;
    wrongGuesses.push(val.length > 20 ? val.slice(0, 20) + '...' : val);
    renderLives();
    renderWrong();
    guessInput.style.borderColor = '#ef4444';
    guessInput.value = '';
    setTimeout(() => { guessInput.style.borderColor = '#2a1c0c'; }, 600);
    if (lives <= 0) { reveal(false); return; }
    if (!revealed) giveHint();
  }
}

guessInput.addEventListener('input', () => {
  const q = normalize(guessInput.value);
  if (q.length < 2) { suggestionsEl.style.display = 'none'; return; }
  const matches = titles.filter(t => normalize(t).includes(q)).slice(0, 6);
  if (!matches.length) { suggestionsEl.style.display = 'none'; return; }
  suggestionsEl.innerHTML = matches.map(t =>
    `<div class="sug" data-title="${t.replace(/"/g,'&quot;')}"
      style="padding:10px 14px;cursor:pointer;font-size:11px;color:#ccc;border-bottom:1px solid #2a1c0c;transition:background 0.1s;"
      onmouseover="this.style.background='#0d0d1a'" onmouseout="this.style.background='none'">${t}</div>`
  ).join('');
  suggestionsEl.style.display = 'block';
});

suggestionsEl.addEventListener('click', e => {
  const item = e.target.closest('.sug');
  if (!item) return;
  guessInput.value = item.dataset.title;
  suggestionsEl.style.display = 'none';
  checkGuess(item.dataset.title);
});

guessInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') { suggestionsEl.style.display = 'none'; checkGuess(guessInput.value); }
  if (e.key === 'Escape') suggestionsEl.style.display = 'none';
});

document.addEventListener('click', e => {
  if (!suggestionsEl.contains(e.target) && e.target !== guessInput)
    suggestionsEl.style.display = 'none';
});

hintBtn.addEventListener('click', giveHint);
skipBtn.addEventListener('click', () => reveal(false));
nextBtn.addEventListener('click', () => { idx++; hintBtn.textContent = '💡 İPUCU'; hintBtn.disabled = false; loadGame(); });

loadGame();
</script>
