---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import watchData from '../../data/watch.json';
import watchListsData from '../../data/watch-lists.json';

const TMDB_KEY = import.meta.env.PUBLIC_TMDB_KEY;
const IMG = 'https://image.tmdb.org/t/p/w300';
const IMG_S = 'https://image.tmdb.org/t/p/w92';

const STATUS_MAP: Record<string, { label: string; color: string }> = {
  watching:  { label: 'İZLİYORUM',  color: '#3b82f6' },
  completed: { label: 'TAMAMLANDI', color: '#22c55e' },
  watchlist: { label: 'LİSTEDE',    color: '#e5c46b' },
  dropped:   { label: 'BIRAKTI',    color: '#ef4444' },
};

type Entry = { tmdbId: number; type: string; status: string; rating: number | null; note: string | null };

async function fetchTmdb(id: number, type: string) {
  if (!TMDB_KEY) return null;
  try {
    const res = await fetch(`https://api.themoviedb.org/3/${type}/${id}?api_key=${TMDB_KEY}&language=tr-TR`);
    return res.ok ? await res.json() : null;
  } catch { return null; }
}

const entries = watchData as Entry[];
const shows  = entries.filter(e => e.type === 'tv');
const movies = entries.filter(e => e.type === 'movie');

const [showsData, moviesData] = await Promise.all([
  Promise.all(shows.map(e => fetchTmdb(e.tmdbId, 'tv'))),
  Promise.all(movies.map(e => fetchTmdb(e.tmdbId, 'movie'))),
]);

const combined = [
  ...shows.map((e, i) => ({ entry: e, tmdb: showsData[i] })),
  ...movies.map((e, i) => ({ entry: e, tmdb: moviesData[i] })),
].filter(x => x.tmdb);

const watchLists = watchListsData as any[];
const listPosters = await Promise.all(
  watchLists.map(async list => {
    const results = await Promise.all(list.items.slice(0, 4).map((item: any) => fetchTmdb(item.tmdbId, item.type)));
    return results.map((t: any) => t?.poster_path ? IMG_S + t.poster_path : null);
  })
);
---

<Layout title="Dizi & Film">

  <!-- LİSTELER bölümü -->
  <div class="px-window" style="margin-bottom:8px;">
    <div class="px-titlebar" style="border-left-color:#e879f9;">
      <span class="px-title" style="color:#e879f9;">📋 LİSTELER — {watchLists.length} LİSTE</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>

    <div style="display:flex;flex-direction:column;">
      {watchLists.map((list, li) => (
        <a href={`/dizi-film/liste/${list.slug}`}
          style="display:flex;align-items:center;gap:12px;padding:8px 14px;border-bottom:1px solid #1e1e2e;transition:background 0.15s;"
          onmouseover="this.style.background='#111118'" onmouseout="this.style.background='none'">
          <!-- Poster kolajı -->
          <div style="display:flex;gap:1px;flex-shrink:0;">
            {(listPosters[li] || []).filter(Boolean).slice(0,4).map((p: any) => (
              <div style="width:28px;height:42px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;">
                <img src={p} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" />
              </div>
            ))}
          </div>
          <!-- Bilgi -->
          <div style="flex:1;min-width:0;">
            <p style="font-family:'VT323',monospace;font-size:18px;color:#fff;margin:0;letter-spacing:0.02em;line-height:1.2;">{list.title}</p>
            {list.description && <p style="font-size:11px;color:#666677;margin:2px 0 0;line-height:1.4;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{list.description}</p>}
          </div>
          <span style="font-family:'VT323',monospace;font-size:13px;color:#444455;flex-shrink:0;">{list.items.length} yapım</span>
          <span style="font-family:'VT323',monospace;font-size:14px;color:#e879f9;flex-shrink:0;">→</span>
        </a>
      ))}
    </div>
  </div>

  <!-- TÜMÜ bölümü -->
  <div class="px-window">
    <div class="px-titlebar" style="border-left-color:#e879f9;">
      <span class="px-title" style="color:#e879f9;">🎬 TÜMÜ — {combined.length} YAPIM</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>

    <!-- Filtre butonları -->
    <div style="padding:8px 12px;border-bottom:1px solid #1e1e2e;display:flex;gap:4px;flex-wrap:wrap;">
      {(['Tümü', 'Diziler', 'Filmler', 'İzliyorum', 'Tamamlandı', 'Listede'] as const).map((tab, i) => (
        <button class="watch-tab" data-tab={tab}
          style={`font-family:'VT323',monospace;font-size:15px;padding:3px 12px;background:#0d0d12;border:1px solid ${i===0?'#e879f9':'#1e1e2e'};color:${i===0?'#e879f9':'#555566'};cursor:pointer;transition:all 0.1s;letter-spacing:0.04em;`}>
          {tab.toUpperCase()}
        </button>
      ))}
    </div>

    <!-- Poster grid -->
    <div id="watchGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:1px;background:#1e1e2e;">
      {combined.map(({ entry, tmdb }) => {
        const slug = `${entry.type}-${entry.tmdbId}`;
        const title = tmdb.name || tmdb.title || '?';
        const year = (tmdb.first_air_date || tmdb.release_date || '').slice(0, 4);
        const poster = tmdb.poster_path ? IMG + tmdb.poster_path : null;
        const status = STATUS_MAP[entry.status] || STATUS_MAP.watchlist;
        return (
          <a href={`/dizi-film/${slug}`}
            class="watch-card"
            data-type={entry.type}
            data-status={entry.status}
            style="display:flex;flex-direction:column;background:#0d0d12;text-decoration:none;transition:background 0.15s;"
            onmouseover="this.style.background='#111118'" onmouseout="this.style.background='#0d0d12'">
            <div style="width:100%;aspect-ratio:2/3;overflow:hidden;background:#080810;position:relative;">
              {poster
                ? <img src={poster} alt={title} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:36px;">{entry.type==='tv'?'📺':'🎬'}</div>
              }
              <div style={`position:absolute;top:5px;left:5px;font-family:'VT323',monospace;font-size:11px;color:#000;background:${status.color};padding:1px 5px;letter-spacing:0.04em;`}>
                {status.label}
              </div>
            </div>
            <div style="padding:7px 9px;">
              <p style="font-family:'VT323',monospace;font-size:15px;color:#e5e5e5;margin:0 0 2px;line-height:1.2;">{title}</p>
              <div style="display:flex;align-items:center;justify-content:space-between;gap:4px;">
                <span style="font-family:'VT323',monospace;font-size:12px;color:#444455;">{year}</span>
                {entry.rating && <span style="font-family:'VT323',monospace;font-size:13px;color:#e5c46b;">{entry.rating}/10</span>}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {!TMDB_KEY && (
      <div style="padding:24px;text-align:center;">
        <p style="font-family:'VT323',monospace;font-size:16px;color:#ef4444;margin:0 0 6px;">PUBLIC_TMDB_KEY TANIMLI DEĞİL</p>
        <p style="font-size:12px;color:#555566;margin:0;">themoviedb.org adresinden ücretsiz API key alıp Vercel env'e ekle.</p>
      </div>
    )}
  </div>

</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('.watch-tab');
  const cards = document.querySelectorAll<HTMLElement>('.watch-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const t = tab.dataset.tab!;
      tabs.forEach(b => { b.style.color='#555566'; b.style.borderColor='#1e1e2e'; });
      tab.style.color='#e879f9'; tab.style.borderColor='#e879f9';

      cards.forEach(card => {
        const type = card.dataset.type!;
        const status = card.dataset.status!;
        let show = true;
        if (t === 'Diziler')     show = type === 'tv';
        else if (t === 'Filmler')     show = type === 'movie';
        else if (t === 'İzliyorum')   show = status === 'watching';
        else if (t === 'Tamamlandı')  show = status === 'completed';
        else if (t === 'Listede')     show = status === 'watchlist';
        card.style.display = show ? 'flex' : 'none';
      });
    });
  });
</script>
