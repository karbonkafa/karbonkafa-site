---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import watchListsData from '../../../data/watch-lists.json';

const { slug } = Astro.params;
const list = (watchListsData as any[]).find(l => l.slug === slug);
if (!list) return Astro.redirect('/dizi-film');

const TMDB_KEY = import.meta.env.PUBLIC_TMDB_KEY;
const IMG_W = 'https://image.tmdb.org/t/p/w300';
const IMG_S = 'https://image.tmdb.org/t/p/w92';

async function fetchTmdb(id: number, type: string) {
  if (!TMDB_KEY) return null;
  try {
    const res = await fetch(`https://api.themoviedb.org/3/${type}/${id}?api_key=${TMDB_KEY}&language=tr-TR`);
    return res.ok ? await res.json() : null;
  } catch { return null; }
}

const tmdbResults = await Promise.all(
  list.items.map((item: any) => fetchTmdb(item.tmdbId, item.type))
);
---

<Layout title={list.title}>

  <!-- Header -->
  <div class="px-window" style="margin-bottom:12px;">
    <div class="px-titlebar" style="border-left-color:#e879f9;">
      <div style="display:flex;align-items:center;gap:8px;min-width:0;">
        <a href="/dizi-film" style="font-family:'VT323',monospace;font-size:14px;color:#555566;text-decoration:none;transition:color 0.1s;"
          onmouseover="this.style.color='#e879f9'" onmouseout="this.style.color='#555566'">DİZİ & FİLM</a>
        <span style="font-family:'VT323',monospace;font-size:13px;color:#333344;">›</span>
        <a href="/dizi-film#listeler" style="font-family:'VT323',monospace;font-size:14px;color:#555566;text-decoration:none;transition:color 0.1s;"
          onmouseover="this.style.color='#e879f9'" onmouseout="this.style.color='#555566'">LİSTELER</a>
        <span style="font-family:'VT323',monospace;font-size:13px;color:#333344;">›</span>
        <span style="font-family:'VT323',monospace;font-size:13px;color:#444455;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{list.title.toUpperCase()}</span>
      </div>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>
    <div style="padding:16px;">
      <h1 style="font-family:'VT323',monospace;font-size:30px;color:#fff;margin:0 0 8px;letter-spacing:0.02em;">{list.title}</h1>
      {list.description && <p style="font-size:14px;color:#888899;margin:0 0 12px;line-height:1.7;max-width:640px;">{list.description}</p>}
      <div style="display:flex;align-items:center;gap:12px;">
        <span style="font-family:'VT323',monospace;font-size:15px;color:#e879f9;">{list.author}</span>
        <span style="font-family:'VT323',monospace;font-size:14px;color:#444455;">{list.items.length} yapım</span>
      </div>
    </div>
  </div>

  <!-- Items -->
  <div class="px-window">
    <div class="px-titlebar">
      <span class="px-title">🎬 {list.items.length} YAPIM</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>
    <div style="display:flex;flex-direction:column;">
      {list.items.map((item: any, idx: number) => {
        const tmdb = tmdbResults[idx];
        if (!tmdb) return null;
        const title = tmdb.name || tmdb.title || '?';
        const year = (tmdb.first_air_date || tmdb.release_date || '').slice(0, 4);
        const poster = tmdb.poster_path ? IMG_S + tmdb.poster_path : null;
        const genres = (tmdb.genres || []).slice(0, 2).map((g: any) => g.name).join(' · ');
        const tmdbScore = tmdb.vote_average ? Math.round(tmdb.vote_average * 10) / 10 : null;
        return (
          <div style="border-bottom:1px solid #1e1e2e;padding:12px 16px;display:grid;grid-template-columns:28px 60px 1fr;gap:12px;align-items:start;transition:background 0.1s;"
            onmouseover="this.style.background='#0d0d18'" onmouseout="this.style.background='none'">
            <div style="font-family:'VT323',monospace;font-size:18px;color:#2a2a3a;padding-top:4px;text-align:right;">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <a href={`/dizi-film/${item.type}-${item.tmdbId}`} style="display:block;width:60px;height:90px;overflow:hidden;border:1px solid #2a2a3a;flex-shrink:0;transition:border-color 0.15s;"
              onmouseover="this.style.borderColor='#e879f9'" onmouseout="this.style.borderColor='#2a2a3a'">
              {poster
                ? <img src={poster} alt={title} loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block;" />
                : <div style="width:100%;height:100%;background:#0d0d12;display:flex;align-items:center;justify-content:center;font-size:20px;">{item.type === 'tv' ? '📺' : '🎬'}</div>
              }
            </a>
            <div style="display:flex;flex-direction:column;gap:4px;padding-top:2px;">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                <a href={`/dizi-film/${item.type}-${item.tmdbId}`}
                  style="font-size:15px;font-weight:600;color:#e5e5e5;line-height:1.3;transition:color 0.15s;text-decoration:none;"
                  onmouseover="this.style.color='#e879f9'" onmouseout="this.style.color='#e5e5e5'">
                  {title}
                </a>
                {tmdbScore && (
                  <span style="font-family:'VT323',monospace;font-size:15px;color:#aaaacc;flex-shrink:0;">{tmdbScore}</span>
                )}
              </div>
              <p style="font-family:'VT323',monospace;font-size:13px;color:#555566;margin:0;">
                {item.type === 'tv' ? 'DİZİ' : 'FİLM'}{year ? ' · ' + year : ''}{genres ? ' · ' + genres : ''}
              </p>
              {item.note && (
                <p style="font-size:13px;color:#778899;margin:4px 0 0;line-height:1.6;border-left:2px solid #e879f933;padding-left:10px;font-style:italic;">
                  "{item.note}"
                </p>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <div style="margin-top:12px;">
    <a href="/dizi-film" style="font-family:'VT323',monospace;font-size:15px;color:#444455;transition:color 0.1s;"
      onmouseover="this.style.color='#e879f9'" onmouseout="this.style.color='#444455'">← DİZİ & FİLM</a>
  </div>

</Layout>
