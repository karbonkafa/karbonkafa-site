---
import Layout from '../../layouts/Layout.astro';

const missableBase = [
  { name: 'Assassin of Kings', risk: 'very-high', description: 'Radovid assassination — "Reason of State" chain must be done before Isle of Mists' },
  { name: 'Full Crew', risk: 'very-high', description: 'Bring 7 allies to Kaer Morhen — Keira and Triss most commonly missed' },
  { name: 'Card Collector', risk: 'high', description: '10 missable Gwent cards — play Gwent with every merchant and innkeeper' },
  { name: 'Gwent Master', risk: 'high', description: 'Beat Tybalt at the Novigrad Gwent tournament' },
  { name: 'Friends With Benefits', risk: 'high', description: "Complete Keira Metz subplot — don't kill her" },
  { name: 'The Doppler Effect', risk: 'high', description: 'Resolve the doppler problem in Novigrad' },
  { name: 'Woodland Spirit', risk: 'high', description: 'Make the right choice in the Woodland Spirit contract' },
  { name: 'Kingmaker', risk: 'medium', description: 'Complete the Skellige ruler selection subplot' },
  { name: 'Brawl Master', risk: 'medium', description: 'Complete all fistfighting quests in all three regions' },
  { name: 'Fast and Furious', risk: 'medium', description: 'Win all 11 horse races — Crows Perch race must be done before Isle of Mists' },
  { name: 'Fist of the South Star', risk: 'low', description: 'Win a fistfight without taking damage' },
];

const missableHoS = [
  { name: 'Let the Good Times Roll!', risk: 'medium', description: 'Requires specific quest choice' },
  { name: 'Shopaholic', risk: 'low', description: 'Shop from Hearts of Stone merchants' },
  { name: 'Curator of Nightmares', risk: 'high', description: 'Depends on quest choice — read carefully' },
  { name: "When It's Many Against One...", risk: 'medium', description: 'Provoke all nightmares simultaneously' },
];

const missableBaW = [
  { name: 'Last Action Hero', risk: 'medium', description: 'Specific combat condition' },
  { name: 'Kling of the Clink', risk: 'medium', description: 'Prison scenario — make the right choice' },
  { name: 'A Knight to Remember', risk: 'high', description: 'Depends on knightly choices' },
  { name: 'Embodiment of the Five Virtues', risk: 'very-high', description: 'Meet all 5 virtues throughout the game — most commonly missed BaW trophy' },
  { name: 'The Grapes of Wrath Stomped', risk: 'low', description: 'Grape stomping mini-game' },
  { name: 'David and Goylat', risk: 'medium', description: 'Specific enemy condition' },
];

const riskColor = (risk: string) => {
  if (risk === 'very-high') return '#ef4444';
  if (risk === 'high') return '#f97316';
  if (risk === 'medium') return '#eab308';
  return '#22c55e';
};

const riskLabel = (risk: string) => {
  if (risk === 'very-high') return '⛔ Very High';
  if (risk === 'high') return '🔴 High';
  if (risk === 'medium') return '🟡 Medium';
  return '🟢 Low';
};
---

<Layout title="Witcher 3 Platinum Guide" description="The Witcher 3 Wild Hunt PS5 Platinum trophy guide — missable trophies, Full Crew, Assassin of Kings and play order.">

  <!-- Breadcrumb -->
  <div style="margin-bottom: 40px; font-size: 13px; color: #444; font-family: 'JetBrains Mono', monospace;">
    <a href="/guides" style="color: #444;">rehberler</a>
    <span style="margin: 0 8px;">/</span>
    <span style="color: #e5e5e5;">witcher-3</span>
  </div>

  <!-- Header -->
  <div style="margin-bottom: 48px;">
    <div style="display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap;">
      <span style="font-size: 12px; color: #666; border: 1px solid #222; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">PS5 Pro</span>
      <span style="font-size: 12px; color: #e5c46b; border: 1px solid #e5c46b44; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">🏆 Platinum</span>
      <span style="font-size: 12px; color: #666; border: 1px solid #222; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">150–200 h</span>
      <span style="font-size: 12px; color: #22c55e; border: 1px solid #22c55e44; padding: 3px 10px; font-family: 'JetBrains Mono', monospace;">NG+ gerekmez</span>
    </div>
    <h1 style="font-size: clamp(28px, 4vw, 42px); font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">The Witcher 3: Wild Hunt</h1>
    <p style="font-size: 15px; color: #666; margin: 0; line-height: 1.6;">GOTY Edition — 78 trophy (52 base + 13 Hearts of Stone + 13 Blood and Wine). Tek playthrough yeterli.</p>
  </div>

  <!-- Warnings -->
  <div style="border: 1px solid #e5c46b44; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #e5c46b; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">⚠️ Before You Start</p>
    <ol style="margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 10px; font-size: 14px; color: #aaa; line-height: 1.6;">
      <li><strong style="color: #e5e5e5;">Difficulty: Death March</strong> — select from the start, don't change later. "Ran the Gauntlet" required.</li>
      <li><strong style="color: #e5e5e5;">Win the first game against every Gwent opponent</strong> — if you lose, the card is gone.</li>
      <li><strong style="color: #e5e5e5;">Talk to every merchant and innkeeper</strong> — they may sell Gwent cards.</li>
      <li><strong style="color: #e5e5e5;">Check before Isle of Mists</strong> — Full Crew and Assassin of Kings chain must be complete.</li>
      <li><strong style="color: #e5e5e5;">Save manually at critical points</strong> — backup before missable trophies.</li>
    </ol>
  </div>

  <!-- Missable — Parent Game -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophies — Parent Game <span style="font-size: 14px; color: #666; font-weight: 400;">({missableBase.length} total)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableBase.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.description}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Full Crew Detay -->
  <div style="border: 1px solid #ef444444; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #ef4444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">Full Crew — Detay</p>
    <p style="font-size: 14px; color: #aaa; margin: 0 0 16px; line-height: 1.6;">You must bring 7 people to Kaer Morhen:</p>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; margin-bottom: 16px;">
      {['Keira Metz', 'Triss Merigold', 'Vernon Roche', 'Ves', 'Zoltan Chivay', 'Hjalmar an Craite', 'Ermion'].map(k => (
        <div style="padding: 10px 14px; background: #0a0a0a; border: 1px solid #222; font-size: 13px; display: flex; align-items: center; gap: 8px;">
          <span style="color: #666;">□</span> {k}
        </div>
      ))}
    </div>
    <p style="font-size: 13px; color: #888; margin: 0; line-height: 1.6; border-top: 1px solid #222; padding-top: 12px;">
      <strong style="color: #ef4444;">Keira:</strong> "A Favor for a Friend" — send her to Kaer Morhen, don't kill her.<br />
      <strong style="color: #ef4444;">Triss:</strong> "Now or Never" — leave her in Novigrad, don't put her on the boat.
    </p>
  </div>

  <!-- Assassin of Kings Detay -->
  <div style="border: 1px solid #ef444444; background: #111; padding: 24px 28px; margin-bottom: 48px;">
    <p style="font-size: 12px; color: #ef4444; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 16px;">Assassin of Kings — Zincir</p>
    <div style="display: flex; flex-direction: column; gap: 8px; font-size: 14px; font-family: 'JetBrains Mono', monospace;">
      {['1. "A Deadly Plot" — Novigrad', '2. "Redania\'s Most Wanted" — Novigrad', '3. "An Eye for an Eye" — with Roche', '4. "Reason of State" — triggers when chain is complete'].map((s, i) => (
        <div style={`padding: 10px 14px; background: #0a0a0a; border: 1px solid #222; font-size: 13px; color: ${i === 3 ? '#e5c46b' : '#aaa'};`}>{s}</div>
      ))}
    </div>
    <p style="font-size: 13px; color: #ef4444; margin: 12px 0 0; line-height: 1.5;">⛔ This chain must be complete before going to Isle of Mists — no return.</p>
  </div>

  <!-- Hearts of Stone -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophies — Hearts of Stone <span style="font-size: 14px; color: #666; font-weight: 400;">({missableHoS.length} total)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableHoS.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.description}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Blood and Wine -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">
      Missable Trophies — Blood and Wine <span style="font-size: 14px; color: #666; font-weight: 400;">({missableBaW.length} total)</span>
    </h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
      {missableBaW.map(t => (
        <div style="padding: 16px 20px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;">
          <div>
            <p style="font-size: 15px; font-weight: 500; margin: 0 0 4px;">{t.name}</p>
            <p style="font-size: 13px; color: #666; margin: 0; line-height: 1.5;">{t.description}</p>
          </div>
          <span style={`font-size: 11px; white-space: nowrap; font-family: 'JetBrains Mono', monospace; color: ${riskColor(t.risk)};`}>{riskLabel(t.risk)}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Play Order -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">Optimal Play Order</h2>
    <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222; font-family: 'JetBrains Mono', monospace; font-size: 13px;">
      {[
        { region: 'White Orchard', notes: ['Play Gwent with innkeeper, get card', 'Talk to all NPCs'] },
        { region: 'Velen', notes: ['Complete Keira Metz quests → send to Kaer Morhen', 'Do fistfights and horse races as you find them', 'Gwent: check every merchant / innkeeper'] },
        { region: 'Novigrad', notes: ['Triss → "Now or Never" → leave in Novigrad', 'Gwent tournament → beat Tybalt', "Start Radovid chain: Deadly Plot → Redania's Most Wanted", 'Complete The Doppler Effect quest'] },
        { region: 'Skellige', notes: ['Kingmaker subplot', 'Hjalmar + Ermion', 'Clear Gwent opponents'] },
        { region: '⛔ Check before Isle of Mists', notes: ['Full Crew: 7/7?', 'Reason of State chain done?', 'All horse races and fistfights done?'] },
        { region: 'Main story finale', notes: ['Assassin of Kings — correct choices'] },
        { region: 'Hearts of Stone', notes: ['Level 32+ recommended'] },
        { region: 'Blood and Wine', notes: ['Leave for last', 'Be careful with Embodiment of the Five Virtues'] },
      ].map((adim, i) => (
        <div style={`padding: 16px 20px; background: #111; border-left: 2px solid ${adim.region.startsWith('⛔') ? '#ef4444' : '#222'};`}>
          <p style={`font-size: 13px; font-weight: 500; margin: 0 0 8px; color: ${adim.region.startsWith('⛔') ? '#ef4444' : '#e5e5e5'};`}>{i + 1}. {adim.region}</p>
          <ul style="margin: 0; padding-left: 16px; display: flex; flex-direction: column; gap: 4px;">
            {adim.notlar.map(n => (
              <li style="font-size: 12px; color: #666; line-height: 1.5;">{n}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Tracking List -->
  <div style="margin-bottom: 48px;">
    <h2 style="font-size: 20px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 16px; border-bottom: 1px solid #222;">Tracking List</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">

      <div>
        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Parent Game</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Assassin of Kings', 'Full Crew', 'Card Collector', 'Gwent Master', 'Friends With Benefits', 'The Doppler Effect', 'Woodland Spirit', 'Kingmaker', 'Brawl Master', 'Fast and Furious'].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>
      </div>

      <div>
        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Hearts of Stone</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Let the Good Times Roll!', 'Shopaholic', 'Curator of Nightmares', "When It's Many Against One..."].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>

        <p style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 24px 0 12px;">Blood and Wine</p>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          {['Last Action Hero', 'Kling of the Clink', 'A Knight to Remember', 'Embodiment of the Five Virtues', 'The Grapes of Wrath Stomped', 'David and Goylat'].map(t => (
            <label style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: #aaa; cursor: pointer;">
              <input type="checkbox" style="accent-color: #e5c46b;" />
              {t}
            </label>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Platinum banner -->
  <div style="border: 1px solid #e5c46b44; background: #111; padding: 32px; text-align: center;">
    <p style="font-size: 32px; margin: 0 0 8px;">🏆</p>
    <p style="font-size: 18px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.01em;">The Witcher 3: Wild Hunt</p>
    <p style="font-size: 14px; color: #e5c46b; margin: 0; font-family: 'JetBrains Mono", monospace;">Platinum Trophy</p>
  </div>

</Layout>
