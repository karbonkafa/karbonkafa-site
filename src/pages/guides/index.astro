---
import Layout from '../../layouts/Layout.astro';

const guideList = [
  {
    slug: 'witcher-3',
    title: 'The Witcher 3: Wild Hunt',
    platform: 'PS5',
    trophy: 'Platinum',
    missable: 19,
    time: '150–200h',
    status: 'Active',
  }
];
---

<Layout title="Guides">

  <div style="margin-bottom: 48px;">
    <p data-i18n="section.guides" style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Achievement Guides</p>
    <h1 data-i18n="nav.guides" style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Guides</h1>
    <p data-i18n="section.guides.desc" style="font-size: 15px; color: #666; margin: 0;">Missable-focused guides for 100% completion.</p>
  </div>

  <div style="display: flex; flex-direction: column; gap: 1px; border: 1px solid #222;">
    {guideList.map(r => (
      <a href={`/guides/${r.slug}`} style="padding: 24px 28px; background: #111; display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; transition: background 0.15s;" onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
        <div>
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 6px;">
            <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.08em;">{r.platform}</span>
            <span style="font-size: 11px; color: #e5c46b; font-family: 'JetBrains Mono', monospace;">🏆 {r.trophy}</span>
          </div>
          <h2 style="font-size: 17px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.01em;">{r.title}</h2>
          <p style="font-size: 13px; color: #666; margin: 0;">{r.missable} <span data-i18n="guide.missable">missable trophy</span> · {r.time}</p>
        </div>
        <span style={`font-size: 12px; padding: 4px 10px; border: 1px solid ${r.status === 'Active' ? '#e5c46b44' : '#222'}; color: ${r.status === 'Active' ? '#e5c46b' : '#444'}; font-family: 'JetBrains Mono', monospace;`}>{r.status}</span>
      </a>
    ))}
  </div>

</Layout>
