---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['Tümü', 'Duyuru', 'Çıkış', 'Donanım', 'Endüstri', 'Bağımsız', 'Haftalık'];

const categoryColors: Record<string, string> = {
  'Duyuru':   '#4a9eed',
  'Çıkış':    '#22c55e',
  'Donanım':  '#f97316',
  'Endüstri': '#9b59b6',
  'Bağımsız': '#14b8a6',
  'Haftalık': '#e5c46b',
};
---

<Layout title="News">
  <div style="margin-bottom: 48px;">
    <p data-i18n="section.news" style="font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 0.1em; font-family: 'JetBrains Mono', monospace; margin: 0 0 12px;">Karbon News</p>
    <h1 data-i18n="nav.news" style="font-size: 36px; font-weight: 600; letter-spacing: -0.03em; margin: 0 0 12px;">Haberler</h1>
    <p data-i18n="section.news.desc" style="font-size: 15px; color: #666; margin: 0;">Haftalık oyun haberleri. Oyuncu perspektifinden.</p>
  </div>

  <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 40px;">
    {categories.map((cat, i) => (
      <button
        class="cat-btn"
        data-cat={cat}
        style={`font-size: 11px; padding: 4px 12px; border: 1px solid ${i === 0 ? '#e5c46b' : '#333'}; background: none; color: ${i === 0 ? '#e5c46b' : '#666'}; font-family: 'JetBrains Mono', monospace; cursor: pointer; transition: all 0.15s;`}
      >
        {cat}
      </button>
    ))}
  </div>

  {sorted.length === 0 ? (
    <div style="border: 1px solid #222; padding: 48px; text-align: center; color: #444; font-family: 'JetBrains Mono', monospace; font-size: 14px;">
      içerik hazırlanıyor
    </div>
  ) : (
    <div id="newsList" style="border: 1px solid #222;">
      {sorted.map((article) => {
        const color = categoryColors[article.data.category] || '#666';
        const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
        return (
          <a
            href={`/news/${article.id}`}
            class="news-item"
            data-category={article.data.category}
            style="display: block; padding: 24px 28px; background: #111; border-bottom: 1px solid #1a1a1a; transition: background 0.15s;"
            onmouseover="this.style.background='#161616'"
            onmouseout="this.style.background='#111'"
          >
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap;">
              <span style={`font-size: 10px; border: 1px solid ${color}44; color: ${color}; padding: 2px 8px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.06em; flex-shrink: 0;`}>
                {article.data.category}
              </span>
              <span style="font-size: 12px; color: #444; font-family: 'JetBrains Mono', monospace;">{dateStr}</span>
            </div>
            <h2 style="font-size: 17px; font-weight: 600; margin: 0 0 8px; letter-spacing: -0.02em; line-height: 1.3; color: #e5e5e5;">{article.data.title}</h2>
            <p style="font-size: 14px; color: #888; margin: 0 0 14px; line-height: 1.6;">{article.data.excerpt}</p>
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
              <span style="font-size: 11px; color: #444; font-family: 'JetBrains Mono', monospace; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                Kaynak: {article.data.source}
              </span>
              <span style="font-size: 12px; color: #555; font-family: 'JetBrains Mono', monospace; flex-shrink: 0;">oku →</span>
            </div>
          </a>
        );
      })}
    </div>
  )}
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const items = document.querySelectorAll<HTMLElement>('.news-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      buttons.forEach(b => {
        b.style.borderColor = '#333';
        b.style.color = '#666';
      });
      btn.style.borderColor = '#e5c46b';
      btn.style.color = '#e5c46b';
      items.forEach(item => {
        const visible = cat === 'Tümü' || item.dataset.category === cat;
        item.style.display = visible ? 'block' : 'none';
      });
    });
  });
</script>
