---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['Tümü', 'Duyuru', 'Çıkış', 'Donanım', 'Endüstri', 'Bağımsız', 'Haftalık'];

const categoryColors: Record<string, string> = {
  'Duyuru':   '#4a9eed',
  'Çıkış':    '#22c55e',
  'Donanım':  '#f97316',
  'Endüstri': '#9b59b6',
  'Bağımsız': '#14b8a6',
  'Haftalık': '#e5c46b',
};
---

<Layout title="Haberler">

  <div class="px-window">
    <div class="px-titlebar">
      <span class="px-title">📰 HABERLER.LOG — {sorted.length} YAYIM</span>
      <div class="px-btns"><span class="px-btn">─</span><span class="px-btn">□</span><span class="px-btn">×</span></div>
    </div>

    <!-- Category filter -->
    <div style="padding: 10px 14px; border-bottom: 1px solid #1e1e2e; display: flex; gap: 4px; flex-wrap: wrap;">
      {categories.map((cat, i) => (
        <button
          class="cat-btn"
          data-cat={cat}
          style={`font-family:'VT323',monospace; font-size: 16px; padding: 4px 12px; border: 1px solid ${i === 0 ? '#e5c46b' : '#1e1e2e'}; background: #0d0d12; color: ${i === 0 ? '#e5c46b' : '#666677'}; cursor: pointer; transition: all 0.15s; letter-spacing:0.04em;`}
        >
          {cat}
        </button>
      ))}
    </div>

    {sorted.length === 0 ? (
      <div style="padding: 48px; text-align: center; color: #444455; font-family: 'VT323', monospace; font-size: 16px; letter-spacing: 0.04em;">
        İÇERİK HAZIRLANIYOR...
      </div>
    ) : (
      <div id="newsList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: #1e1e2e;">
        {sorted.map((article) => {
          const color = categoryColors[article.data.category] || '#666';
          const dateStr = article.data.date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
          return (
            <a
              href={`/news/${article.id}`}
              class="news-item"
              data-category={article.data.category}
              style="display: flex; flex-direction: column; background: #0d0d12; transition: background 0.15s;"
              onmouseover="this.style.background='#111118'"
              onmouseout="this.style.background='#0d0d12'"
            >
              {article.data.image ? (
                <div style="width: 100%; aspect-ratio: 16/9; overflow: hidden; background: #0a0a0a;">
                  <img
                    src={article.data.image}
                    alt={article.data.title}
                    style="width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s;"
                    onmouseover="this.style.transform='scale(1.03)'"
                    onmouseout="this.style.transform='scale(1)'"
                  />
                </div>
              ) : (
                <div style={`width: 100%; aspect-ratio: 16/9; background: #080810; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid #1e1e2e;`}>
                  <span style={`font-family:'VT323',monospace;font-size:13px;color:${color};text-transform:uppercase;letter-spacing:0.1em;`}>{article.data.category}</span>
                </div>
              )}
              <div style="padding: 16px; display: flex; flex-direction: column; flex: 1;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap;">
                  <span style={`font-family:'VT323',monospace;font-size:13px;border:1px solid ${color}44;color:${color};padding:2px 8px;text-transform:uppercase;letter-spacing:0.06em;flex-shrink:0;`}>
                    {article.data.category}
                  </span>
                  <span style="font-family:'VT323',monospace;font-size:13px;color:#444455;">{dateStr}</span>
                </div>
                <h2 style="font-size:15px;font-weight:600;margin:0 0 8px;letter-spacing:-0.02em;line-height:1.35;color:#e5e5e5;flex:1;">{article.data.title}</h2>
                <p style="font-size:12px;color:#666677;margin:0 0 12px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{article.data.excerpt}</p>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:auto;">
                  <span style="font-family:'VT323',monospace;font-size:13px;color:#444455;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    {article.data.source}
                  </span>
                  <span style="font-family:'VT323',monospace;font-size:13px;color:#555566;flex-shrink:0;">OKU →</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const items = document.querySelectorAll<HTMLElement>('.news-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      buttons.forEach(b => {
        b.style.borderColor = '#1e1e2e';
        b.style.color = '#666677';
      });
      btn.style.borderColor = '#e5c46b';
      btn.style.color = '#e5c46b';
      items.forEach(item => {
        const visible = cat === 'Tümü' || item.dataset.category === cat;
        item.style.display = visible ? 'flex' : 'none';
      });
    });
  });
</script>
